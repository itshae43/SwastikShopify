{% doc %}
  Renders a product card for the collection grids.

  @param {product} product - The product object to render.
{% enddoc %}

{% assign current_variant = product.selected_or_first_available_variant %}
{% assign original_price = current_variant.compare_at_price %}
{% assign price = current_variant.price %}

{% assign class_prefix_default = class_prefix | default: 'best-sellers' %}

<div class="{{ class_prefix_default }}__card" data-product-id="{{ product.id }}">
  <!-- Image Area -->
  <div class="{{ class_prefix_default }}__image-wrapper">
    {% if badge_text != blank %}
      <span class="{{ class_prefix_default }}__card-tag">{{ badge_text }}</span>
    {% elsif original_price > price %}
      <span class="{{ class_prefix_default }}__card-tag">SALE</span>
    {% endif %}
    <button class="{{ class_prefix_default }}__wishlist-btn" aria-label="Add to Wishlist">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
      </svg>
    </button>
    
    <div class="{{ class_prefix_default }}__img-slides">
      {% if product.images.size > 0 %}
        {% for image in product.images limit: 3 %}
          <img src="{{ image | image_url: width: 400, height: 400 }}" 
               alt="{{ product.title | escape }}" 
               class="{{ class_prefix_default }}__img{% if forloop.first %} active{% endif %}"
               data-index="{{ forloop.index0 }}"
               loading="lazy"
               width="400"
               height="400">
        {% endfor %}
      {% else %}
        {% capture placeholder_class %}placeholder-svg {{ class_prefix_default }}__img active{% endcapture %}
        {{ 'product-1' | placeholder_svg_tag: placeholder_class }}
      {% endif %}
    </div>

    <!-- Carousel Dots Indicator -->
    {% if product.images.size > 1 %}
      <div class="{{ class_prefix_default }}__dots">
        {% for image in product.images limit: 3 %}
          <button class="dot{% if forloop.first %} dot--active{% endif %}" data-slide-to="{{ forloop.index0 }}" aria-label="Slide {{ forloop.index }}"></button>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <!-- Content Area -->
  <div class="{{ class_prefix_default }}__card-content">
    <h3 class="{{ class_prefix_default }}__card-title">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>
    <p class="{{ class_prefix_default }}__card-desc">{{ product.vendor | default: '18K Gold • BIS Hallmarked' }}</p>
    
    <!-- Pricing Row -->
    <div class="{{ class_prefix_default }}__price-row">
      <span class="price-current">{{ price | money }}</span>
      {% if original_price > price %}
        <span class="price-original">{{ original_price | money }}</span>
        {% assign discount = original_price | minus: price | times: 100.0 | divided_by: original_price | round %}
        <span class="price-discount">{{ discount }}% OFF</span>
      {% endif %}
    </div>

    <!-- Button Group -->
    {% form 'product', product %}
      <input type="hidden" name="id" value="{{ current_variant.id }}">
      <div class="{{ class_prefix_default }}__button-group">
        <button type="submit" class="btn-add-cart">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
          </svg>
          ADD TO CART
        </button>
        <a href="{{ product.url }}" class="btn-quick-view" aria-label="View Details">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
            <circle cx="12" cy="12" r="3"/>
          </svg>
        </a>
      </div>
    {% endform %}
  </div>
</div>
