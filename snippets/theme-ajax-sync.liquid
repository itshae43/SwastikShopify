{% doc %}
  Global theme script to manage card click behavior, AJAX add-to-cart,
  wishlist toggle synchronization, and visual toast notifications.

  @example
  {% render 'theme-ajax-sync' %}
{% enddoc %}

<style>
  /* Toast Notification Styling */
  .toast-container {
    position: fixed;
    top: 2rem;
    right: 2rem;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    pointer-events: none;
  }

  .toast-item {
    background: rgba(1, 63, 62, 0.95);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(212, 175, 55, 0.3);
    color: #FFFFFF;
    padding: 1.6rem 2.4rem;
    border-radius: 8px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
    display: flex;
    align-items: center;
    gap: 1.6rem;
    width: 360px;
    pointer-events: auto;
    transform: translateX(120%);
    transition: transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275), opacity 0.5s ease;
    opacity: 0;
  }

  .toast-item.show {
    transform: translateX(0);
    opacity: 1;
  }

  .toast-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.8rem;
    height: 2.8rem;
    border-radius: 50%;
    background: rgba(212, 175, 55, 0.15);
    color: #D4AF37;
    flex-shrink: 0;
  }

  .toast-content {
    flex-grow: 1;
  }

  .toast-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.4rem;
    font-weight: 600;
    margin-bottom: 0.2rem;
    letter-spacing: 0.05em;
  }

  .toast-message {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.2rem;
    opacity: 0.8;
  }

  .toast-action {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.2rem;
    color: #D4AF37;
    text-decoration: underline;
    font-weight: 500;
    cursor: pointer;
  }

  /* Add cursor styles to cards */
  .best-sellers__card,
  .new-arrivals__card {
    cursor: pointer;
  }

  /* Reset cursor for interactive components in card */
  .best-sellers__card button,
  .best-sellers__card a,
  .best-sellers__card .dot,
  .new-arrivals__card button,
  .new-arrivals__card a,
  .new-arrivals__card .dot {
    cursor: auto;
  }
  
  .best-sellers__wishlist-btn,
  .new-arrivals__wishlist-btn,
  .btn-add-cart,
  .btn-quick-view,
  .dot {
    cursor: pointer !important;
  }

  /* loading state for add to cart button */
  .btn-add-cart.btn-loading {
    opacity: 0.7;
    pointer-events: none;
    position: relative;
  }
  
  .btn-add-cart.btn-loading::after {
    content: "";
    position: absolute;
    width: 16px;
    height: 16px;
    top: 50%;
    left: 50%;
    margin-top: -8px;
    margin-left: -8px;
    border: 2px solid transparent;
    border-top-color: currentColor;
    border-radius: 50%;
    animation: toast-spinner 0.6s linear infinite;
  }

  @keyframes toast-spinner {
    to { transform: rotate(360deg); }
  }
  
  /* Make heart filled and red when active */
  .best-sellers__wishlist-btn.active svg,
  .new-arrivals__wishlist-btn.active svg,
  .product-single__wishlist-btn.active svg {
    fill: #E25C5C;
    stroke: #E25C5C;
  }
</style>

<div class="toast-container" id="toast-container"></div>

<script>
  (function() {
    // 1. Initialize Mock Wishlist & Cart from initial values in header badges
    const wishlistBadge = document.getElementById('wishlist-count-badge');
    const cartBadge = document.getElementById('cart-count-badge');

    // Wishlist Initialization
    let wishlist = [];
    try {
      const storedWishlist = localStorage.getItem('wishlist');
      if (storedWishlist) {
        wishlist = JSON.parse(storedWishlist);
      } else {
        // Pre-fill with dummy ids if initial badge is positive
        const initialCount = wishlistBadge ? parseInt(wishlistBadge.innerText) || 0 : 0;
        for (let i = 0; i < initialCount; i++) {
          wishlist.push('mock-id-' + i);
        }
        localStorage.setItem('wishlist', JSON.stringify(wishlist));
      }
    } catch(e) {
      console.error('Local storage error: ', e);
    }
    updateWishlistBadge();

    // Cart Initialization
    let cartCount = 0;
    try {
      const storedCart = localStorage.getItem('cart_count');
      if (storedCart) {
        cartCount = parseInt(storedCart) || 0;
      } else {
        cartCount = cartBadge ? parseInt(cartBadge.innerText) || 0 : 0;
        localStorage.setItem('cart_count', cartCount);
      }
    } catch(e) {
      console.error(e);
    }
    updateCartBadge();

    // Set initial active state of wishlist heart buttons on load
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('[data-product-id]').forEach(card => {
        const id = card.getAttribute('data-product-id');
        if (wishlist.includes(id)) {
          const heart = card.querySelector('.best-sellers__wishlist-btn, .new-arrivals__wishlist-btn, .product-single__wishlist-btn');
          if (heart) heart.classList.add('active');
        }
      });
    });

    // Helper functions to update Badges
    window.updateWishlistBadge = function() {
      if (!wishlistBadge) return;
      const count = wishlist.length;
      wishlistBadge.innerText = count;
      wishlistBadge.style.display = count > 0 ? 'inline-flex' : 'none';
    };

    window.updateCartBadge = function() {
      if (!cartBadge) return;
      cartBadge.innerText = cartCount;
      cartBadge.style.display = cartCount > 0 ? 'inline-flex' : 'none';
    };

    // 2. Global Toast Notification Generator
    window.showSwastikToast = function(title, message, isCart = false) {
      const container = document.getElementById('toast-container');
      if (!container) return;

      const toast = document.createElement('div');
      toast.className = 'toast-item';
      
      const iconSVG = isCart 
        ? `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>`
        : `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`;

      toast.innerHTML = `
        <div class="toast-icon">
          ${iconSVG}
        </div>
        <div class="toast-content">
          <div class="toast-title">${title}</div>
          <div class="toast-message">${message}</div>
        </div>
        ${isCart ? `<a href="/cart" class="toast-action">View Cart</a>` : ''}
      `;

      container.appendChild(toast);

      // Trigger animation
      setTimeout(() => {
        toast.classList.add('show');
      }, 50);

      // Remove after 4 seconds
      setTimeout(() => {
        toast.classList.remove('show');
        setTimeout(() => {
          toast.remove();
        }, 500);
      }, 4000);
    };

    // 3. (Removed JS card-wide click interceptor in favor of native title link pseudo-element for better performance)

    // 4. AJAX Wishlist click interceptor
    document.addEventListener('click', (e) => {
      const btn = e.target.closest('.best-sellers__wishlist-btn, .new-arrivals__wishlist-btn, .product-single__wishlist-btn, .product-card-ui__wishlist');
      if (!btn) return;

      e.preventDefault();
      e.stopPropagation();

      const card = btn.closest('[data-product-id]');
      if (!card) return;

      const productId = card.getAttribute('data-product-id');
      const url = card.getAttribute('data-url') || '#';
      const titleElement = card.querySelector('.best-sellers__card-title, .new-arrivals__card-title, .product-single__title, .product-single__heading, .product-card-ui__title');
      const productTitle = titleElement ? titleElement.innerText.trim() : 'Product';
      
      const priceElement = card.querySelector('.price-current, .price-item--regular');
      const productPrice = priceElement ? priceElement.innerText.trim().replace(/[^0-9.-]+/g,"") * 100 : 0;
      
      const imgElement = card.querySelector('img');
      const productImg = imgElement ? imgElement.src : '';

      btn.classList.toggle('active');

      if (btn.classList.contains('active')) {
        if (!wishlist.includes(productId)) {
          wishlist.push(productId);
          localStorage.setItem('wishlist', JSON.stringify(wishlist));
          
          let detailedWishlist = JSON.parse(localStorage.getItem('wishlist_items_data') || '[]');
          detailedWishlist.push({
            id: productId,
            title: productTitle,
            price: productPrice,
            image: productImg,
            url: url
          });
          localStorage.setItem('wishlist_items_data', JSON.stringify(detailedWishlist));
        }
        window.updateWishlistBadge();
        
        // Open Sidebar Drawer instead of Toast
        if (window.openWishlistDrawer) {
          window.openWishlistDrawer();
        } else {
          showSwastikToast('Added to Wishlist', `${productTitle} has been saved to your likes.`, false);
        }
      } else {
        wishlist = wishlist.filter(id => id !== productId);
        localStorage.setItem('wishlist', JSON.stringify(wishlist));
        
        let detailedWishlist = JSON.parse(localStorage.getItem('wishlist_items_data') || '[]');
        detailedWishlist = detailedWishlist.filter(item => item.id !== productId);
        localStorage.setItem('wishlist_items_data', JSON.stringify(detailedWishlist));

        window.updateWishlistBadge();
        
        if (window.renderDrawerContent && document.getElementById('SidebarDrawer').classList.contains('open')) {
          window.renderDrawerContent();
        } else {
          showSwastikToast('Removed from Wishlist', `${productTitle} has been removed.`, false);
        }
      }
    });

    // 5. AJAX Add to Cart interceptor
    document.addEventListener('submit', (e) => {
      const form = e.target;
      
      // Match forms submitting to shopify add-to-cart or forms with product IDs
      const isCartForm = form.action.includes('/cart/add') || form.querySelector('[name="id"]') !== null;
      if (!isCartForm) return;

      e.preventDefault();

      const submitBtn = form.querySelector('[type="submit"], .btn-add-cart');
      if (submitBtn) submitBtn.classList.add('btn-loading');

      // Get quantity
      const qtyInput = form.querySelector('[name="quantity"]');
      const qtyVal = qtyInput ? parseInt(qtyInput.value) || 1 : 1;

      // Get Product title for Toast
      let title = 'Product';
      const card = form.closest('[data-product-id]') || document.querySelector('.product-single');
      if (card) {
        const titleElement = card.querySelector('.best-sellers__card-title, .new-arrivals__card-title, .product-single__title, .product-single__heading, h1');
        if (titleElement) title = titleElement.innerText.trim();
      }

      // Form data handling for detailed mock cart
      const cardId = card ? card.getAttribute('data-product-id') : ('mock-' + Date.now());
      const url = card ? (card.getAttribute('data-url') || '#') : '#';
      const priceElement = card ? card.querySelector('.price-current, .price-item--regular') : null;
      const productPrice = priceElement ? priceElement.innerText.trim().replace(/[^0-9.-]+/g,"") * 100 : 0;
      const imgElement = card ? card.querySelector('img') : null;
      const productImg = imgElement ? imgElement.src : '';

      function handleAddToCartSuccess() {
        cartCount += qtyVal;
        localStorage.setItem('cart_count', cartCount);
        
        // Save detailed data
        let detailedCart = JSON.parse(localStorage.getItem('cart_items_data') || '[]');
        const existingItem = detailedCart.find(i => i.id === cardId);
        if (existingItem) {
          existingItem.quantity += qtyVal;
        } else {
          detailedCart.push({
            id: cardId,
            title: title,
            price: productPrice,
            image: productImg,
            url: url,
            quantity: qtyVal
          });
        }
        localStorage.setItem('cart_items_data', JSON.stringify(detailedCart));
        window.updateCartBadge();

        if (submitBtn) submitBtn.classList.remove('btn-loading');
        
        // Open Sidebar Drawer instead of Toast
        if (window.openCartDrawer) {
          window.openCartDrawer();
        } else {
          showSwastikToast('Added to Cart', `${qtyVal} x ${title} added!`, true);
        }
      }

      // Perform AJAX Post
      fetch('/cart/add.js', {
        method: 'POST',
        body: new FormData(form)
      })
      .then(response => {
        handleAddToCartSuccess();
      })
      .catch(error => {
        console.warn('Shopify Cart API error, falling back to Mock Cart. ', error);
        handleAddToCartSuccess();
      });
    });

    // 6. Header Triggers for Drawer (using event delegation for reliability)
    document.addEventListener('click', (e) => {
      const wishlistTrigger = e.target.closest('.header__wishlist-trigger');
      if (wishlistTrigger) {
        e.preventDefault();
        if (window.openWishlistDrawer) window.openWishlistDrawer();
        return;
      }

      const cartTrigger = e.target.closest('.header__cart-trigger');
      if (cartTrigger) {
        e.preventDefault();
        if (window.openCartDrawer) window.openCartDrawer();
        return;
      }
    });

    // 7. Buy It Now button behavior
    document.addEventListener('click', (e) => {
      const buyNowBtn = e.target.closest('.btn-buy-now');
      if (buyNowBtn) {
        e.preventDefault();
        const form = buyNowBtn.closest('form');
        if (form) {
          const returnInput = document.createElement('input');
          returnInput.type = 'hidden';
          returnInput.name = 'return_to';
          returnInput.value = '/checkout';
          form.appendChild(returnInput);
          form.submit();
        }
      }
    });

  })();
</script>
