{% doc %}
  Renders the fallback product grid for the best-sellers section.
  @param {string} type - The category type: 'pendants', 'earrings', 'rings-bracelets'
{% enddoc %}

{% for i in (1..4) %}
  {% capture fallback_title %}
    {% if type == 'pendants' %}
      {% case i %}
        {% when 1 %}Golden Teardrop Pendant
        {% when 2 %}Diamond Solitaire Pendant
        {% when 3 %}Emerald Halo Pendant
        {% when 4 %}Classic Gold Locket
      {% endcase %}
    {% elsif type == 'earrings' %}
      {% case i %}
        {% when 1 %}Floral Drop Earrings
        {% when 2 %}Classic Gold Studs
        {% when 3 %}Diamond Hoop Earrings
        {% when 4 %}Sapphire Drop Earrings
      {% endcase %}
    {% else %}
      {% case i %}
        {% when 1 %}Twist Diamond Ring
        {% when 2 %}Infinity Link Bracelet
        {% when 3 %}Classic Solitaire Ring
        {% when 4 %}Gold Bangle Bracelet
      {% endcase %}
    {% endif %}
  {% endcapture %}

  {% capture fallback_desc %}
    {% if type == 'pendants' %}
      18K Gold • BIS Hallmarked
    {% elsif type == 'earrings' %}
      18K Gold • BIS Hallmarked
    {% else %}
      {% case i %}
        {% when 1 or 3 %}18K Gold • BIS Hallmarked
        {% else %}22K Gold • BIS Hallmarked
      {% endcase %}
    {% endif %}
  {% endcapture %}

  {% capture fallback_price %}
    {% if type == 'pendants' %}
      {% case i %}
        {% when 1 %}₹24,999
        {% when 2 %}₹29,999
        {% when 3 %}₹34,999
        {% when 4 %}₹19,999
      {% endcase %}
    {% elsif type == 'earrings' %}
      {% case i %}
        {% when 1 %}₹18,999
        {% when 2 %}₹12,499
        {% when 3 %}₹26,999
        {% when 4 %}₹22,999
      {% endcase %}
    {% else %}
      {% case i %}
        {% when 1 %}₹22,999
        {% when 2 %}₹20,999
        {% when 3 %}₹25,499
        {% when 4 %}₹32,999
      {% endcase %}
    {% endif %}
  {% endcapture %}

  {% capture fallback_original_price %}
    {% if type == 'pendants' %}
      {% case i %}
        {% when 1 %}₹31,999
        {% when 2 %}₹38,999
        {% when 3 %}₹44,999
        {% when 4 %}₹25,999
      {% endcase %}
    {% elsif type == 'earrings' %}
      {% case i %}
        {% when 1 %}₹24,999
        {% when 2 %}₹16,499
        {% when 3 %}₹33,999
        {% when 4 %}₹29,999
      {% endcase %}
    {% else %}
      {% case i %}
        {% when 1 %}₹28,999
        {% when 2 %}₹26,999
        {% when 3 %}₹32,999
        {% when 4 %}₹41,999
      {% endcase %}
    {% endif %}
  {% endcapture %}

  {% capture fallback_discount %}
    {% if type == 'pendants' %}
      {% case i %}
        {% when 1 %}22% OFF
        {% when 2 %}23% OFF
        {% when 3 %}22% OFF
        {% when 4 %}23% OFF
      {% endcase %}
    {% elsif type == 'earrings' %}
      {% case i %}
        {% when 1 %}24% OFF
        {% when 2 %}24% OFF
        {% when 3 %}20% OFF
        {% when 4 %}23% OFF
      {% endcase %}
    {% else %}
      {% case i %}
        {% when 1 %}21% OFF
        {% when 2 %}22% OFF
        {% when 3 %}22% OFF
        {% when 4 %}21% OFF
      {% endcase %}
    {% endif %}
  {% endcapture %}

  {% capture img_1 %}
    {% if type == 'pendants' %}
      {% case i %}
        {% when 1 %}best_seller_pendant.png
        {% when 2 %}pendant_placeholder.png
        {% when 3 %}necklace_placeholder.png
        {% when 4 %}best_seller_pendant.png
      {% endcase %}
    {% elsif type == 'earrings' %}
      {% case i %}
        {% when 1 %}best_seller_earrings.png
        {% when 2 %}earring_placeholder.png
        {% when 3 %}best_seller_earrings.png
        {% when 4 %}earring_placeholder.png
      {% endcase %}
    {% else %}
      {% case i %}
        {% when 1 %}best_seller_ring.png
        {% when 2 %}best_seller_bracelet.png
        {% when 3 %}ring_placeholder.png
        {% when 4 %}bangle_placeholder.png
      {% endcase %}
    {% endif %}
  {% endcapture %}

  {% capture img_2 %}
    {% if type == 'pendants' %}
      best_seller_pendant_2.png
    {% elsif type == 'earrings' %}
      best_seller_earrings_2.png
    {% else %}
      {% case i %}
        {% when 1 or 3 %}best_seller_ring_2.png
        {% else %}best_seller_bracelet_2.png
      {% endcase %}
    {% endif %}
  {% endcapture %}

  {% capture img_3 %}
    {% if type == 'pendants' %}
      best_seller_pendant_3.png
    {% elsif type == 'earrings' %}
      best_seller_earrings_3.png
    {% else %}
      {% case i %}
        {% when 1 or 3 %}best_seller_ring_3.png
        {% else %}best_seller_bracelet_3.png
      {% endcase %}
    {% endif %}
  {% endcapture %}

  {% assign fallback_url = '/products/golden-teardrop-pendant' %}
  {% assign fallback_id = 'mock-' | append: type | append: '-' | append: i %}
  <div class="best-sellers__card" data-product-id="{{ fallback_id }}" data-url="{{ fallback_url }}" data-product-index="{{ i }}" data-fallback-card>
    <!-- Image Area -->
    <div class="best-sellers__image-wrapper">
      <span class="best-sellers__card-tag">BEST SELLER</span>
      <button class="best-sellers__wishlist-btn" aria-label="Add to Wishlist">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
        </svg>
      </button>
      
      <a href="{{ fallback_url }}" class="best-sellers__image-link" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1;">
        <div class="best-sellers__img-slides" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;">
          <img src="{{ img_1 | strip | asset_url }}" 
               alt="{{ fallback_title | strip }}" 
               class="best-sellers__img active"
               data-index="0"
               width="400"
               height="400"
               loading="lazy"
               onerror="this.src='{{ 'logo.png' | asset_url }}'; this.style.opacity='0.2';">
          <img src="{{ img_2 | strip | asset_url }}" 
               alt="{{ fallback_title | strip }}" 
               class="best-sellers__img"
               data-index="1"
               width="400"
               height="400"
               loading="lazy"
               onerror="this.src='{{ 'logo.png' | asset_url }}'; this.style.opacity='0.2';">
          <img src="{{ img_3 | strip | asset_url }}" 
               alt="{{ fallback_title | strip }}" 
               class="best-sellers__img"
               data-index="2"
               width="400"
               height="400"
               loading="lazy"
               onerror="this.src='{{ 'logo.png' | asset_url }}'; this.style.opacity='0.2';">
        </div>
      </a>

      <!-- Carousel Dots Indicator -->
      <div class="best-sellers__dots">
        <button class="dot dot--active" data-slide-to="0" aria-label="Slide 1"></button>
        <button class="dot" data-slide-to="1" aria-label="Slide 2"></button>
        <button class="dot" data-slide-to="2" aria-label="Slide 3"></button>
      </div>
    </div>

    <!-- Content Area -->
    <div class="best-sellers__card-content">
      <h3 class="best-sellers__card-title">
        <a href="{{ fallback_url }}">{{ fallback_title | strip }}</a>
      </h3>
      <p class="best-sellers__card-desc">{{ fallback_desc | strip }}</p>
      
      <!-- Pricing Row -->
      <div class="best-sellers__price-row">
        <span class="price-current">{{ fallback_price | strip }}</span>
        <span class="price-original">{{ fallback_original_price | strip }}</span>
        <span class="price-discount">{{ fallback_discount | strip }}</span>
      </div>

      <!-- Button Group -->
      <div class="best-sellers__button-group">
        <button class="btn-add-cart">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
          </svg>
          ADD TO CART
        </button>
        <a href="{{ fallback_url }}" class="btn-quick-view" aria-label="Quick View">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
            <circle cx="12" cy="12" r="3"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
{% endfor %}
