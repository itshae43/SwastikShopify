{% doc %}
  Renders responsive breadcrumb navigation for products, collections, and pages.

  @param {object} [product] - The product object
  @param {object} [collection] - The collection object

  @example
  {% render 'breadcrumb', product: product, collection: collection %}
{% enddoc %}

<nav class="pp-breadcrumb-nav" aria-label="Breadcrumb">
  <div class="pp-breadcrumb-container">
    <ol class="pp-breadcrumb-list">
      <li class="pp-breadcrumb-item">
        <a href="{{ routes.root_url }}" class="pp-breadcrumb-link">
          <svg class="pp-home-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
            <polyline points="9 22 9 12 15 12 15 22"></polyline>
          </svg>
          <span>Home</span>
        </a>
      </li>

      <li class="pp-breadcrumb-separator" aria-hidden="true">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
      </li>

      {%- if collection -%}
        <li class="pp-breadcrumb-item">
          <a href="{{ collection.url }}" class="pp-breadcrumb-link">{{ collection.title }}</a>
        </li>
        <li class="pp-breadcrumb-separator" aria-hidden="true">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
        </li>
      {%- elsif product and product.collections.first -%}
        <li class="pp-breadcrumb-item">
          <a href="{{ product.collections.first.url }}" class="pp-breadcrumb-link">{{ product.collections.first.title }}</a>
        </li>
        <li class="pp-breadcrumb-separator" aria-hidden="true">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
        </li>
      {%- elsif product and product.type != blank -%}
        <li class="pp-breadcrumb-item">
          <a href="/collections/all?filter.p.product_type={{ product.type | url_encode }}" class="pp-breadcrumb-link">{{ product.type }}</a>
        </li>
        <li class="pp-breadcrumb-separator" aria-hidden="true">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
        </li>
      {%- else -%}
        <li class="pp-breadcrumb-item">
          <a href="/collections/all" class="pp-breadcrumb-link">Jewellery</a>
        </li>
        <li class="pp-breadcrumb-separator" aria-hidden="true">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
        </li>
      {%- endif -%}

      {%- if product -%}
        <li class="pp-breadcrumb-item is-active" aria-current="page">
          <span class="pp-breadcrumb-current" title="{{ product.title | escape }}">{{ product.title }}</span>
        </li>
      {%- endif -%}
    </ol>
  </div>
</nav>
