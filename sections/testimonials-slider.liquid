{%- liquid
  assign bg_color = section.settings.bg_color | default: '#fdfbf7'
  assign text_color = section.settings.text_color | default: '#0a2a26'
  assign accent_color = section.settings.accent_color | default: '#b38245'
-%}

<div class="testimonials-v2 section-spacing" id="TestimonialsSlider-{{ section.id }}" style="--bg-color: {{ bg_color }}; --text-color: {{ text_color }}; --accent-color: {{ accent_color }};" data-autoplay="{{ section.settings.autoplay }}" data-autoplay-speed="{{ section.settings.autoplay_speed }}">
  <div class="testimonials-v2__container">
    
    <div class="testimonials-v2__left">
      {%- if section.settings.subheading != blank -%}
        <div class="testimonials-v2__subheading">{{ section.settings.subheading | escape }}</div>
      {%- endif -%}
      
      {%- if section.settings.title != blank -%}
        <h2 class="testimonials-v2__heading serif-font">{{ section.settings.title | newline_to_br }}</h2>
      {%- endif -%}
      
      <div class="testimonials-v2__divider"></div>

      <div class="testimonials-v2__stats">
        {%- if section.settings.stat_1_value != blank -%}
          <div class="testimonials-v2__stat">
            <div class="testimonials-v2__stat-value">{{ section.settings.stat_1_value }}</div>
            <div class="testimonials-v2__stat-label">{{ section.settings.stat_1_label }}</div>
          </div>
        {%- endif -%}
        
        {%- if section.settings.stat_2_value != blank -%}
          <div class="testimonials-v2__stat">
            <div class="testimonials-v2__stat-value">{{ section.settings.stat_2_value }}</div>
            <div class="testimonials-v2__stat-label">{{ section.settings.stat_2_label }}</div>
          </div>
        {%- endif -%}
        
        {%- if section.settings.stat_3_value != blank -%}
          <div class="testimonials-v2__stat">
            <div class="testimonials-v2__stat-value">{{ section.settings.stat_3_value }}</div>
            <div class="testimonials-v2__stat-label">{{ section.settings.stat_3_label }}</div>
          </div>
        {%- endif -%}

        {%- if section.settings.stat_4_value != blank -%}
          <div class="testimonials-v2__stat">
            <div class="testimonials-v2__stat-value">{{ section.settings.stat_4_value }}</div>
            <div class="testimonials-v2__stat-label">{{ section.settings.stat_4_label }}</div>
          </div>
        {%- endif -%}
      </div>
    </div>

    <div class="testimonials-v2__right">
      <div class="testimonials-v2__slider-viewport" data-slider-viewport>
        <div class="testimonials-v2__slider-track" data-slider-track>
          {%- for block in section.blocks -%}
            <div class="testimonials-v2__card-wrapper" data-slide-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
              <div class="testimonials-v2__card">
                <div class="testimonials-v2__card-header">
                  <div class="testimonials-v2__quote-icon">
                    <svg viewBox="0 0 24 20" fill="currentColor">
                      <path d="M5.5 20c-1.8 0-3.3-.7-4.5-2C.3 16.7 0 15 0 13c0-2.8 1-5.6 3.1-8.3C5.2 2 8 0 11.5 0v3.5C9.2 4.7 7.7 6.2 7 8c1.3.2 2.3.8 3 1.8.8 1 1.2 2.3 1.2 3.7 0 1.8-.6 3.3-1.8 4.5S6.8 20 5.5 20zm12 0c-1.8 0-3.3-.7-4.5-2-1.2-1.3-1.8-3-1.8-5 0-2.8 1-5.6 3.1-8.3C17.2 2 20 0 23.5 0v3.5c-2.3 1.2-3.8 2.7-4.5 4.5 1.3.2 2.3.8 3 1.8.8 1 1.2 2.3 1.2 3.7 0 1.8-.6 3.3-1.8 4.5s-2.6 2-3.9 2z"/>
                    </svg>
                  </div>
                  {%- if block.settings.rating > 0 -%}
                    <div class="testimonials-v2__rating" aria-label="{{ block.settings.rating }} out of 5 stars">
                      {%- for i in (1..5) -%}
                        {%- if i <= block.settings.rating -%}
                          <svg class="star star--filled" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                        {%- else -%}
                          <svg class="star star--empty" viewBox="0 0 24 24" fill="currentColor" opacity="0.2"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                  {%- endif -%}
                </div>
                
                <blockquote class="testimonials-v2__text">
                  <p>{{ block.settings.text | escape }}</p>
                </blockquote>
                
                <div class="testimonials-v2__meta">
                  <div class="testimonials-v2__author-row">
                    <span class="testimonials-v2__author">- {{ block.settings.author | escape }}</span>
                  </div>
                  <div class="testimonials-v2__location-row">
                    <span class="testimonials-v2__verify">VERIFIED PURCHASE</span>
                    <span class="testimonials-v2__dot">&bull;</span>
                    <span class="testimonials-v2__location">{{ block.settings.location | escape | upcase }}</span>
                  </div>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
      
      {%- if section.blocks.size > 1 -%}
        <div class="testimonials-v2__dots-container">
          <div class="testimonials-v2__dots" data-slider-dots>
            {%- for block in section.blocks -%}
              <button class="testimonials-v2__dot {% if forloop.first %}is-active{% endif %}" aria-label="Go to slide {{ forloop.index }}" data-index="{{ forloop.index0 }}"></button>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
      
    </div>
  </div>
</div>

{% stylesheet %}
.testimonials-v2 {
  background-color: var(--bg-color, #fdfbf7);
  padding: 6rem 0;
  overflow: hidden;
}

.testimonials-v2__container {
  max-width: 1400px;
  margin: 0 auto;
  display: flex;
  gap: 3.5rem;
  padding-left: 4.8rem;
  padding-right: 2rem;
  align-items: center;
}

.testimonials-v2__left {
  flex: 0 0 320px;
  max-width: 350px;
  padding-right: 0;
}

.testimonials-v2__subheading {
  font-family: 'Montserrat', sans-serif;
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--text-color, #0a2a26);
  text-transform: uppercase;
  letter-spacing: 0.2em;
  margin-bottom: 1.6rem;
  opacity: 0.75;
}

.testimonials-v2__heading {
  font-size: 3.8rem;
  color: var(--text-color, #0a2a26);
  margin: 0 0 2rem 0;
  font-weight: 400;
  line-height: 1.2;
}

.testimonials-v2__divider {
  height: 2px;
  background-color: var(--accent-color, #b38245);
  width: 70px;
  margin-bottom: 3.5rem;
}

.testimonials-v2__stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2.5rem 2rem;
}

.testimonials-v2__stat {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  text-align: left;
}

.testimonials-v2__stat-icon {
  width: 32px;
  height: 32px;
  color: var(--accent-color, #b38245);
  margin-bottom: 1.2rem;
}

.testimonials-v2__stat-value {
  font-family: 'Montserrat', sans-serif;
  font-size: 1.8rem;
  font-weight: 700;
  color: var(--text-color, #0a2a26);
  margin-bottom: 0.4rem;
}

.testimonials-v2__stat-label {
  font-family: 'Montserrat', sans-serif;
  font-size: 1.15rem;
  font-weight: 500;
  color: var(--text-color, #0a2a26);
  opacity: 0.7;
}

.testimonials-v2__right {
  flex: 1;
  min-width: 0;
  position: relative;
  display: flex;
  flex-direction: column;
}

.testimonials-v2__slider-viewport {
  overflow-x: auto;
  overflow-y: visible;
  padding: 2rem 0 3rem 0;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none; /* Firefox */
  mask-image: linear-gradient(to right, black 85%, transparent 100%);
  -webkit-mask-image: linear-gradient(to right, black 85%, transparent 100%);
}

.testimonials-v2__slider-viewport::-webkit-scrollbar {
  display: none; /* Chrome/Safari */
}

.testimonials-v2__slider-track {
  display: flex;
  gap: 2.4rem;
  width: max-content;
  padding-left: 0;
  padding-right: 6rem;
}

.testimonials-v2__card-wrapper {
  scroll-snap-align: start;
  scroll-snap-stop: always;
  flex-shrink: 0;
  width: 330px;
  transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.4s ease;
  filter: drop-shadow(0 4px 15px rgba(0,0,0,0.04));
}

.testimonials-v2__card {
  background: #ffffff;
  border-radius: 30px;
  padding: 3.2rem 2.8rem;
  position: relative;
  display: flex;
  flex-direction: column;
  height: 100%;
}

.testimonials-v2__card::after {
  content: '';
  position: absolute;
  bottom: -12px;
  left: 60px; /* Aligned roughly with the start of the author text */
  width: 0;
  height: 0;
  border-left: 12px solid transparent;
  border-right: 12px solid transparent;
  border-top: 12px solid #ffffff;
}

.testimonials-v2__card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 1.6rem;
}

.testimonials-v2__quote-icon {
  color: var(--accent-color, #b38245);
  width: 20px;
  line-height: 0;
}

.testimonials-v2__rating {
  display: flex;
  gap: 2px;
}

.testimonials-v2__rating .star {
  width: 15px;
  height: 15px;
  color: var(--accent-color, #b38245);
}

.testimonials-v2__text {
  margin: 0 0 2.4rem 0;
  flex-grow: 1;
}

.testimonials-v2__text p {
  font-family: 'Montserrat', sans-serif;
  font-size: 1.4rem;
  line-height: 1.5;
  color: var(--text-color, #0a2a26);
  margin: 0;
  font-weight: 500;
}

.testimonials-v2__meta {
  margin-top: auto;
}

.testimonials-v2__author-row {
  margin-bottom: 0.6rem;
}

.testimonials-v2__author {
  font-family: 'Montserrat', sans-serif;
  font-size: 1.35rem;
  font-weight: 700;
  color: var(--text-color, #0a2a26);
}

.testimonials-v2__location-row {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-family: 'Montserrat', sans-serif;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  color: var(--text-color, #0a2a26);
  opacity: 0.5;
}

.testimonials-v2__dots-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 2rem 0 0 0;
  width: 100%;
}

.testimonials-v2__dots {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
}

.testimonials-v2__dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  border: 1.5px solid var(--accent-color, #b38245);
  background-color: transparent;
  padding: 0;
  cursor: pointer;
  opacity: 0.5;
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}

.testimonials-v2__dot.is-active {
  width: 26px;
  height: 10px;
  border-radius: 5px;
  background-color: var(--accent-color, #b38245);
  border-color: var(--accent-color, #b38245);
  opacity: 1;
}

.testimonials-v2__card-wrapper {
  scroll-snap-align: start;
  scroll-snap-stop: always;
  flex-shrink: 0;
  width: 330px;
  opacity: 0.8;
  transform: scale(0.98);
  transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.4s ease, filter 0.4s ease;
  filter: drop-shadow(0 2px 8px rgba(0,0,0,0.03));
}

.testimonials-v2__card-wrapper.is-active {
  opacity: 1;
  transform: scale(1);
  filter: drop-shadow(0 6px 20px rgba(0,0,0,0.07));
}

@media (max-width: 990px) {
  .testimonials-v2 {
    padding: 5rem 0;
  }
  .testimonials-v2__container {
    flex-direction: column;
    padding-left: 2rem;
    padding-right: 2rem;
    gap: 2rem;
  }
  .testimonials-v2__left {
    flex: 0 0 auto;
    width: 100%;
    max-width: 100%;
    padding-right: 0;
    text-align: center;
    margin-bottom: 1rem;
  }
  .testimonials-v2__heading {
    font-size: 3.2rem;
  }
  .testimonials-v2__divider {
    margin: 0 auto 2.5rem auto;
  }
  .testimonials-v2__stat {
    align-items: center;
    text-align: center;
  }
  .testimonials-v2__stats {
    max-width: 400px;
    margin: 0 auto;
  }
  .testimonials-v2__slider-viewport {
    mask-image: none;
    -webkit-mask-image: none;
    margin: 0 -2rem; /* Bleed out on mobile */
    padding: 1.5rem 2rem;
  }
  .testimonials-v2__card-wrapper {
    width: 290px;
  }
  .testimonials-v2__dots-container {
    justify-content: center;
  }
}
{% endstylesheet %}

{% javascript %}
document.addEventListener('DOMContentLoaded', () => {
  const initSliders = () => {
    document.querySelectorAll('.testimonials-v2').forEach(section => {
      if (section.dataset.initialized) return;
      section.dataset.initialized = true;

      const viewport = section.querySelector('[data-slider-viewport]');
      const track = section.querySelector('[data-slider-track]');
      const dots = section.querySelectorAll('.testimonials-v2__dot');
      const cards = section.querySelectorAll('.testimonials-v2__card-wrapper');

      if (!viewport || !dots.length) return;

      const updateDots = () => {
        const viewportLeft = viewport.scrollLeft;
        let closestIndex = 0;
        let minDistance = Infinity;

        cards.forEach((card, index) => {
          const cardLeft = card.offsetLeft;
          const distance = Math.abs(viewportLeft - cardLeft);
          if (distance < minDistance) {
            minDistance = distance;
            closestIndex = index;
          }
        });

        dots.forEach((dot, index) => {
          if (index === closestIndex) {
            dot.classList.add('is-active');
          } else {
            dot.classList.remove('is-active');
          }
        });

        cards.forEach((card, index) => {
          if (index === closestIndex) {
            card.classList.add('is-active');
          } else {
            card.classList.remove('is-active');
          }
        });
      };

      // Listen to scroll events on the viewport
      let scrollTimeout;
      viewport.addEventListener('scroll', () => {
        if (scrollTimeout) {
          window.cancelAnimationFrame(scrollTimeout);
        }
        scrollTimeout = window.requestAnimationFrame(updateDots);
      });

      // Handle dot clicks
      dots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
          const card = cards[index];
          if (card) {
            const scrollLeft = card.offsetLeft;
            viewport.scrollTo({
              left: scrollLeft,
              behavior: 'smooth'
            });
          }
        });
      });
      
      // Auto setup initial dot
      updateDots();
      setTimeout(updateDots, 150);

      // Autoplay logic
      const autoplay = section.dataset.autoplay === 'true';
      const autoplaySpeed = parseInt(section.dataset.autoplaySpeed, 10) * 1000 || 6000;
      let autoplayInterval;

      const startAutoplay = () => {
        if (!autoplay) return;
        stopAutoplay();
        autoplayInterval = setInterval(() => {
          let activeIndex = Array.from(dots).findIndex(dot => dot.classList.contains('is-active'));
          let nextIndex = (activeIndex + 1) % dots.length;
          
          const card = cards[nextIndex];
          if (card) {
            const scrollLeft = card.offsetLeft;
            viewport.scrollTo({
              left: scrollLeft,
              behavior: 'smooth'
            });
          }
        }, autoplaySpeed);
      };

      const stopAutoplay = () => {
        if (autoplayInterval) clearInterval(autoplayInterval);
      };

      if (autoplay) {
        startAutoplay();
        viewport.addEventListener('mouseenter', stopAutoplay);
        viewport.addEventListener('mouseleave', startAutoplay);
        viewport.addEventListener('touchstart', stopAutoplay, {passive: true});
        viewport.addEventListener('touchend', startAutoplay, {passive: true});
      }
    });
  };
  
  initSliders();
  document.addEventListener('shopify:section:load', initSliders);
});
{% endjavascript %}

