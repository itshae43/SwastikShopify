{%- liquid
  assign bg_color = section.settings.bg_color | default: '#fdfbf7'
  assign text_color = section.settings.text_color | default: '#0a2a26'
  assign accent_color = section.settings.accent_color | default: '#b38245'
-%}

<div class="testimonials-slider section-spacing" id="TestimonialsSlider-{{ section.id }}" style="--bg-color: {{ bg_color }}; --text-color: {{ text_color }}; --accent-color: {{ accent_color }};" data-section-id="{{ section.id }}" data-autoplay="{{ section.settings.autoplay }}" data-autoplay-speed="{{ section.settings.autoplay_speed }}">
  <div class="testimonials-slider__container">
    
    {%- if section.settings.subheading != blank or section.settings.title != blank or section.settings.description != blank -%}
      <div class="testimonials-slider__header">
        {%- if section.settings.subheading != blank -%}
          <div class="testimonials-slider__subheading-wrapper">
            <span class="testimonials-slider__divider-line"></span>
            <span class="testimonials-slider__subheading">{{ section.settings.subheading | escape }}</span>
            <span class="testimonials-slider__divider-line"></span>
          </div>
        {%- endif -%}
        
        {%- if section.settings.title != blank -%}
          <h2 class="testimonials-slider__heading serif-font">{{ section.settings.title | escape }}</h2>
        {%- endif -%}
        
        {%- if section.settings.description != blank -%}
          <p class="testimonials-slider__description">{{ section.settings.description | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="testimonials-slider__slider-wrapper">
      
      <button class="testimonials-slider__arrow testimonials-slider__arrow--left" aria-label="Previous testimonial" type="button">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <div class="testimonials-slider__viewport">
        <div class="testimonials-slider__track" data-count="{{ section.blocks.size }}">
          {%- liquid
            assign clones_before = ''
            assign originals = ''
            assign clones_after = ''
          -%}

          {%- for block in section.blocks -%}
            {%- capture card_inner -%}
              <div class="testimonials-slider__quote-icon-wrapper">
                <svg class="testimonials-slider__quote-icon" viewBox="0 0 24 20" fill="currentColor">
                  <path d="M5.5 20c-1.8 0-3.3-.7-4.5-2C.3 16.7 0 15 0 13c0-2.8 1-5.6 3.1-8.3C5.2 2 8 0 11.5 0v3.5C9.2 4.7 7.7 6.2 7 8c1.3.2 2.3.8 3 1.8.8 1 1.2 2.3 1.2 3.7 0 1.8-.6 3.3-1.8 4.5S6.8 20 5.5 20zm12 0c-1.8 0-3.3-.7-4.5-2-1.2-1.3-1.8-3-1.8-5 0-2.8 1-5.6 3.1-8.3C17.2 2 20 0 23.5 0v3.5c-2.3 1.2-3.8 2.7-4.5 4.5 1.3.2 2.3.8 3 1.8.8 1 1.2 2.3 1.2 3.7 0 1.8-.6 3.3-1.8 4.5s-2.6 2-3.9 2z"/>
                </svg>
              </div>
              
              {%- if block.settings.rating > 0 -%}
                <div class="testimonials-slider__rating" aria-label="{{ block.settings.rating }} out of 5 stars">
                  {%- for i in (1..5) -%}
                    {%- if i <= block.settings.rating -%}
                      <svg class="star star--filled" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                      </svg>
                    {%- else -%}
                      <svg class="star star--empty" viewBox="0 0 24 24" fill="currentColor" opacity="0.2">
                        <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                      </svg>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              {%- endif -%}

              {%- if block.settings.text != blank -%}
                <blockquote class="testimonials-slider__text">
                  <p>{{ block.settings.text | escape }}</p>
                </blockquote>
              {%- endif -%}

              <div class="testimonials-slider__meta">
                {%- if block.settings.author != blank -%}
                  <cite class="testimonials-slider__author">{{ block.settings.author | escape }}</cite>
                {%- endif -%}
                {%- if block.settings.location != blank -%}
                  <span class="testimonials-slider__location">{{ block.settings.location | escape }}</span>
                {%- endif -%}
              </div>
            {%- endcapture -%}

            {%- capture clone_html -%}
              <div class="testimonials-slider__card testimonials-slider__card--clone" data-index="{{ forloop.index0 }}">
                {{ card_inner }}
              </div>
            {%- endcapture -%}

            {%- capture original_html -%}
              <div class="testimonials-slider__card testimonials-slider__card--original" {{ block.shopify_attributes }} data-index="{{ forloop.index0 }}">
                {{ card_inner }}
              </div>
            {%- endcapture -%}

            {%- assign clones_before = clones_before | append: clone_html -%}
            {%- assign originals = originals | append: original_html -%}
            {%- assign clones_after = clones_after | append: clone_html -%}
          {%- endfor -%}

          {%- if section.blocks.size > 0 -%}
            {{ clones_before }}
            {{ originals }}
            {{ clones_after }}
          {%- endif -%}
        </div>
      </div>

      <button class="testimonials-slider__arrow testimonials-slider__arrow--right" aria-label="Next testimonial" type="button">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>

    </div>

    <div class="testimonials-slider__dots">
      {%- for block in section.blocks -%}
        <button class="testimonials-slider__dot{% if forloop.first %} testimonials-slider__dot--active{% endif %}" aria-label="Go to slide {{ forloop.index }}" data-slide="{{ forloop.index0 }}" type="button"></button>
      {%- endfor -%}
    </div>

  </div>
</div>

{% stylesheet %}
.testimonials-slider {
  background-color: var(--bg-color, #fdfbf7);
  padding-top: 8rem;
  padding-bottom: 8rem;
  border-top: 1px solid rgba(10, 42, 38, 0.05);
  border-bottom: 1px solid rgba(10, 42, 38, 0.05);
  overflow: hidden;
}

.testimonials-slider__container {
  max-width: 1400px;
  margin: 0 auto;
  padding-left: 4.8rem;
  padding-right: 4.8rem;
  position: relative;
}

.testimonials-slider__header {
  margin-bottom: 5rem;
  text-align: center;
}

.testimonials-slider__subheading-wrapper {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 2.4rem;
  width: 100%;
  margin-bottom: 1.6rem;
}

.testimonials-slider__divider-line {
  height: 1px;
  background-color: var(--accent-color, #b38245);
  width: 60px;
  opacity: 0.3;
}

.testimonials-slider__subheading {
  font-family: 'Montserrat', sans-serif;
  font-size: 1.2rem;
  font-weight: 600;
  color: var(--accent-color, #b38245);
  text-transform: uppercase;
  letter-spacing: 0.25em;
  white-space: nowrap;
}

.testimonials-slider__heading {
  font-size: 3.8rem;
  color: var(--text-color, #0a2a26);
  margin: 0 0 1.6rem 0;
  font-weight: 500;
  line-height: 1.25;
}

.testimonials-slider__description {
  font-family: 'Montserrat', sans-serif;
  font-size: 1.5rem;
  color: var(--text-color, #0a2a26);
  opacity: 0.75;
  margin: 0 auto;
  max-width: 600px;
  line-height: 1.5;
}

.testimonials-slider__slider-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  width: 100%;
}

.testimonials-slider__viewport {
  width: 100%;
  overflow: hidden;
  padding: 3rem 6rem;
}

.testimonials-slider__track {
  display: flex;
  gap: 2.4rem;
  width: 100%;
  align-items: center;
  position: relative;
  /* Hardware acceleration for smooth scrolling */
  will-change: transform;
}

.testimonials-slider__card {
  background: #ffffff;
  border-radius: 16px;
  border: 1px solid rgba(10, 42, 38, 0.08);
  padding: 3rem 2.8rem;
  text-align: left;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  position: relative;
  box-shadow: 0 4px 16px rgba(10, 42, 38, 0.02);
  flex: 0 0 350px;
  height: 260px;
  transition: opacity 0.6s ease, box-shadow 0.6s ease, border-color 0.6s ease, transform 0.6s ease;
  opacity: 0.5;
  transform: scale(0.95);
}

.testimonials-slider__card--active {
  opacity: 1;
  transform: scale(1);
  border-color: rgba(179, 130, 69, 0.35);
  box-shadow: 0 12px 32px rgba(179, 130, 69, 0.08);
}

.testimonials-slider__quote-icon-wrapper {
  color: var(--accent-color, #b38245);
  opacity: 0.15;
  margin-bottom: 1.2rem;
  display: block;
}

.testimonials-slider__quote-icon {
  width: 2.2rem;
  height: 1.8rem;
  transition: all 0.3s ease;
}

.testimonials-slider__rating {
  display: flex;
  gap: 0.3rem;
  margin-bottom: 1.2rem;
  position: relative;
  z-index: 1;
}

.testimonials-slider__rating .star {
  width: 1.2rem;
  height: 1.2rem;
  color: var(--accent-color, #b38245);
  transition: all 0.3s ease;
}

.testimonials-slider__text {
  margin: 0 0 1.6rem 0;
  padding: 0;
  position: relative;
  z-index: 1;
  flex-grow: 1;
}

.testimonials-slider__text p {
  font-family: 'Montserrat', sans-serif;
  font-size: 1.45rem;
  line-height: 1.5;
  color: var(--text-color, #0a2a26);
  margin: 0;
  font-weight: 400;
  font-style: italic;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 4;
  transition: all 0.3s ease;
}

.testimonials-slider__meta {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  margin-top: auto;
  position: relative;
  z-index: 1;
}

.testimonials-slider__author {
  font-family: 'Montserrat', sans-serif;
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--text-color, #0a2a26);
  font-style: normal;
  transition: all 0.3s ease;
}

.testimonials-slider__location {
  font-family: 'Montserrat', sans-serif;
  font-size: 1.15rem;
  font-weight: 600;
  color: var(--accent-color, #b38245);
  text-transform: uppercase;
  letter-spacing: 0.15em;
  transition: all 0.3s ease;
}

.testimonials-slider__arrow {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(179, 130, 69, 0.3);
  color: var(--accent-color, #b38245);
  width: 4.6rem;
  height: 4.6rem;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.3s ease;
  position: absolute;
  z-index: 3;
  box-shadow: 0 4px 12px rgba(10, 42, 38, 0.04);
  top: 50%;
  transform: translateY(-50%);
}

.testimonials-slider__arrow svg {
  width: 2rem;
  height: 2rem;
}

.testimonials-slider__arrow--left {
  left: 0.8rem;
}

.testimonials-slider__arrow--right {
  right: 0.8rem;
}

.testimonials-slider__dots {
  display: flex;
  justify-content: center;
  gap: 1rem;
  margin-top: 4rem;
}

.testimonials-slider__dot {
  width: 0.6rem;
  height: 0.6rem;
  border-radius: 50%;
  background-color: var(--accent-color, #b38245);
  opacity: 0.25;
  border: none;
  padding: 0;
  cursor: pointer;
  transition: opacity 0.3s ease, transform 0.3s ease;
}

.testimonials-slider__dot:hover {
  opacity: 0.5;
}

.testimonials-slider__dot--active {
  opacity: 1;
  transform: scale(1.4);
}

@media (hover: hover) {
  .testimonials-slider__arrow:hover {
    background-color: #ffffff;
    border-color: var(--accent-color, #b38245);
    color: var(--accent-color, #b38245);
    box-shadow: 0 6px 16px rgba(179, 130, 69, 0.15);
    transform: translateY(-50%) scale(1.05);
  }
}

@media screen and (max-width: 1024px) {
  .testimonials-slider__viewport {
    padding: 3rem 4rem;
  }
  .testimonials-slider__card {
    flex: 0 0 300px;
    height: 240px;
    padding: 2.6rem;
  }
  .testimonials-slider__arrow--left {
    left: 0.4rem;
  }
  .testimonials-slider__arrow--right {
    right: 0.4rem;
  }
}

@media screen and (max-width: 768px) {
  .testimonials-slider {
    padding-top: 6rem;
    padding-bottom: 6rem;
  }
  .testimonials-slider__container {
    padding-left: 2rem;
    padding-right: 2rem;
    padding-bottom: 7rem;
  }
  .testimonials-slider__slider-wrapper {
    position: relative;
  }
  .testimonials-slider__viewport {
    padding: 2rem 0;
  }
  .testimonials-slider__heading {
    font-size: 3rem;
    margin-bottom: 1.2rem;
  }
  .testimonials-slider__subheading-wrapper {
    gap: 1.6rem;
    margin-bottom: 1.2rem;
  }
  .testimonials-slider__divider-line {
    width: 40px;
  }
  .testimonials-slider__subheading {
    font-size: 1.1rem;
    letter-spacing: 0.2em;
  }
  .testimonials-slider__description {
    font-size: 1.4rem;
    max-width: 100%;
    line-height: 1.45;
  }
  .testimonials-slider__card {
    flex: 0 0 calc(100% - 96px);
    max-width: 280px;
    height: 250px;
    padding: 2.4rem 2rem;
  }
  .testimonials-slider__text p {
    font-size: 1.35rem;
    line-height: 1.45;
    -webkit-line-clamp: 4;
  }
  .testimonials-slider__arrow {
    display: flex;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 3.2rem;
    height: 3.2rem;
    z-index: 3;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(179, 130, 69, 0.3);
    box-shadow: 0 4px 12px rgba(10, 42, 38, 0.04);
  }
  .testimonials-slider__arrow svg {
    width: 1.4rem;
    height: 1.4rem;
  }
  .testimonials-slider__arrow--left {
    left: 0.8rem;
    right: auto;
    bottom: auto;
  }
  .testimonials-slider__arrow--right {
    right: 0.8rem;
    left: auto;
    bottom: auto;
  }
  .testimonials-slider__dots {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    margin: 0;
    height: 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }
}
{% endstylesheet %}

{% javascript %}
class TestimonialsSlider {
  constructor(element) {
    this.slider = element;
    this.track = element.querySelector('.testimonials-slider__track');
    this.cards = Array.from(element.querySelectorAll('.testimonials-slider__card'));
    this.prevBtn = element.querySelector('.testimonials-slider__arrow--left');
    this.nextBtn = element.querySelector('.testimonials-slider__arrow--right');
    this.dots = Array.from(element.querySelectorAll('.testimonials-slider__dot'));
    
    this.originalCount = parseInt(this.track.getAttribute('data-count') || '0', 10);
    if (!this.track || this.originalCount === 0) return;

    // Start in the middle set of originals to allow infinite scroll both ways
    this.currentIndex = this.originalCount;
    this.autoplay = element.getAttribute('data-autoplay') === 'true';
    this.autoplaySpeed = parseInt(element.getAttribute('data-autoplay-speed'), 10) * 1000 || 5000;
    this.autoplayTimer = null;
    
    this.startX = 0;
    this.currentTranslate = 0;
    this.prevTranslate = 0;
    this.isDragging = false;
    this.isTransitioning = false;
    this.transitionDuration = 600; // ms matching CSS
    
    this.init();
  }

  init() {
    this.updateSlider(false);

    if (this.prevBtn) {
      this.prevBtn.addEventListener('click', () => {
        if (this.isTransitioning) return;
        this.slidePrev();
        this.resetAutoplay();
      });
    }

    if (this.nextBtn) {
      this.nextBtn.addEventListener('click', () => {
        if (this.isTransitioning) return;
        this.slideNext();
        this.resetAutoplay();
      });
    }

    this.dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        if (this.isTransitioning) return;
        this.slideTo(index);
        this.resetAutoplay();
      });
    });

    this.track.addEventListener('touchstart', (e) => this.touchStart(e));
    this.track.addEventListener('touchmove', (e) => this.touchMove(e));
    this.track.addEventListener('touchend', () => this.touchEnd());
    
    this.track.addEventListener('mousedown', (e) => this.touchStart(e));
    this.track.addEventListener('mousemove', (e) => this.touchMove(e));
    this.track.addEventListener('mouseup', () => this.touchEnd());
    this.track.addEventListener('mouseleave', () => {
      if (this.isDragging) this.touchEnd();
    });

    this.slider.addEventListener('mouseenter', () => this.stopAutoplay());
    this.slider.addEventListener('mouseleave', () => this.startAutoplay());

    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        this.updateSlider(false);
      }, 100);
    });

    this.startAutoplay();
  }

  slideTo(realIndex) {
    this.currentIndex = this.originalCount + realIndex;
    this.updateSlider(true);
  }

  slideNext() {
    this.isTransitioning = true;
    this.currentIndex++;
    this.updateSlider(true);
    this.checkLoop();
  }

  slidePrev() {
    this.isTransitioning = true;
    this.currentIndex--;
    this.updateSlider(true);
    this.checkLoop();
  }

  checkLoop() {
    setTimeout(() => {
      if (this.currentIndex >= this.originalCount * 2) {
        // Snapped past the right edge, instantly jump back to original set
        this.currentIndex -= this.originalCount;
        this.updateSlider(false);
      } else if (this.currentIndex < this.originalCount) {
        // Snapped past the left edge, instantly jump forward to original set
        this.currentIndex += this.originalCount;
        this.updateSlider(false);
      }
      this.isTransitioning = false;
    }, this.transitionDuration);
  }

  updateSlider(withTransition = true) {
    if (withTransition) {
      this.track.style.transition = `transform ${this.transitionDuration}ms cubic-bezier(0.16, 1, 0.3, 1)`;
    } else {
      this.track.style.transition = 'none';
    }

    this.cards.forEach((card, index) => {
      if (index === this.currentIndex) {
        card.classList.add('testimonials-slider__card--active');
        card.setAttribute('aria-current', 'true');
      } else {
        card.classList.remove('testimonials-slider__card--active');
        card.removeAttribute('aria-current');
      }
    });

    const viewportWidth = this.track.parentElement.offsetWidth;
    const activeCard = this.cards[this.currentIndex];
    
    if (activeCard) {
      const cardCenter = activeCard.offsetLeft + (activeCard.offsetWidth / 2);
      this.currentTranslate = (viewportWidth / 2) - cardCenter;
    }

    this.track.style.transform = `translateX(${this.currentTranslate}px)`;
    this.prevTranslate = this.currentTranslate;

    const realIndex = this.currentIndex % this.originalCount;
    this.dots.forEach((dot, index) => {
      if (index === realIndex) {
        dot.classList.add('testimonials-slider__dot--active');
        dot.setAttribute('aria-selected', 'true');
      } else {
        dot.classList.remove('testimonials-slider__dot--active');
        dot.setAttribute('aria-selected', 'false');
      }
    });
  }

  startAutoplay() {
    if (!this.autoplay) return;
    this.autoplayTimer = setInterval(() => this.slideNext(), this.autoplaySpeed);
  }

  stopAutoplay() {
    if (this.autoplayTimer) {
      clearInterval(this.autoplayTimer);
    }
  }

  resetAutoplay() {
    this.stopAutoplay();
    this.startAutoplay();
  }

  touchStart(e) {
    if (this.isTransitioning) return;
    this.isDragging = true;
    this.startX = this.getPositionX(e);
    this.track.style.transition = 'none';
    this.stopAutoplay();
  }

  touchMove(e) {
    if (!this.isDragging || this.isTransitioning) return;
    const currentX = this.getPositionX(e);
    const diff = currentX - this.startX;
    const dragTranslate = this.prevTranslate + diff;
    this.track.style.transform = `translateX(${dragTranslate}px)`;
  }

  touchEnd() {
    if (!this.isDragging) return;
    this.isDragging = false;
    
    // Get current transform value
    const style = window.getComputedStyle(this.track);
    const matrix = new WebKitCSSMatrix(style.transform);
    const endTranslate = matrix.m41;
    
    const movedBy = endTranslate - this.prevTranslate;
    const threshold = 50;

    if (movedBy < -threshold) {
      this.slideNext();
    } else if (movedBy > threshold) {
      this.slidePrev();
    } else {
      this.updateSlider(true);
    }
    
    this.startAutoplay();
  }

  getPositionX(e) {
    return e.type.includes('mouse') ? e.pageX : e.touches[0].clientX;
  }
}

document.addEventListener('DOMContentLoaded', () => {
  const initSliders = () => {
    document.querySelectorAll('.testimonials-slider').forEach(slider => {
      if (!slider.dataset.initialized) {
        new TestimonialsSlider(slider);
        slider.dataset.initialized = 'true';
      }
    });
  };
  initSliders();
  document.addEventListener('shopify:section:load', (event) => {
    const slider = event.target.querySelector('.testimonials-slider');
    if (slider) {
      new TestimonialsSlider(slider);
      slider.dataset.initialized = 'true';
    }
  });
});
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.testimonials_slider.name",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "t:sections.testimonials_slider.settings.title",
      "default": "In Their Own Words"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.testimonials_slider.settings.subheading",
      "default": "OUR REVIEW"
    },
    {
      "type": "text",
      "id": "description",
      "label": "t:sections.testimonials_slider.settings.description",
      "default": "More than reviews — stories of love, celebration, and cherished moments."
    },
    {
