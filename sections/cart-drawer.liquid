<div id="CartDrawer" class="cart-drawer" aria-hidden="true">
  <div class="cart-drawer__overlay" onclick="closeCartDrawer()"></div>
  <div class="cart-drawer__content">
    <div class="cart-drawer__header">
      <h2 class="cart-drawer__title">Your Cart (<span id="CartDrawerCount">0</span>)</h2>
      <button type="button" class="cart-drawer__close" aria-label="Close cart" onclick="closeCartDrawer()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <div class="cart-drawer__body" id="CartDrawerBody">
      <div class="cart-drawer__empty">
        <svg class="empty-cart-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007Z" />
        </svg>
        <p>Your cart is currently empty.</p>
        <button type="button" class="btn-continue" onclick="closeCartDrawer()">Continue Shopping</button>
      </div>
    </div>

    <div class="cart-drawer__footer" id="CartDrawerFooter" style="display: none;">
      <div class="cart-drawer__subtotal-row">
        <span class="subtotal-label">Subtotal</span>
        <span class="subtotal-price" id="CartDrawerSubtotal">₹0</span>
      </div>
      <p class="cart-drawer__tax-note">Taxes and shipping calculated at checkout</p>
      
      <div class="cart-drawer__actions">
        <a href="{{ routes.cart_url }}" class="btn-view-cart">View Cart</a>
        <form action="{{ routes.cart_url }}" method="post" id="cart-drawer-form">
          <button type="submit" name="checkout" class="btn-checkout">Checkout</button>
        </form>
      </div>
    </div>
  </div>
</div>

{% style %}
  .cart-drawer {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 9999;
    display: flex;
    justify-content: flex-end;
    visibility: hidden;
    pointer-events: none;
    font-family: 'Montserrat', sans-serif;
  }
  .cart-drawer.is-open {
    visibility: visible;
    pointer-events: auto;
  }
  .cart-drawer__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.4);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .cart-drawer.is-open .cart-drawer__overlay {
    opacity: 1;
  }
  .cart-drawer__content {
    position: relative;
    width: 100%;
    max-width: 450px;
    height: 100%;
    background-color: #FAF8F2;
    box-shadow: -5px 0 30px rgba(0, 0, 0, 0.1);
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
  }
  .cart-drawer.is-open .cart-drawer__content {
    transform: translateX(0);
  }
  
  .cart-drawer__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 2rem 2.4rem;
    border-bottom: 1px solid rgba(1, 63, 62, 0.1);
  }
  .cart-drawer__title {
    margin: 0;
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.8rem;
    font-weight: 500;
    color: var(--color-primary, #013F3E);
  }
  .cart-drawer__close {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-primary, #013F3E);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    transition: background-color 0.2s ease;
  }
  .cart-drawer__close:hover {
    background-color: rgba(1, 63, 62, 0.05);
  }
  .cart-drawer__close svg {
    width: 2rem;
    height: 2rem;
  }

  .cart-drawer__body {
    flex: 1;
    overflow-y: auto;
    padding: 2.4rem;
  }
  
  /* Empty state */
  .cart-drawer__empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    text-align: center;
    color: #666666;
  }
  .empty-cart-icon {
    width: 6.4rem;
    height: 6.4rem;
    margin-bottom: 2rem;
    color: rgba(1, 63, 62, 0.2);
  }
  .btn-continue {
    margin-top: 2rem;
    padding: 1.2rem 2.4rem;
    background-color: transparent;
    color: var(--color-primary, #013F3E);
    border: 1px solid var(--color-primary, #013F3E);
    border-radius: 4px;
    cursor: pointer;
    font-weight: 500;
    transition: all 0.2s ease;
  }
  .btn-continue:hover {
    background-color: var(--color-primary, #013F3E);
    color: #FFFFFF;
  }

  /* Cart Items */
  .cart-item {
    display: flex;
    gap: 1.6rem;
    padding-bottom: 2rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid rgba(1, 63, 62, 0.08);
  }
  .cart-item:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }
  .cart-item__image {
    width: 90px;
    height: 90px;
    object-fit: cover;
    border-radius: 4px;
    border: 1px solid rgba(1, 63, 62, 0.05);
  }
  .cart-item__details {
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .cart-item__title {
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--color-primary, #013F3E);
    text-decoration: none;
    margin-bottom: 0.4rem;
    display: block;
  }
  .cart-item__title:hover {
    text-decoration: underline;
  }
  .cart-item__options {
    font-size: 1.15rem;
    color: #666;
    margin-bottom: 1rem;
    line-height: 1.4;
  }
  .cart-item__price {
    font-weight: 600;
    color: var(--color-primary, #013F3E);
    font-size: 1.3rem;
  }
  
  .cart-item__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
  }
  .cart-item__qty {
    display: flex;
    align-items: center;
    border: 1px solid rgba(1, 63, 62, 0.2);
    border-radius: 4px;
    height: 3.2rem;
  }
  .cart-item__qty button {
    background: none;
    border: none;
    width: 3.2rem;
    height: 100%;
    cursor: pointer;
    color: var(--color-primary, #013F3E);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cart-item__qty input {
    width: 3.2rem;
    height: 100%;
    border: none;
    text-align: center;
    font-family: 'Montserrat', sans-serif;
    font-size: 1.2rem;
    font-weight: 500;
    background: none;
    color: var(--color-primary, #013F3E);
  }
  .cart-item__qty input:focus {
    outline: none;
  }
  .cart-item__remove {
    background: none;
    border: none;
    color: #999;
    font-size: 1.15rem;
    text-decoration: underline;
    cursor: pointer;
    font-family: inherit;
    transition: color 0.2s ease;
  }
  .cart-item__remove:hover {
    color: #D32F2F;
  }

  /* Footer */
  .cart-drawer__footer {
    padding: 2.4rem;
    background-color: #FFFFFF;
    border-top: 1px solid rgba(1, 63, 62, 0.1);
  }
  .cart-drawer__subtotal-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.8rem;
  }
  .subtotal-label {
    font-size: 1.6rem;
    font-weight: 500;
    color: var(--color-primary, #013F3E);
  }
  .subtotal-price {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.2rem;
    font-weight: 600;
    color: var(--color-primary, #013F3E);
  }
  .cart-drawer__tax-note {
    font-size: 1.15rem;
    color: #666;
    margin-bottom: 2.4rem;
  }
  .cart-drawer__actions {
    display: flex;
    gap: 1.2rem;
  }
  .btn-view-cart {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.4rem;
    background: transparent;
    color: var(--color-primary, #013F3E);
    border: 1px solid var(--color-primary, #013F3E);
    border-radius: 4px;
    text-decoration: none;
    font-weight: 500;
    font-size: 1.2rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: all 0.2s ease;
  }
  .btn-view-cart:hover {
    background-color: rgba(1, 63, 62, 0.05);
  }
  .btn-checkout {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.4rem;
    background-color: var(--color-primary, #013F3E);
    color: #FFFFFF;
    border: none;
    border-radius: 4px;
    font-weight: 500;
    font-size: 1.2rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    font-family: inherit;
    transition: background-color 0.2s ease;
    width: 100%;
  }
  .btn-checkout:hover {
    background-color: #002E28;
  }
  
  .cart-drawer-overlay-loading {
    opacity: 0.5;
    pointer-events: none;
  }
{% endstyle %}

<script>
  function formatMoney(cents) {
    return '₹' + (cents / 100).toLocaleString('en-IN', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }

  function renderCart(cart) {
    const body = document.getElementById('CartDrawerBody');
    const footer = document.getElementById('CartDrawerFooter');
    const countBadge = document.getElementById('CartDrawerCount');
    
    countBadge.textContent = cart.item_count;

    // Update global navbar badges if function exists
    if (window.updateGlobalCartCount) {
      window.updateGlobalCartCount(cart.item_count);
    }

    if (cart.item_count === 0) {
      body.innerHTML = `
        <div class="cart-drawer__empty">
          <svg class="empty-cart-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007Z" />
          </svg>
          <p>Your cart is currently empty.</p>
          <button type="button" class="btn-continue" onclick="closeCartDrawer()">Continue Shopping</button>
        </div>
      `;
      footer.style.display = 'none';
      return;
    }

    let html = '';
    cart.items.forEach(item => {
      const optionsText = item.options_with_values 
        ? item.options_with_values.filter(opt => opt.value !== 'Default Title').map(opt => opt.value).join(' | ') 
        : '';
        
      html += `
        <div class="cart-item" data-key="${item.key}">
          <img src="${item.image || ''}" alt="${item.title}" class="cart-item__image">
          <div class="cart-item__details">
            <a href="${item.url}" class="cart-item__title">${item.product_title}</a>
            ${optionsText ? `<div class="cart-item__options">${optionsText}</div>` : ''}
            <div class="cart-item__price">${formatMoney(item.final_line_price)}</div>
            
            <div class="cart-item__bottom">
              <div class="cart-item__qty">
                <button type="button" onclick="updateCartItem('${item.key}', ${item.quantity - 1})">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 12h14"/></svg>
                </button>
                <input type="number" value="${item.quantity}" readonly>
                <button type="button" onclick="updateCartItem('${item.key}', ${item.quantity + 1})">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M12 5v14M5 12h14"/></svg>
                </button>
              </div>
              <button type="button" class="cart-item__remove" onclick="updateCartItem('${item.key}', 0)">Remove</button>
            </div>
          </div>
        </div>
      `;
    });

    body.innerHTML = html;
    
    document.getElementById('CartDrawerSubtotal').textContent = formatMoney(cart.total_price);
    footer.style.display = 'block';
  }

  function fetchCart() {
    const body = document.getElementById('CartDrawerBody');
    body.classList.add('cart-drawer-overlay-loading');
    
    fetch((window.Shopify?.routes?.root || '/') + 'cart.js')
      .then(res => res.json())
      .then(cart => {
        body.classList.remove('cart-drawer-overlay-loading');
        renderCart(cart);
      })
      .catch(err => {
        body.classList.remove('cart-drawer-overlay-loading');
        console.error('Error fetching cart:', err);
      });
  }

  function updateCartItem(key, quantity) {
    const body = document.getElementById('CartDrawerBody');
    body.classList.add('cart-drawer-overlay-loading');
    
    fetch((window.Shopify?.routes?.root || '/') + 'cart/change.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify({ id: key, quantity: quantity })
    })
    .then(res => res.json())
    .then(cart => {
      body.classList.remove('cart-drawer-overlay-loading');
      renderCart(cart);
    })
    .catch(err => {
      body.classList.remove('cart-drawer-overlay-loading');
      console.error('Error updating cart:', err);
    });
  }

  window.openCartDrawer = function() {
    document.getElementById('CartDrawer').classList.add('is-open');
    document.body.style.overflow = 'hidden'; // Prevent background scrolling
    document.body.classList.add('drawer-open');
    fetchCart();
  };

  window.closeCartDrawer = function() {
    document.getElementById('CartDrawer').classList.remove('is-open');
    document.body.style.overflow = '';
    document.body.classList.remove('drawer-open');
  };
</script>

{% schema %}
{
  "name": "Cart Drawer",
  "settings": []
}
{% endschema %}
