{
  "name": "Collection Product Grid",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    }
  ]
}
{% endschema %}

{% javascript %}
  document.addEventListener('DOMContentLoaded', function() {
    // 1. Mobile Filter Sheet Modal Handlers
    const openFilterBtn = document.getElementById('MobileFilterToggle');
    const closeFilterBtn = document.getElementById('CollectionFiltersClose');
    const filterOverlay = document.getElementById('CollectionFiltersOverlay');
    const filterSidebar = document.getElementById('CollectionPageSidebar');

    function openFilters() {
      if (filterSidebar && filterOverlay) {
        filterSidebar.classList.add('open');
        filterOverlay.classList.add('open');
        document.body.style.overflow = 'hidden';
      }
    }

    function closeFilters() {
      if (filterSidebar && filterOverlay) {
        filterSidebar.classList.remove('open');
        filterOverlay.classList.remove('open');
        document.body.style.overflow = '';
      }
    }

    if (openFilterBtn) openFilterBtn.addEventListener('click', openFilters);
    if (closeFilterBtn) closeFilterBtn.addEventListener('click', closeFilters);
    if (filterOverlay) filterOverlay.addEventListener('click', closeFilters);

    // 2. Dual Range Price Slider logic
    const minSliders = document.querySelectorAll('.price-slider__range--min');
    const maxSliders = document.querySelectorAll('.price-slider__range--max');

    minSliders.forEach((minSlider, index) => {
      const maxSlider = maxSliders[index];
      const track = minSlider.parentElement.querySelector('.price-slider__track');
      
      const minLabel = minSlider.parentElement.nextElementSibling.querySelector('span[id^="label-min"]');
      const maxLabel = minSlider.parentElement.nextElementSibling.querySelector('span[id^="label-max"]');
      
      const hiddenMin = minSlider.parentElement.parentElement.querySelector('input[name*="gte"]');
      const hiddenMax = minSlider.parentElement.parentElement.querySelector('input[name*="lte"]');
      
      const form = minSlider.closest('form');

      function updateSlider() {
        let minVal = parseInt(minSlider.value);
        let maxVal = parseInt(maxSlider.value);

        if (minVal > maxVal) {
          if (this === minSlider) {
            minVal = maxVal;
            minSlider.value = minVal;
          } else {
            maxVal = minVal;
            maxSlider.value = maxVal;
          }
        }

        const parentText = minLabel.parentElement ? minLabel.parentElement.textContent : '';
        const activeLocale = parentText.includes('₹') ? 'en-IN' : 'en-US';
        minLabel.textContent = minVal.toLocaleString(activeLocale);
        maxLabel.textContent = maxVal.toLocaleString(activeLocale);
        
        if (hiddenMin) hiddenMin.value = minVal;
        if (hiddenMax) hiddenMax.value = maxVal;

        const maxTotal = parseInt(minSlider.max) || 1;
        const percentMin = (minVal / maxTotal) * 100;
        const percentMax = (maxVal / maxTotal) * 100;
        
        if (track) {
          track.style.left = percentMin + "%";
          track.style.width = (percentMax - percentMin) + "%";
        }
      }

      minSlider.addEventListener('input', updateSlider);
      maxSlider.addEventListener('input', updateSlider);
      
      updateSlider();
    });
  });
{% endjavascript %}
