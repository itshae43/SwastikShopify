<div class="collection-page" style="background-color: {{ section.settings.bg_color }};">
  <div class="collection-page__container">
    
    <!-- Sidebar Filters -->
    <aside class="collection-page__sidebar">
      <div class="collection-filters">
        <div class="collection-filters__header">
          <h3 class="collection-filters__title">FILTERS</h3>
          <a href="{{ collection.url }}" class="collection-filters__clear">Clear All</a>
        </div>
        
        <form id="CollectionFiltersForm" class="collection-filters__form">
          {%- for filter in collection.filters -%}
            <div class="filter-group" open>
              <details class="filter-group__details" open>
                <summary class="filter-group__summary">
                  <span class="filter-group__name">{{ filter.label }}</span>
                  <svg class="icon-caret" width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </summary>
                
                <div class="filter-group__display">
                  {%- case filter.type -%}
                    {%- when 'boolean' or 'list' -%}
                      <ul class="filter-group__list">
                        {%- for filter_value in filter.values -%}
                          <li class="filter-group__list-item">
                            <label for="Filter-{{ filter.param_name }}-{{ forloop.index }}" class="filter-checkbox">
                              <input type="checkbox" 
                                name="{{ filter_value.param_name }}"
                                value="{{ filter_value.value }}"
                                id="Filter-{{ filter.param_name }}-{{ forloop.index }}"
                                {% if filter_value.active -%}checked{%- endif %}
                                onchange="this.form.submit()">
                              <span class="filter-checkbox__box"></span>
                              <span class="filter-checkbox__label">{{ filter_value.label }}</span>
                            </label>
                          </li>
                        {%- endfor -%}
                      </ul>
                      
                    {%- when 'price_range' -%}
                      <div class="filter-group__price-range">
                        <div class="price-slider-container">
                          <!-- Visual slider -->
                          <div class="price-slider">
                            <div class="price-slider__track" id="slider-track-{{ filter.label | handleize }}"></div>
                            <input type="range" min="0" max="{{ filter.range_max | divided_by: 100.0 | ceil }}" 
                                   value="{{ filter.min_value.value | default: 0 | divided_by: 100.0 | floor }}" 
                                   class="price-slider__range price-slider__range--min" id="slider-min-{{ filter.label | handleize }}">
                            <input type="range" min="0" max="{{ filter.range_max | divided_by: 100.0 | ceil }}" 
                                   value="{{ filter.max_value.value | default: filter.range_max | divided_by: 100.0 | ceil }}" 
                                   class="price-slider__range price-slider__range--max" id="slider-max-{{ filter.label | handleize }}">
                          </div>
                          
                          <!-- Labels -->
                          <div class="price-slider__labels">
                            <span class="price-slider__label">₹ <span id="label-min-{{ filter.label | handleize }}">{{ filter.min_value.value | default: 0 | divided_by: 100.0 | floor }}</span></span>
                            <span class="price-slider__label">₹ <span id="label-max-{{ filter.label | handleize }}">{{ filter.max_value.value | default: filter.range_max | divided_by: 100.0 | ceil }}</span>+</span>
                          </div>

                          <!-- Hidden actual inputs that submit the form -->
                          <input type="hidden" name="{{ filter.min_value.param_name }}" id="Filter-{{ filter.min_value.param_name }}" value="{{ filter.min_value.value | divided_by: 100.0 | floor | default: '' }}">
                          <input type="hidden" name="{{ filter.max_value.param_name }}" id="Filter-{{ filter.max_value.param_name }}" value="{{ filter.max_value.value | divided_by: 100.0 | ceil | default: '' }}">
                        </div>
                      </div>
                  {%- endcase -%}
                </div>
              </details>
            </div>
          {%- endfor -%}
          
          <!-- Hardcoded filters for visual mockup -->
          {% assign custom_filters = "Diamond Shape, Metal Type, Occasion, Collection" | split: ", " %}
          {% for custom_filter in custom_filters %}
            <div class="filter-group">
              <details class="filter-group__details">
                <summary class="filter-group__summary">
                  <span class="filter-group__name">{{ custom_filter }}</span>
                  <svg class="icon-caret" width="10" height="6" viewBox="0 0 10 6" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </summary>
                <div class="filter-group__display">
                  <ul class="filter-group__list">
                    <!-- Dummy items for mockup -->
                    <li class="filter-group__list-item">
                      <label class="filter-checkbox">
                        <input type="checkbox" disabled>
                        <span class="filter-checkbox__box"></span>
                        <span class="filter-checkbox__label">Option 1</span>
                      </label>
                    </li>
                    <li class="filter-group__list-item">
                      <label class="filter-checkbox">
                        <input type="checkbox" disabled>
                        <span class="filter-checkbox__box"></span>
                        <span class="filter-checkbox__label">Option 2</span>
                      </label>
                    </li>
                  </ul>
                </div>
              </details>
            </div>
          {% endfor %}
          
          <!-- Hidden inputs for sorting so it's maintained when filtering -->
          {%- if collection.sort_by -%}
            <input type="hidden" name="sort_by" value="{{ collection.sort_by }}">
          {%- endif -%}
        </form>
      </div>
    </aside>
    
    <!-- Main Content -->
    <main class="collection-page__main">
      <div class="collection-toolbar">
        <div class="collection-toolbar__count">
          All Products ({{ collection.products_count }})
        </div>
        
        <div class="collection-toolbar__sort">
          <label for="SortBy" class="collection-toolbar__sort-label">Sort<br>by:</label>
          <select name="sort_by" id="SortBy" form="CollectionFiltersForm" onchange="this.form.submit()">
            {%- for option in collection.sort_options -%}
              <option value="{{ option.value }}" {% if option.value == collection.sort_by %}selected="selected"{% endif %}>
                {{ option.name }}
              </option>
            {%- endfor -%}
          </select>
        </div>
      </div>
      
      {% paginate collection.products by 24 %}
        <div class="collection-grid">
          {%- for product in collection.products -%}
            {% render 'product-card', product: product, class_prefix: 'best-sellers' %}
          {%- else -%}
            <div class="collection-grid__empty">
              <p>No products found matching your filters.</p>
              <a href="{{ collection.url }}" class="btn">Clear Filters</a>
            </div>
          {%- endfor -%}
        </div>
        
        {%- if paginate.pages > 1 -%}
          <div class="collection-pagination">
            {{ paginate | default_pagination: next: 'Next', previous: 'Prev' }}
          </div>
        {%- endif -%}
      {% endpaginate %}
    </main>
  </div>
</div>

{% stylesheet %}
  .collection-page {
    padding: 3rem 0 5rem;
    font-family: 'Inter', sans-serif;
  }
  
  .collection-page__container {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 4rem;
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 4rem;
    align-items: start;
  }
  
  /* Sidebar Styles */
  .collection-filters {
    background-color: #faf7f2;
    border-radius: 8px;
    padding: 1.5rem;
  }
  
  .collection-filters__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }
  
  .collection-filters__title {
    font-size: 1.1rem;
    font-weight: 700;
    font-family: 'Merriweather', serif;
    margin: 0;
    letter-spacing: 0.05em;
    color: #013F3E;
  }
  
  .collection-filters__clear {
    font-size: 0.85rem;
    color: #555;
    text-decoration: none;
  }
  
  .filter-group {
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }
  .filter-group:last-child {
    border-bottom: none;
  }
  
  .filter-group__summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
    cursor: pointer;
    list-style: none;
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #013F3E;
  }
  .filter-group__summary::-webkit-details-marker {
    display: none;
  }
  
  .icon-caret {
    transition: transform 0.3s ease;
  }
  details[open] .icon-caret {
    transform: rotate(180deg);
  }
  
  .filter-group__display {
    padding-bottom: 1.5rem;
  }
  
  .filter-group__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .filter-group__list-item {
    margin-bottom: 0.8rem;
  }
  
  .filter-checkbox {
    display: flex;
    align-items: center;
    cursor: pointer;
  }
  
  .filter-checkbox input {
    position: absolute;
    opacity: 0;
    cursor: pointer;
  }
  
  .filter-checkbox__box {
    width: 16px;
    height: 16px;
    border: 1px solid #ccc;
    border-radius: 3px;
    margin-right: 10px;
    position: relative;
    background-color: #fff;
  }
  
  .filter-checkbox input:checked ~ .filter-checkbox__box {
    background-color: #013F3E;
    border-color: #013F3E;
  }
  
  .filter-checkbox input:checked ~ .filter-checkbox__box::after {
    content: '';
    position: absolute;
    left: 4px;
    top: 1px;
    width: 4px;
    height: 8px;
    border: solid white;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }
  
  .filter-checkbox__label {
    font-size: 0.95rem;
    color: #333;
  }
  
  /* Price Range Slider */
  .filter-group__price-range {
    width: 100%;
  }
  .price-slider-container {
    padding: 10px 0;
    width: 100%;
  }
  .price-slider {
    position: relative;
    width: 100%;
    height: 4px;
    background-color: #e0e0e0;
    border-radius: 4px;
    margin: 20px 0 15px;
  }
  .price-slider__track {
    position: absolute;
    height: 100%;
    background-color: #013F3E;
    border-radius: 4px;
    z-index: 1;
  }
  .price-slider__range {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 4px;
    position: absolute;
    background: transparent;
    pointer-events: none;
    z-index: 2;
    outline: none;
    margin: 0;
  }
  .price-slider__range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #ffffff;
    border: 2px solid #013F3E;
    cursor: pointer;
    pointer-events: auto;
  }
  .price-slider__range::-moz-range-thumb {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #ffffff;
    border: 2px solid #013F3E;
    cursor: pointer;
    pointer-events: auto;
  }
  .price-slider__labels {
    display: flex;
    justify-content: space-between;
    font-size: 0.85rem;
    color: #013F3E;
    font-weight: 500;
  }
  
  /* Toolbar */
  .collection-toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }
  
  .collection-toolbar__count {
    font-size: 1.2rem;
    font-weight: 700;
    color: #013F3E;
    font-family: 'Merriweather', serif;
  }
  
  .collection-toolbar__sort {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  
  .collection-toolbar__sort-label {
    font-size: 0.75rem;
    line-height: 1.1;
    text-align: right;
    color: #555;
  }
  
  .collection-toolbar__sort select {
    padding: 0;
    border: none;
    background-color: transparent;
    font-size: 0.95rem;
    font-weight: 600;
    color: #013F3E;
    cursor: pointer;
    appearance: none;
    outline: none;
  }
  
  /* Grid */
  .collection-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }
  
  .collection-grid__empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 4rem 0;
    background: #faf7f2;
    border-radius: 8px;
  }
  
  .collection-pagination {
    margin-top: 4rem;
    display: flex;
    justify-content: center;
    gap: 1rem;
  }
  .collection-pagination span,
  .collection-pagination a {
    padding: 0.5rem 1rem;
    background: #faf7f2;
    color: #333;
    text-decoration: none;
    border-radius: 4px;
  }
  .collection-pagination .current {
    background: #013F3E;
    color: #fff;
  }

  @media screen and (max-width: 1200px) {
    .collection-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  
  @media screen and (max-width: 900px) {
    .collection-page__container {
      grid-template-columns: 1fr;
      padding: 0 2rem;
    }
    .collection-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media screen and (max-width: 500px) {
    .collection-grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection Product Grid",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    }
  ]
}
{% endschema %}

{% javascript %}
  document.addEventListener('DOMContentLoaded', function() {
    const minSliders = document.querySelectorAll('.price-slider__range--min');
    const maxSliders = document.querySelectorAll('.price-slider__range--max');

    minSliders.forEach((minSlider, index) => {
      const maxSlider = maxSliders[index];
      const track = minSlider.parentElement.querySelector('.price-slider__track');
      
      const minLabel = minSlider.parentElement.nextElementSibling.querySelector('span[id^="label-min"]');
      const maxLabel = minSlider.parentElement.nextElementSibling.querySelector('span[id^="label-max"]');
      
      const hiddenMin = minSlider.parentElement.parentElement.querySelector('input[name*="gte"]');
      const hiddenMax = minSlider.parentElement.parentElement.querySelector('input[name*="lte"]');
      
      const form = minSlider.closest('form');

      function updateSlider() {
        let minVal = parseInt(minSlider.value);
        let maxVal = parseInt(maxSlider.value);

        if (minVal > maxVal) {
          if (this === minSlider) {
            minVal = maxVal;
            minSlider.value = minVal;
          } else {
            maxVal = minVal;
            maxSlider.value = maxVal;
          }
        }

        minLabel.textContent = minVal.toLocaleString('en-IN');
        maxLabel.textContent = maxVal.toLocaleString('en-IN');
        
        hiddenMin.value = minVal;
        hiddenMax.value = maxVal;

        const maxTotal = parseInt(minSlider.max) || 1;
        const percentMin = (minVal / maxTotal) * 100;
        const percentMax = (maxVal / maxTotal) * 100;
        
        track.style.left = percentMin + "%";
        track.style.width = (percentMax - percentMin) + "%";
      }

      minSlider.addEventListener('input', updateSlider);
      maxSlider.addEventListener('input', updateSlider);
      
      minSlider.addEventListener('change', () => form.submit());
      maxSlider.addEventListener('change', () => form.submit());

      updateSlider();
    });
  });
{% endjavascript %}
