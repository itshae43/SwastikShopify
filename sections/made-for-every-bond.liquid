{%- liquid
  assign bg_color = section.settings.bg_color | default: '#fdfbf7'
  assign text_color = section.settings.text_color | default: '#0a2a26'
  assign accent_color = section.settings.accent_color | default: '#b38245'
-%}

<div class="every-bond" style="--bg-color: {{ bg_color }}; --text-color: {{ text_color }}; --accent-color: {{ accent_color }};">
  <div class="every-bond__wrapper">
    <!-- Left Banner -->
    <div class="every-bond__banner">
      {%- if section.settings.heading_main != blank or section.settings.heading_accent != blank -%}
        <h2 class="every-bond__heading">
          {{ section.settings.heading_main | escape }} <span>{{ section.settings.heading_accent | escape }}</span>
        </h2>
      {%- endif -%}

      <div class="every-bond__divider">
        <span class="every-bond__divider-line"></span>
        <span class="every-bond__divider-icon">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M12,6L16,12L12,18L8,12Z"/>
          </svg>
        </span>
        <span class="every-bond__divider-line"></span>
      </div>

      {%- if section.settings.description != blank -%}
        <p class="every-bond__description">{{ section.settings.description | escape }}</p>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: '#' }}" class="every-bond__btn">
          {{ section.settings.button_label | escape }}
          <span class="every-bond__btn-arrow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="16" height="16">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </span>
        </a>
      {%- endif -%}
    </div>

    <!-- Right Cards Grid -->
    <div class="every-bond__grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign title = block.settings.title
          assign subtitle = block.settings.subtitle
          assign image = block.settings.image
          assign link = block.settings.link | default: '#'
        -%}
        <div class="every-bond__card" {{ block.shopify_attributes }}>
          <a href="{{ link }}" class="every-bond__card-link" aria-label="{{ title | escape }}">
            <div class="every-bond__image-container">
              {%- if image != blank -%}
                {{ image | image_url: width: 600, height: 800, crop: 'center' | image_tag: loading: 'lazy', alt: title, class: 'every-bond__img' }}
              {%- else -%}
                {%- comment -%}Use generated fallback image based on the block index or settings{%- endcomment -%}
                {%- assign fallback_img_name = '' -%}
                {%- if title contains 'Mother' -%}
                  {%- assign fallback_img_name = 'bond_mothers.png' -%}
                {%- elsif title contains 'Sister' -%}
                  {%- assign fallback_img_name = 'bond_sisters.png' -%}
                {%- elsif title contains 'Bride' -%}
                  {%- assign fallback_img_name = 'bond_brides.png' -%}
                {%- endif -%}

                {%- if fallback_img_name != '' -%}
                  <img src="{{ fallback_img_name | asset_url }}" alt="{{ title }}" loading="lazy" width="600" height="800" class="every-bond__img">
                {%- else -%}
                  {%- capture placeholder_index -%}{% cycle 1, 2, 3 %}{%- endcapture -%}
                  {{ 'collection-' | append: placeholder_index | placeholder_svg_tag: 'every-bond__img placeholder-svg' }}
                {%- endif -%}
              {%- endif -%}
            </div>
            
            <!-- Overlay Badge Card -->
            <div class="every-bond__overlay">
              <div class="every-bond__icon-circle">
                {%- case block.settings.icon -%}
                  {%- when 'mother' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="7" r="3" />
                      <path d="M5 20a7 7 0 0 1 14 0" />
                      <path d="M12 17l-1.5-1.5a2.12 2.12 0 1 1 3 0L12 17z" />
                    </svg>
                  {%- when 'sister' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="8" cy="8" r="2.5" />
                      <path d="M3 18a5 5 0 0 1 8-1" />
                      <circle cx="16" cy="8" r="2.5" />
                      <path d="M13 17a5 5 0 0 1 8 1" />
                      <path d="M11 14h2" />
                    </svg>
                  {%- when 'bride' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="9" cy="14" r="4.5" />
                      <circle cx="15" cy="11" r="4.5" />
                      <path d="M15 6.5l1.5-1.5 1.5 1.5-1.5 1.5z" />
                    </svg>
                  {%- when 'heart' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                    </svg>
                  {%- when 'rings' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="8" cy="13" r="4" />
                      <circle cx="14" cy="13" r="4" />
                    </svg>
                  {%- when 'custom' -%}
                    {%- if block.settings.custom_icon_svg != blank -%}
                      {{ block.settings.custom_icon_svg }}
                    {%- else -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/>
                      </svg>
                    {%- endif -%}
                {%- endcase -%}
              </div>
              <div class="every-bond__text">
                <h3 class="every-bond__card-title">{{ title | escape }}</h3>
                <p class="every-bond__card-subtitle">{{ subtitle | escape }}</p>
              </div>
            </div>
          </a>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
.every-bond {
  background-color: var(--bg-color);
  padding: 80px 48px;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.every-bond__wrapper {
  display: grid;
  grid-template-columns: 340px 1fr;
  gap: 70px;
  align-items: center;
  max-width: 1600px;
  margin: 0 auto;
}

.every-bond__banner {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  text-align: left;
}

.every-bond__heading {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 48px;
  line-height: 1.15;
  color: var(--text-color);
  margin: 0 0 15px 0;
  font-weight: 500;
  letter-spacing: -0.01em;
}

.every-bond__heading span {
  color: var(--accent-color);
}

.every-bond__divider {
  display: flex;
  align-items: center;
  margin-bottom: 25px;
  width: 120px;
}

.every-bond__divider-line {
  flex-grow: 1;
  height: 1px;
  background-color: var(--accent-color);
  opacity: 0.3;
}

.every-bond__divider-icon {
  width: 14px;
  height: 14px;
  color: var(--accent-color);
  margin: 0 10px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.every-bond__divider-icon svg {
  width: 100%;
  height: 100%;
}

.every-bond__description {
  font-family: 'Inter', sans-serif;
  font-size: 15px;
  line-height: 1.6;
  color: var(--text-color);
  opacity: 0.75;
  margin: 0 0 30px 0;
  max-width: 300px;
}

.every-bond__btn {
  font-family: 'Inter', sans-serif;
  display: inline-flex;
  align-items: center;
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.1em;
  color: var(--accent-color);
  text-decoration: none;
  text-transform: uppercase;
  transition: opacity 0.3s ease;
  position: relative;
  padding-bottom: 4px;
}

.every-bond__btn::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 1px;
  background-color: var(--accent-color);
  transform: scaleX(0.3);
  transform-origin: left;
  transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.every-bond__btn:hover::after {
  transform: scaleX(1);
}

.every-bond__btn-arrow {
  margin-left: 8px;
  display: flex;
  align-items: center;
  transition: transform 0.3s ease;
}

.every-bond__btn-arrow svg {
  width: 16px;
  height: 16px;
}

.every-bond__btn:hover .every-bond__btn-arrow {
  transform: translateX(4px);
}

/* Cards Grid */
.every-bond__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30px;
}

.every-bond__card {
  position: relative;
  border-radius: 24px;
  overflow: hidden;
  aspect-ratio: 3 / 3.9;
  background-color: #faf7f2;
}

.every-bond__card-link {
  display: block;
  width: 100%;
  height: 100%;
  text-decoration: none;
}

.every-bond__image-container {
  width: 100%;
  height: 100%;
  overflow: hidden;
  position: relative;
}

.every-bond__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
}

.every-bond__card:hover .every-bond__img {
  transform: scale(1.04);
}

.every-bond__img.placeholder-svg {
  background-color: rgba(10, 42, 38, 0.04);
  padding: 40px;
  box-sizing: border-box;
}

/* Overlay Badge Card */
.every-bond__overlay {
  position: absolute;
  left: 16px;
  right: 16px;
  bottom: 16px;
  background-color: #ffffff;
  padding: 16px;
  border-radius: 20px;
  display: flex;
  align-items: center;
  gap: 16px;
  border: 1px solid rgba(179, 130, 69, 0.08);
  box-shadow: 0 8px 24px rgba(10, 42, 38, 0.04);
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s ease;
}

.every-bond__card:hover .every-bond__overlay {
  transform: translateY(-4px);
  box-shadow: 0 14px 30px rgba(10, 42, 38, 0.08);
}

.every-bond__icon-circle {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  border: 1px solid rgba(179, 130, 69, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--accent-color);
  flex-shrink: 0;
  transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
}

.every-bond__card:hover .every-bond__icon-circle {
  background-color: var(--accent-color);
  color: #ffffff;
  border-color: var(--accent-color);
}

.every-bond__icon-circle svg {
  width: 22px;
  height: 22px;
}

.every-bond__text {
  display: flex;
  flex-direction: column;
  gap: 2px;
  text-align: left;
}

.every-bond__card-title {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 18px;
  font-weight: 500;
  color: var(--text-color);
  margin: 0;
  line-height: 1.2;
}

.every-bond__card-subtitle {
  font-family: 'Inter', sans-serif;
  font-size: 12px;
  color: var(--text-color);
  opacity: 0.65;
  margin: 0;
  line-height: 1.3;
}

/* Responsiveness */
@media screen and (max-width: 1200px) {
  .every-bond__wrapper {
    gap: 40px;
    grid-template-columns: 290px 1fr;
  }
  .every-bond__grid {
    gap: 20px;
  }
  .every-bond__heading {
    font-size: 40px;
  }
}

@media screen and (max-width: 991px) {
  .every-bond {
    padding: 60px 20px;
  }
  .every-bond__wrapper {
    grid-template-columns: 1fr;
    gap: 36px;
  }
  .every-bond__banner {
    align-items: center;
    text-align: center;
  }
  .every-bond__divider {
    justify-content: center;
    margin-bottom: 20px;
  }
  .every-bond__description {
    max-width: 100%;
    margin-bottom: 24px;
  }
  .every-bond__grid {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: 16px;
    padding-bottom: 16px;
    margin: 0 -20px;
    padding-left: 20px;
    padding-right: 20px;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .every-bond__grid::-webkit-scrollbar {
    display: none;
  }
  .every-bond__card {
    flex: 0 0 280px;
    scroll-snap-align: start;
    aspect-ratio: 3 / 3.9;
    border-radius: 20px;
  }
  .every-bond__overlay {
    left: 12px;
    right: 12px;
    bottom: 12px;
    padding: 12px 14px;
    border-radius: 16px;
    gap: 12px;
  }
  .every-bond__icon-circle {
    width: 40px;
    height: 40px;
  }
  .every-bond__icon-circle svg {
    width: 18px;
    height: 18px;
  }
  .every-bond__card-title {
    font-size: 16px;
  }
  .every-bond__card-subtitle {
    font-size: 11px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Made for Every Bond",
  "class": "section",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading_main",
      "label": "Heading Main",
      "default": "Made for"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading Accent Word (Gold)",
      "default": "Every Bond"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Beautiful jewellery for the people who make every moment special."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Explore Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fdfbf7"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#0a2a26"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#b38245"
    }
  ],
  "blocks": [
    {
      "type": "bond",
      "name": "Bond Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "For Mothers"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Her love, our forever."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Card Link"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon Badge type",
          "default": "mother",
          "options": [
            {
              "value": "mother",
              "label": "Motherhood"
            },
            {
              "value": "sister",
              "label": "Sisterhood"
            },
            {
              "value": "bride",
              "label": "Bridal Rings"
            },
            {
              "value": "heart",
              "label": "Heart"
            },
            {
              "value": "rings",
              "label": "Double Rings"
            },
            {
              "value": "custom",
              "label": "Custom SVG"
            }
          ]
        },
        {
          "type": "textarea",
          "id": "custom_icon_svg",
          "label": "Custom SVG Icon code"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Made for Every Bond",
      "blocks": [
        {
          "type": "bond",
          "settings": {
            "title": "For Mothers",
            "subtitle": "Her love, our forever.",
            "icon": "mother"
          }
        },
        {
          "type": "bond",
          "settings": {
            "title": "For Sisters",
            "subtitle": "Partners in all things.",
            "icon": "sister"
          }
        },
        {
          "type": "bond",
          "settings": {
            "title": "For Brides",
            "subtitle": "For the beginning of forever.",
            "icon": "bride"
          }
        }
      ]
    }
  ]
}
{% endschema %}
