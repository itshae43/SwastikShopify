{% comment %}
  Renders the main store footer, featuring brand profile, quick links, customer support links, contact details, social media links, and copyright info.
  Styled on a dark brand green background with gold/accent headings and elegant hover states.
{% endcomment %}

<footer class="footer-wrapper" style="{% if section.settings.color_footer_bg != blank %}--footer-bg: {{ section.settings.color_footer_bg }};{% endif %} {% if section.settings.color_footer_text != blank %}--footer-text: {{ section.settings.color_footer_text }};{% endif %} {% if section.settings.color_footer_accent != blank %}--footer-accent-setting: {{ section.settings.color_footer_accent }};{% endif %}">
  <div class="footer container">
    <div class="footer__grid">
      <!-- Col 1: Brand Info & Contact Info -->
      <div class="footer__col footer__col--brand">
        <h3 class="footer__logo serif-font">{{ section.settings.brand_name }}</h3>
        <p class="footer__description">
          {{ section.settings.brand_description }}
        </p>
        <ul class="footer__contact-list-inline">
          {% if section.settings.contact_phone != blank %}
            <li>
              <a href="tel:{{ section.settings.contact_phone | replace: ' ', '' }}" class="footer__contact-link">
                <svg class="footer__contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                </svg>
                <span>{{ section.settings.contact_phone | escape }}</span>
              </a>
            </li>
          {% endif %}
          {% if section.settings.contact_email != blank %}
            <li>
              <a href="mailto:{{ section.settings.contact_email }}" class="footer__contact-link">
                <svg class="footer__contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                  <polyline points="22,6 12,13 2,6"></polyline>
                </svg>
                <span>{{ section.settings.contact_email | escape }}</span>
              </a>
            </li>
          {% endif %}
          {% if section.settings.contact_address != blank %}
            <li>
              <a href="https://www.google.com/maps/place/Swastik+Jewels/@28.6504041,77.1913016,17z" target="_blank" rel="noopener noreferrer" class="footer__contact-link">
                <svg class="footer__contact-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                  <circle cx="12" cy="10" r="3"></circle>
                </svg>
                <span>{{ section.settings.contact_address | escape }}</span>
              </a>
            </li>
          {% endif %}
        </ul>
        <div class="footer__social-icons">
          {% if section.settings.social_facebook_link != blank %}
            <a href="{{ section.settings.social_facebook_link }}" class="footer__social-link" aria-label="Facebook">
              <svg class="icon icon-facebook" viewBox="0 0 24 24" fill="currentColor">
                <path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"/>
              </svg>
            </a>
          {% endif %}
          {% if section.settings.social_instagram_link != blank %}
            <a href="{{ section.settings.social_instagram_link }}" class="footer__social-link" aria-label="Instagram">
              <svg class="icon icon-instagram" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
              </svg>
            </a>
          {% endif %}
          {% if section.settings.social_twitter_link != blank %}
            <a href="{{ section.settings.social_twitter_link }}" class="footer__social-link" aria-label="Twitter">
              <svg class="icon icon-twitter" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path>
              </svg>
            </a>
          {% endif %}
          {% if section.settings.social_youtube_link != blank %}
            <a href="{{ section.settings.social_youtube_link }}" class="footer__social-link" aria-label="YouTube">
              <svg class="icon icon-youtube" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.41 19c1.71.46 8.59.46 8.59.46s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96 29 29 0 0 0 .46-5.33 29 29 0 0 0-.46-5.33z"></path>
                <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon>
              </svg>
            </a>
          {% endif %}
        </div>
      </div>

      <!-- Col 2: Menu 1 -->
      <div class="footer__col">
        <h4 class="footer__heading">{{ section.settings.menu_title | default: "KNOW YOUR JEWELLERY" }}</h4>
        <ul class="footer__links-list">
          {% if section.settings.menu != blank %}
            {% for link in section.settings.menu.links %}
              <li><a href="{{ link.url }}" class="footer__link">{{ link.title }}</a></li>
            {% endfor %}
          {% else %}
            <li><a href="/pages/diamond-guide" class="footer__link">Diamond Guide</a></li>
            <li><a href="/pages/gold-guide" class="footer__link">Gold Guide</a></li>
            <li><a href="/pages/ring-size-guide" class="footer__link">Ring Size Guide</a></li>
            <li><a href="/pages/carat-war" class="footer__link">Carat War</a></li>
          {% endif %}
        </ul>
      </div>

      <!-- Col 3: Menu 2 -->
      <div class="footer__col">
        <h4 class="footer__heading">{{ section.settings.customer_menu_title | default: "POLICY" }}</h4>
        <ul class="footer__links-list">
          {% if section.settings.customer_menu != blank %}
            {% for link in section.settings.customer_menu.links %}
              <li><a href="{{ link.url }}" class="footer__link">{{ link.title }}</a></li>
            {% endfor %}
          {% else %}
            <li><a href="/pages/privacy-policy" class="footer__link">Privacy Policy</a></li>
            <li><a href="/pages/terms-conditions" class="footer__link">Terms & Conditions</a></li>
            <li><a href="/pages/return-policy" class="footer__link">Return Policy</a></li>
            <li><a href="/pages/buyback-policy" class="footer__link">Buyback Policy</a></li>
            <li><a href="/pages/shipping-policy" class="footer__link">Shipping Policy</a></li>
          {% endif %}
        </ul>
      </div>

      <!-- Col 4: Menu 3 -->
      <div class="footer__col">
        <h4 class="footer__heading">{{ section.settings.help_menu_title | default: "HELP" }}</h4>
        <ul class="footer__links-list">
          {% if section.settings.help_menu != blank %}
            {% for link in section.settings.help_menu.links %}
              <li><a href="{{ link.url }}" class="footer__link">{{ link.title }}</a></li>
            {% endfor %}
          {% else %}
            <li><a href="/pages/contact-us" class="footer__link">Contact Us</a></li>
            <li><a href="/pages/faq" class="footer__link">FAQ's</a></li>
            <li><a href="/pages/find-store" class="footer__link">Find Store</a></li>
          {% endif %}
        </ul>
      </div>


    </div>

  </div>

  <div class="footer-bottom-wrapper">
    <div class="footer__bottom container">
      <div class="footer__bottom-left">
        <img src="{{ 'logo.png' | asset_url }}" alt="Swastik Logo" class="footer__bottom-logo" width="30" height="30" loading="lazy">
        <span class="footer__copyright">&copy; 2011 - {{ 'now' | date: '%Y' }} {{ section.settings.brand_name }}. A brand developed and managed by Nitin Gupta | All rights reserved</span>
      </div>
      
      <div class="footer__bottom-center">
        <a href="{{ section.settings.sitemap_url | default: '#' }}" class="footer__bottom-link">SITEMAP</a>
        <span class="footer__bottom-divider">|</span>
        <a href="/pages/accessibility" class="footer__bottom-link">ACCESSIBILITY</a>
        <span class="footer__bottom-divider">|</span>
        <a href="/pages/disclaimer" class="footer__bottom-link">DISCLAIMER</a>
      </div>

      <div class="footer__bottom-right">
        <span class="footer__accept-text">WE ACCEPT</span>
        <div class="footer__payment-icons">
          {% assign enabled_payment_types = 'visa,master,american_express,rupay,upi' | split: ',' %}
          {% for type in enabled_payment_types %}
            {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</footer>

{% stylesheet %}
  .footer-wrapper {
    background-color: var(--footer-bg, #013F3E);
    color: var(--footer-text, var(--color-secondary-bg, #FDFBF7));
    --footer-accent: var(--footer-accent-setting, var(--color-accent, #D4AF37));
    padding-top: 6.5rem;
    padding-bottom: 0;
    border-top: 1px solid color-mix(in srgb, var(--footer-text) 10%, transparent);
    font-family: 'Montserrat', sans-serif;
  }

  .footer.container {
    width: 100%;
    max-width: 1600px;
    margin: 0 auto;
    padding-left: 4rem;
    padding-right: 4rem;
    box-sizing: border-box;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 5rem;
    padding-bottom: 4rem;
  }

  .footer__col {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Typography */
  .footer__logo {
    color: var(--footer-accent);
    font-family: 'Montserrat', sans-serif;
    font-size: 2.2rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    margin: 0;
  }

  .footer__heading {
    color: var(--footer-text);
    font-family: 'Montserrat', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin: 0;
    padding-bottom: 1.2rem;
    position: relative;
  }
  .footer__heading::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 28px;
    height: 1.5px;
    background-color: var(--footer-accent);
  }

  .footer__description {
    font-size: 1.4rem;
    line-height: 1.7;
    color: color-mix(in srgb, var(--footer-text) 75%, transparent);
    margin: 0;
    max-width: 32rem;
  }

  /* Navigation Lists */
  .footer__links-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin: 0;
    padding: 0;
    margin-top: 2.2rem;
  }

  .footer__link {
    font-size: 1.4rem;
    color: color-mix(in srgb, var(--footer-text) 85%, transparent);
    text-decoration: none;
    transition: color 0.25s ease, transform 0.25s ease;
    display: inline-flex;
    align-items: center;
  }

  .footer__link::before {
    content: "";
    display: inline-block;
    width: 5px;
    height: 5px;
    border-top: 1.5px solid currentColor;
    border-right: 1.5px solid currentColor;
    transform: rotate(45deg);
    margin-right: 1.2rem;
    opacity: 0.8;
  }

  .footer__link:hover {
    color: var(--footer-accent);
    transform: translateX(4px);
  }

  /* Social Icons */
  .footer__social-icons {
    display: flex;
    gap: 1.2rem;
    margin-top: 0.5rem;
  }

  .footer__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.6rem;
    height: 3.6rem;
    border-radius: 50%;
    background-color: color-mix(in srgb, var(--footer-text) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--footer-text) 10%, transparent);
    color: color-mix(in srgb, var(--footer-text) 85%, transparent);
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    text-decoration: none;
  }

  .footer__social-link:hover {
    background-color: color-mix(in srgb, var(--footer-accent) 15%, transparent);
    border-color: var(--footer-accent);
    color: var(--footer-accent);
    transform: translateY(-2px);
  }

  .footer__social-link svg {
    width: 1.6rem;
    height: 1.6rem;
  }

  /* Inline Contact Info */
  .footer__contact-list-inline {
    list-style-type: none !important;
    padding-left: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    color: color-mix(in srgb, var(--footer-text) 75%, transparent);
    font-size: 1.4rem;
  }

  .footer__contact-list-inline li {
    list-style-type: none !important;
    line-height: 1.6;
    padding-left: 0;
    margin-left: 0;
  }

  .footer__contact-link {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    color: inherit;
    text-decoration: none;
    transition: color 0.25s ease;
  }
  
  .footer__contact-icon {
    width: 1.8rem;
    height: 1.8rem;
    flex-shrink: 0;
    margin-top: 0.2rem;
    color: var(--footer-accent);
    transition: transform 0.25s ease;
  }

  .footer__contact-link:hover {
    color: var(--footer-accent);
  }
  
  .footer__contact-link:hover .footer__contact-icon {
    transform: scale(1.1);
  }

  /* Footer Bottom Details */
  .footer-bottom-wrapper {
    background-color: #013F3E;
    color: #FFFFFF;
    width: 100%;
    padding: 2.5rem 0;
  }
  
  .footer__bottom.container {
    width: 100%;
    max-width: 1600px;
    margin: 0 auto;
    padding-left: 4rem;
    padding-right: 4rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 1.25rem;
    color: #FFFFFF;
  }

  .footer__bottom-left {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .footer__bottom-logo {
    height: 40px;
    width: auto;
    object-fit: contain;
  }

  .footer__bottom-center {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .footer__bottom-link {
    color: #FFFFFF;
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: color 0.25s ease;
  }

  .footer__bottom-link:hover {
    color: var(--footer-accent);
  }

  .footer__bottom-divider {
    color: rgba(255, 255, 255, 0.4);
  }

  .footer__bottom-right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  
  .footer__accept-text {
    letter-spacing: 0.05em;
    color: #FFFFFF;
  }

  .footer__payment-icons {
    display: flex;
    gap: 0.8rem;
    align-items: center;
  }
  
  .footer__payment-icons svg {
    height: 24px;
    width: auto;
    border-radius: 4px;
    background: #fff;
    padding: 2px 4px;
  }

  /* Responsive Adjustments */
  @media (max-width: 1100px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
    .footer__col:first-child {
      grid-column: span 2;
    }
  }

  @media (max-width: 900px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
    }
    .footer__col:first-child {
      grid-column: span 2;
    }
  }

  @media (max-width: 768px) {
    .footer-wrapper {
      padding-top: 5rem;
      padding-bottom: 0;
    }
    .footer.container {
      padding-left: 2rem;
      padding-right: 2rem;
    }
    .footer__grid {
      grid-template-columns: 1fr;
      gap: 3.5rem;
      padding-bottom: 3.5rem;
    }
    .footer-bottom-wrapper {
      padding: 2rem 0;
    }
    .footer__bottom.container {
      flex-direction: column;
      gap: 2.5rem;
      text-align: center;
      padding-left: 2rem;
      padding-right: 2rem;
    }
    .footer__bottom-left {
      flex-direction: column;
      gap: 1rem;
    }
    .footer__bottom-center {
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
    }
    .footer__bottom-right {
      flex-direction: column;
      gap: 1rem;
    }
  }
{% endstylesheet %}

