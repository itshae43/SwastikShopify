{% comment %}
  Renders the main store footer, featuring brand profile, quick links, customer support links, contact details, social media links, and copyright info.
  Styled on a dark brand green background with gold/accent headings and elegant hover states.
{% endcomment %}

<footer class="footer-wrapper" style="{% if section.settings.color_footer_bg != blank %}--footer-bg: {{ section.settings.color_footer_bg }};{% endif %} {% if section.settings.color_footer_text != blank %}--footer-text: {{ section.settings.color_footer_text }};{% endif %} {% if section.settings.color_footer_accent != blank %}--footer-accent-setting: {{ section.settings.color_footer_accent }};{% endif %}">
  <div class="footer container">
    <div class="footer__grid">
      <!-- Col 1: Brand Info & Contact Info -->
      <div class="footer__col footer__col--brand">
        <h3 class="footer__logo serif-font">{{ section.settings.brand_name }}</h3>
        <p class="footer__description">
          {{ section.settings.brand_description }}
        </p>
        <ul class="footer__contact-list-inline">
          {% if section.settings.contact_address != blank %}
            <li>{{ section.settings.contact_address | escape }}</li>
          {% endif %}
          {% if section.settings.contact_phone != blank %}
            <li><a href="tel:{{ section.settings.contact_phone | replace: ' ', '' }}">{{ section.settings.contact_phone | escape }}</a></li>
          {% endif %}
          {% if section.settings.contact_email != blank %}
            <li><a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_email | escape }}</a></li>
          {% endif %}
        </ul>
        <div class="footer__social-icons">
          {% if section.settings.social_facebook_link != blank %}
            <a href="{{ section.settings.social_facebook_link }}" class="footer__social-link" aria-label="Facebook">
              <svg class="icon icon-facebook" viewBox="0 0 24 24" fill="currentColor">
                <path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c5.05-.5 9-4.76 9-9.95z"/>
              </svg>
            </a>
          {% endif %}
          {% if section.settings.social_instagram_link != blank %}
            <a href="{{ section.settings.social_instagram_link }}" class="footer__social-link" aria-label="Instagram">
              <svg class="icon icon-instagram" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
              </svg>
            </a>
          {% endif %}
          {% if section.settings.social_twitter_link != blank %}
            <a href="{{ section.settings.social_twitter_link }}" class="footer__social-link" aria-label="Twitter">
              <svg class="icon icon-twitter" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path>
              </svg>
            </a>
          {% endif %}
          {% if section.settings.social_youtube_link != blank %}
            <a href="{{ section.settings.social_youtube_link }}" class="footer__social-link" aria-label="YouTube">
              <svg class="icon icon-youtube" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.41 19c1.71.46 8.59.46 8.59.46s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96 29 29 0 0 0 .46-5.33 29 29 0 0 0-.46-5.33z"></path>
                <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon>
              </svg>
            </a>
          {% endif %}
        </div>
      </div>

      <!-- Col 2: Quick Links Navigation -->
      <div class="footer__col">
        <h4 class="footer__heading serif-font">Quick Links</h4>
        <ul class="footer__links-list">
          {% if section.settings.menu != blank %}
            {% for link in section.settings.menu.links %}
              <li><a href="{{ link.url }}" class="footer__link">{{ link.title }}</a></li>
            {% endfor %}
          {% else %}
            <li><a href="/pages/about-us" class="footer__link">About Us</a></li>
            <li><a href="{{ routes.collections_url }}" class="footer__link">Collections</a></li>
            <li><a href="{{ routes.collections_url }}/bridal" class="footer__link">Bridal Jewelry</a></li>
            <li><a href="{{ routes.collections_url }}/new-arrivals" class="footer__link">New Arrivals</a></li>
            <li><a href="/pages/contact" class="footer__link">Contact Us</a></li>
          {% endif %}
        </ul>
      </div>

      <!-- Col 3: Customer Care Navigation -->
      <div class="footer__col">
        <h4 class="footer__heading serif-font">Customer Care</h4>
        <ul class="footer__links-list">
          {% if section.settings.customer_menu != blank %}
            {% for link in section.settings.customer_menu.links %}
              <li><a href="{{ link.url }}" class="footer__link">{{ link.title }}</a></li>
            {% endfor %}
          {% else %}
            <li><a href="/pages/shipping-policy" class="footer__link">Shipping Policy</a></li>
            <li><a href="/pages/returns-exchanges" class="footer__link">Return & Exchange</a></li>
            <li><a href="/pages/jewelry-care" class="footer__link">Jewelry Care</a></li>
            <li><a href="/pages/size-guide" class="footer__link">Size Guide</a></li>
            <li><a href="/pages/faq" class="footer__link">FAQ</a></li>
          {% endif %}
        </ul>
      </div>


    </div>

    <!-- Bottom copyright and policy links -->
    <div class="footer__bottom">
      <div class="footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ section.settings.brand_name }}. All rights reserved.
      </div>
      <div class="footer__bottom-links">
        <a href="{{ section.settings.privacy_policy_url | default: '#' }}" class="footer__bottom-link">Privacy Policy</a>
        <a href="{{ section.settings.terms_of_service_url | default: '#' }}" class="footer__bottom-link">Terms of Service</a>
        <a href="{{ section.settings.sitemap_url | default: '#' }}" class="footer__bottom-link">Sitemap</a>
      </div>
    </div>
  </div>
</footer>

{% stylesheet %}
  .footer-wrapper {
    background-color: var(--footer-bg, #013F3E);
    color: var(--footer-text, var(--color-secondary-bg, #FDFBF7));
    --footer-accent: var(--footer-accent-setting, var(--color-accent, #D4AF37));
    padding-top: 6.5rem;
    padding-bottom: 3rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    font-family: 'Montserrat', sans-serif;
  }

  .footer.container {
    width: 100%;
    max-width: 1600px;
    margin: 0 auto;
    padding-left: 4rem;
    padding-right: 4rem;
    box-sizing: border-box;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 5rem;
    padding-bottom: 4rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer__col {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Typography */
  .footer__logo {
    color: var(--footer-accent);
    font-family: 'Montserrat', sans-serif;
    font-size: 2.2rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    margin: 0;
  }

  .footer__heading {
    color: var(--footer-accent);
    font-family: 'Montserrat', sans-serif;
    font-size: 1.8rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    margin: 0;
    padding-bottom: 0.5rem;
  }

  .footer__description {
    font-size: 1.4rem;
    line-height: 1.7;
    color: rgba(253, 251, 247, 0.75);
    margin: 0;
    max-width: 32rem;
  }

  /* Navigation Lists */
  .footer__links-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    margin: 0;
    padding: 0;
  }

  .footer__link {
    font-size: 1.4rem;
    color: rgba(253, 251, 247, 0.75);
    text-decoration: none;
    transition: color 0.25s ease, transform 0.25s ease;
    display: inline-block;
  }

  .footer__link:hover {
    color: var(--footer-accent);
    transform: translateX(4px);
  }

  /* Social Icons */
  .footer__social-icons {
    display: flex;
    gap: 1.2rem;
    margin-top: 0.5rem;
  }

  .footer__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.6rem;
    height: 3.6rem;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: rgba(253, 251, 247, 0.85);
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    text-decoration: none;
  }

  .footer__social-link:hover {
    background-color: rgba(212, 175, 55, 0.15);
    border-color: var(--footer-accent);
    color: var(--footer-accent);
    transform: translateY(-2px);
  }

  .footer__social-link svg {
    width: 1.6rem;
    height: 1.6rem;
  }

  /* Inline Contact Info */
  .footer__contact-list-inline {
    list-style-type: disc;
    padding-left: 2rem;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    color: rgba(253, 251, 247, 0.75);
    font-size: 1.4rem;
  }

  .footer__contact-list-inline li {
    line-height: 1.6;
    padding-left: 0.5rem;
  }

  .footer__contact-list-inline li::marker {
    color: rgba(253, 251, 247, 0.75);
    font-size: 1.2em;
  }

  .footer__contact-list-inline a {
    color: inherit;
    text-decoration: none;
    transition: color 0.25s ease;
  }

  .footer__contact-list-inline a:hover {
    color: var(--footer-accent);
  }

  /* Footer Bottom Details */
  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 2.8rem;
    font-size: 1.25rem;
    color: rgba(253, 251, 247, 0.5);
  }

  .footer__bottom-links {
    display: flex;
    gap: 2.4rem;
  }

  .footer__bottom-link {
    color: rgba(253, 251, 247, 0.5);
    text-decoration: none;
    transition: color 0.25s ease;
  }

  .footer__bottom-link:hover {
    color: var(--footer-accent);
  }

  /* Responsive Adjustments */
  @media (max-width: 1100px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
    .footer__col:first-child {
      grid-column: span 2;
    }
  }

  @media (max-width: 900px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
    }
    .footer__col:first-child {
      grid-column: span 2;
    }
  }

  @media (max-width: 768px) {
    .footer-wrapper {
      padding-top: 5rem;
      padding-bottom: 2.5rem;
    }
    .footer.container {
      padding-left: 2rem;
      padding-right: 2rem;
    }
    .footer__grid {
      grid-template-columns: 1fr;
      gap: 3.5rem;
      padding-bottom: 3.5rem;
    }
    .footer__bottom {
      flex-direction: column;
      gap: 1.8rem;
      align-items: flex-start;
      padding-top: 2.4rem;
    }
    .footer__bottom-links {
      width: 100%;
      justify-content: flex-start;
      flex-wrap: wrap;
      gap: 1.6rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand Name",
      "default": "Swastik Jewels"
    },
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Brand Description",
      "default": "Crafting timeless elegance since 1985. Your trusted partner for luxury jewelry."
    },
    {
      "type": "url",
      "id": "social_facebook_link",
      "label": "Facebook Link"
    },
    {
      "type": "url",
      "id": "social_instagram_link",
      "label": "Instagram Link"
    },
    {
      "type": "url",
      "id": "social_twitter_link",
      "label": "Twitter/X Link"
    },
    {
      "type": "url",
      "id": "social_youtube_link",
      "label": "YouTube Link"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Quick Links Menu"
    },
    {
      "type": "link_list",
      "id": "customer_menu",
      "label": "Customer Care Menu"
    },
    {
      "type": "header",
      "content": "Contact Info"
    },
    {
      "type": "text",
      "id": "contact_address",
      "label": "Address",
      "default": "123 Jewelry Street, Mumbai, Maharashtra 400001"
    },
    {
      "type": "text",
      "id": "contact_phone",
      "label": "Phone Number",
      "default": "+91 22 1234 5678"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Email Address",
      "default": "contact@swastikjewels.com"
    },
    {
      "type": "header",
      "content": "Footer Bottom Links"
    },
    {
      "type": "url",
      "id": "privacy_policy_url",
      "label": "Privacy Policy URL"
    },
    {
      "type": "url",
      "id": "terms_of_service_url",
      "label": "Terms of Service URL"
    },
    {
      "type": "url",
      "id": "sitemap_url",
      "label": "Sitemap URL"
    },
    {
      "type": "header",
      "content": "Footer Colors"
    },
    {
      "type": "color",
      "id": "color_footer_bg",
      "label": "Background Color",
      "default": "#013F3E"
    },
    {
      "type": "color",
      "id": "color_footer_text",
      "label": "Text Color",
      "default": "#FDFBF7"
    },
    {
      "type": "color",
      "id": "color_footer_accent",
      "label": "Accent Color",
      "default": "#D4AF37"
    }
  ]
}
{% endschema %}
