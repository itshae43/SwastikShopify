<div class="discover-grid-section" style="--bg-color: {{ section.settings.bg_color }};">
  <div class="discover-grid-header">
    {%- if section.settings.subheading != blank -%}
      <span class="discover-grid-subheading">{{ section.settings.subheading | escape }}</span>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2 class="discover-grid-title">{{ section.settings.title | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.description != blank -%}
      <p class="discover-grid-description">{{ section.settings.description | escape }}</p>
    {%- endif -%}
  </div>

  <div class="discover-grid-container">
    {%- for block in section.blocks -%}
      {%- liquid
        assign card_class = 'discover-grid-card--' | append: block.settings.color_scheme
        assign loop_index = forloop.index
        
        if loop_index == 1
          assign fallback_image_name = 'rings_category.png'
        elsif loop_index == 2
          assign fallback_image_name = 'earrings_category.png'
        elsif loop_index == 3
          assign fallback_image_name = 'pendants_category.png'
        elsif loop_index == 4
          assign fallback_image_name = 'tennis_category.png'
        endif
      -%}
      <a href="{{ block.settings.link | default: '#' }}" class="discover-grid-card discover-grid-card--{{ loop_index }} {{ card_class }}" {{ block.shopify_attributes }}>
        <div class="discover-grid-card-content">
          <div class="discover-grid-card-number">
            {{ block.settings.number | escape }}
          </div>
          <h3 class="discover-grid-card-title">
            {{ block.settings.title | escape }}
          </h3>
          {%- if block.settings.description != blank -%}
            <p class="discover-grid-card-desc">
              {{ block.settings.description | escape }}
            </p>
          {%- endif -%}
          <span class="discover-grid-card-link">
            {{ 'sections.discover_grid.explore' | t | default: 'EXPLORE' }}
            <span class="discover-grid-card-arrow">&rarr;</span>
          </span>
        </div>
        <div class="discover-grid-card-image-wrap">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'discover-grid-card-image' }}
          {%- else -%}
            <img src="{{ fallback_image_name | asset_url }}" loading="lazy" class="discover-grid-card-image" alt="{{ block.settings.title | escape }}" width="400" height="400">
          {%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
.discover-grid-section {
  background-color: var(--bg-color, #ffffff);
  padding: 80px 20px;
  width: 100%;
  box-sizing: border-box;
}

.discover-grid-header {
  text-align: center;
  max-width: 600px;
  margin: 0 auto 50px auto;
}

.discover-grid-subheading {
  display: block;
  font-size: 14px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #c5a47e;
  margin-bottom: 12px;
  font-weight: 600;
}

.discover-grid-title {
  font-family: Georgia, serif;
  font-size: 36px;
  line-height: 1.2;
  text-transform: uppercase;
  color: #0b2e27;
  margin: 0 0 16px 0;
  font-weight: normal;
  letter-spacing: 0.05em;
}

.discover-grid-description {
  font-size: 16px;
  line-height: 1.6;
  color: #555555;
  margin: 0;
}

.discover-grid-container {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: repeat(2, minmax(220px, auto));
  gap: 24px;
  max-width: 1200px;
  margin: 0 auto;
}

.discover-grid-card {
  display: flex;
  position: relative;
  text-decoration: none;
  border-radius: 16px;
  overflow: hidden;
  box-sizing: border-box;
  padding: 30px;
  height: 100%;
  min-height: 220px;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.discover-grid-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 24px rgba(0, 0, 0, 0.1);
}

/* Color Themes */
.discover-grid-card--cream {
  background-color: #f7f3eb;
  color: #0b2e27;
}
.discover-grid-card--cream .discover-grid-card-title {
  color: #0b2e27 !important;
}
.discover-grid-card--cream .discover-grid-card-desc {
  color: rgba(11, 46, 39, 0.8) !important;
}
.discover-grid-card--cream .discover-grid-card-link {
  color: var(--color-accent, #c5a47e) !important;
}

.discover-grid-card--dark-green {
  background-color: #0b2e27;
  color: #ffffff;
}
.discover-grid-card--dark-green .discover-grid-card-title {
  color: #ffffff !important;
}
.discover-grid-card--dark-green .discover-grid-card-desc {
  color: rgba(255, 255, 255, 0.85) !important;
}
.discover-grid-card--dark-green .discover-grid-card-link {
  color: var(--color-accent, #c5a47e) !important;
}

/* Desktop Grid Assignments */
.discover-grid-card--1 {
  grid-column: 1;
  grid-row: 1 / 3;
  flex-direction: column;
  justify-content: space-between;
  min-height: 480px;
}

.discover-grid-card--2 {
  grid-column: 2;
  grid-row: 1;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.discover-grid-card--3 {
  grid-column: 3;
  grid-row: 1;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.discover-grid-card--4 {
  grid-column: 2 / 4;
  grid-row: 2;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

/* Card Elements Layout */
.discover-grid-card-content {
  display: flex;
  flex-direction: column;
  z-index: 2;
  max-width: 50%;
}

.discover-grid-card--1 .discover-grid-card-content {
  max-width: 100%;
}

.discover-grid-card-number {
  font-size: 16px;
  font-weight: bold;
  color: #c5a47e;
  margin-bottom: 12px;
  position: relative;
  display: inline-block;
}

.discover-grid-card-number::after {
  content: '';
  position: absolute;
  left: 0;
  bottom: -4px;
  width: 15px;
  height: 2px;
  background-color: #c5a47e;
}

.discover-grid-card-title {
  font-family: Georgia, serif;
  font-size: 24px;
  font-weight: normal;
  margin: 0 0 16px 0;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  line-height: 1.2;
}

.discover-grid-card-desc {
  font-family: 'Inter', sans-serif;
  font-size: 14px;
  line-height: 1.5;
  margin: 0 0 20px 0;
  font-weight: 300;
}

.discover-grid-card-link {
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: none;
  display: inline-flex;
  align-items: center;
  transition: color 0.3s ease;
}

.discover-grid-card-arrow {
  margin-left: 6px;
  transition: transform 0.3s ease;
}

.discover-grid-card:hover .discover-grid-card-arrow {
  transform: translateX(4px);
}

/* Card Images positioning */
.discover-grid-card-image-wrap {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 50%;
  height: 100%;
  overflow: hidden;
  z-index: 1;
  pointer-events: none;
}

.discover-grid-card--1 .discover-grid-card-image-wrap {
  width: 100%;
  height: 60%;
  position: relative;
}

.discover-grid-card-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
}

.discover-grid-card:hover .discover-grid-card-image {
  transform: scale(1.05);
}

.placeholder-svg {
  background-color: rgba(0, 0, 0, 0.05);
}

/* Mobile Layout */
@media screen and (max-width: 768px) {
  .discover-grid-section {
    padding: 30px 12px;
  }

  .discover-grid-header {
    margin-bottom: 20px;
  }

  .discover-grid-title {
    font-size: 24px;
    margin-bottom: 8px;
  }

  .discover-grid-description {
    font-size: 13px;
  }

  .discover-grid-container {
    display: grid;
    grid-template-columns: 1fr 1fr 2fr;
    grid-template-rows: auto auto;
    gap: 12px !important;
    width: 100%;
  }

  /* Reset number display on mobile */
  .discover-grid-card-number {
    display: none !important;
  }

  /* Horizontal Card (1) - Rings */
  .discover-grid-card--1 {
    grid-column: 1 / 4 !important;
    grid-row: 1 !important;
    flex-direction: row !important;
    justify-content: space-between !important;
    align-items: center !important;
    min-height: 130px !important;
    padding: 12px 16px 32px 16px !important; /* Balanced padding with room for absolute link */
    position: relative !important;
  }

  .discover-grid-card--1 .discover-grid-card-content {
    max-width: calc(100% - 92px) !important;
    width: calc(100% - 92px) !important;
    display: flex;
    flex-direction: column;
    justify-content: flex-start !important;
  }

  .discover-grid-card--1 .discover-grid-card-image-wrap {
    position: relative !important;
    width: 80px !important;
    height: 80px !important;
    flex-shrink: 0 !important;
    margin: 0 !important;
    border-radius: 8px;
    overflow: hidden;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    background-color: #f7f3eb !important; /* Cream inner box */
    padding: 6px !important;
    box-sizing: border-box;
  }

  .discover-grid-card--1 .discover-grid-card-image {
    object-fit: contain !important;
    max-width: 100% !important;
    max-height: 100% !important;
    width: auto !important;
    height: auto !important;
  }

  /* Vertical Cards (2, 3) and Horizontal Card (4) in Row 2 */
  .discover-grid-card--2,
  .discover-grid-card--3,
  .discover-grid-card--4 {
    box-sizing: border-box;
    position: relative !important;
    min-height: 130px !important;
  }

  .discover-grid-card--2,
  .discover-grid-card--3 {
    flex-direction: column !important;
    justify-content: flex-start !important;
    grid-row: 2 !important;
    padding: 10px 8px 30px 8px !important; /* Tighter padding for narrow cards */
  }

  .discover-grid-card--2 {
    grid-column: 1 !important;
  }

  .discover-grid-card--3 {
    grid-column: 2 !important;
  }

  .discover-grid-card--4 {
    grid-column: 3 !important;
    grid-row: 2 !important;
    flex-direction: row !important;
    justify-content: space-between !important;
    align-items: center !important;
    padding: 10px 10px 30px 10px !important; /* Compact padding for horizontal card */
  }

  .discover-grid-card--2 .discover-grid-card-content,
  .discover-grid-card--3 .discover-grid-card-content {
    max-width: 100% !important;
    width: 100%;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    justify-content: flex-start !important;
    padding-bottom: 6px !important;
  }

  .discover-grid-card--4 .discover-grid-card-content {
    max-width: calc(100% - 77px) !important;
    width: calc(100% - 77px) !important;
    display: flex;
    flex-direction: column;
    justify-content: flex-start !important;
  }

  .discover-grid-card--2 .discover-grid-card-image-wrap,
  .discover-grid-card--3 .discover-grid-card-image-wrap,
  .discover-grid-card--4 .discover-grid-card-image-wrap {
    position: relative !important;
    order: -1 !important;
    border-radius: 6px;
    overflow: hidden;
    background: transparent !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
  }

  .discover-grid-card--2 .discover-grid-card-image-wrap,
  .discover-grid-card--3 .discover-grid-card-image-wrap {
    width: 100% !important;
    height: 50px !important;
    margin-bottom: 6px !important;
  }

  .discover-grid-card--4 .discover-grid-card-image-wrap {
    width: 65px !important;
    height: 65px !important;
    flex-shrink: 0 !important;
    margin: 0 !important;
  }

  .discover-grid-card--2 .discover-grid-card-image,
  .discover-grid-card--3 .discover-grid-card-image,
  .discover-grid-card--4 .discover-grid-card-image {
    object-fit: contain !important;
    max-width: 100% !important;
    max-height: 100% !important;
    width: auto !important;
    height: auto !important;
  }

  /* Hide description on mobile for cards 2, 3, and 4 */
  .discover-grid-card--2 .discover-grid-card-desc,
  .discover-grid-card--3 .discover-grid-card-desc,
  .discover-grid-card--4 .discover-grid-card-desc {
    display: none !important;
  }

  /* Typography adjustments for mobile */
  .discover-grid-card-title {
    font-size: 11px !important;
    margin-bottom: 4px !important;
    font-weight: normal !important;
    line-height: 1.2 !important;
  }

  .discover-grid-card--1 .discover-grid-card-title,
  .discover-grid-card--4 .discover-grid-card-title {
    font-size: 14px !important;
  }

  .discover-grid-card-desc {
    font-size: 10px !important;
    margin: 0 0 8px 0 !important;
    line-height: 1.25 !important;
    opacity: 0.8 !important;
  }

  /* Absolute position Explore link for Bento Grid alignment */
  .discover-grid-card-link {
    position: absolute !important;
    right: 8px !important;
    bottom: 8px !important;
    margin: 0 !important;
    font-size: 10px !important;
  }

  .discover-grid-card--1 .discover-grid-card-link {
    right: 12px !important;
    bottom: 12px !important;
    font-size: 11px !important;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.discover_grid.name",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "DISCOVER"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "DIAMONDS, DESIGNED FOR YOU"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Explore our finest diamond creations, crafted for every occasion, every emotion, every you."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fdfbf7"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "t:sections.discover_grid.blocks.card.name",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "t:sections.discover_grid.blocks.card.settings.number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.discover_grid.blocks.card.settings.title",
          "default": "RINGS"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Explore our collection."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.discover_grid.blocks.card.settings.image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.discover_grid.blocks.card.settings.link"
        },
        {
          "type": "select",
          "id": "color_scheme",
          "label": "t:sections.discover_grid.blocks.card.settings.color_scheme",
          "options": [
            {
              "value": "cream",
              "label": "t:sections.discover_grid.blocks.card.settings.cream"
            },
            {
              "value": "dark-green",
              "label": "t:sections.discover_grid.blocks.card.settings.dark_green"
            }
          ],
          "default": "cream"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "t:sections.discover_grid.name",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "number": "01",
            "title": "RINGS",
            "color_scheme": "cream"
          }
        },
        {
          "type": "card",
          "settings": {
            "number": "02",
            "title": "EARRINGS",
            "color_scheme": "dark-green"
          }
        },
        {
          "type": "card",
          "settings": {
            "number": "03",
            "title": "PENDANTS",
            "color_scheme": "cream"
          }
        },
        {
          "type": "card",
          "settings": {
            "number": "04",
            "title": "TENNIS COLLECTION",
            "color_scheme": "dark-green"
          }
        }
      ]
    }
  ]
}
{% endschema %}
