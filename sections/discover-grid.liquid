<div class="discover-grid-section" style="--bg-color: {{ section.settings.bg_color }};">
  <div class="discover-grid-header">
    {%- if section.settings.subheading != blank -%}
      <span class="discover-grid-subheading">{{ section.settings.subheading | escape }}</span>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2 class="discover-grid-title">{{ section.settings.title | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.description != blank -%}
      <p class="discover-grid-description">{{ section.settings.description | escape }}</p>
    {%- endif -%}
  </div>

  <div class="discover-grid-container">
    {%- for block in section.blocks -%}
      {%- liquid
        assign loop_index = forloop.index
      -%}
      <a href="{{ block.settings.link | default: '#' }}" class="discover-grid-card discover-grid-card--{{ loop_index }}" {{ block.shopify_attributes }}>
        <div class="discover-grid-card-image-wrap">
          {%- if block.settings.image != blank -%}
            <picture class="discover-grid-card-picture">
              {%- if block.settings.image_mobile != blank -%}
                <source media="(max-width: 767px)" srcset="{{ block.settings.image_mobile | image_url: width: 768 }}">
              {%- else -%}
                <source media="(max-width: 767px)" srcset="{{ block.settings.image | image_url: width: 768 }}">
              {%- endif -%}
              <source media="(min-width: 768px)" srcset="{{ block.settings.image | image_url: width: 1200 }}">
              <img src="{{ block.settings.image | image_url: width: 1200 }}" 
                   alt="{{ block.settings.image.alt | default: 'Category Image' | escape }}" 
                   class="discover-grid-card-image" 
                   loading="lazy"
                   width="{{ block.settings.image.width }}"
                   height="{{ block.settings.image.height }}">
            </picture>
          {%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
.discover-grid-section {
  background-color: var(--bg-color, #ffffff);
  padding: 80px 20px;
  width: 100%;
  box-sizing: border-box;
}

.discover-grid-header {
  text-align: center;
  max-width: 600px;
  margin: 0 auto 50px auto;
}

.discover-grid-subheading {
  display: block;
  font-size: 14px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #c5a47e;
  margin-bottom: 12px;
  font-weight: 600;
}

.discover-grid-title {
  font-family: Georgia, serif;
  font-size: 36px;
  line-height: 1.2;
  text-transform: uppercase;
  color: #0b2e27;
  margin: 0 0 16px 0;
  font-weight: normal;
  letter-spacing: 0.05em;
}

.discover-grid-description {
  font-size: 16px;
  line-height: 1.6;
  color: #555555;
  margin: 0;
}

.discover-grid-container {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: repeat(2, minmax(220px, auto));
  gap: 24px;
  max-width: 1200px;
  margin: 0 auto;
}

.discover-grid-card {
  display: block;
  position: relative;
  text-decoration: none;
  border-radius: 16px;
  overflow: hidden;
  box-sizing: border-box;
  height: 100%;
  min-height: 220px;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  border: 1px solid rgba(11, 46, 39, 0.1);
}

.discover-grid-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 12px 24px rgba(0, 0, 0, 0.1);
}

/* Desktop Grid Assignments */
.discover-grid-card--1 {
  grid-column: 1 / 3;
  grid-row: 1;
}

.discover-grid-card--2 {
  grid-column: 3;
  grid-row: 1;
}

.discover-grid-card--3 {
  grid-column: 1;
  grid-row: 2;
}

.discover-grid-card--4 {
  grid-column: 2 / 4;
  grid-row: 2;
}

/* Card Images positioning */
.discover-grid-card-image-wrap {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.discover-grid-card-picture {
  display: block;
  width: 100%;
  height: 100%;
}

.discover-grid-card-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
}

.discover-grid-card:hover .discover-grid-card-image {
  transform: scale(1.05);
}

/* Mobile Layout */
@media screen and (max-width: 768px) {
  .discover-grid-section {
    padding: 30px 12px;
  }

  .discover-grid-header {
    margin-bottom: 20px;
  }

  .discover-grid-title {
    font-size: 24px;
    margin-bottom: 8px;
  }

  .discover-grid-description {
    font-size: 13px;
  }

  /* 2-column grid: cards 1 and 4 span both, cards 2 and 3 each take one */
  .discover-grid-container {
    display: grid !important;
    grid-template-columns: 1fr 1fr !important;
    grid-template-rows: auto auto auto !important;
    gap: 10px !important;
    width: 100%;
  }

  /* Shared card base on mobile */
  .discover-grid-card--1,
  .discover-grid-card--2,
  .discover-grid-card--3,
  .discover-grid-card--4 {
    display: block !important;
    min-height: 110px !important;
    box-sizing: border-box !important;
    border-radius: 14px !important;
    position: relative !important;
    border: 1px solid rgba(11, 46, 39, 0.1) !important;
    overflow: hidden !important;
  }

  /* Card 1 (Rings) — full width, Row 1 */
  .discover-grid-card--1 {
    grid-column: 1 / 3 !important;
    grid-row: 1 !important;
  }

  /* Cards 2 (Earrings) and 3 (Pendants) — equal halves, Row 2 */
  .discover-grid-card--2 {
    grid-column: 1 !important;
    grid-row: 2 !important;
  }

  .discover-grid-card--3 {
    grid-column: 2 !important;
    grid-row: 2 !important;
  }

  /* Card 4 (Tennis Collection) — full width, Row 3 */
  .discover-grid-card--4 {
    grid-column: 1 / 3 !important;
    grid-row: 3 !important;
  }

  /* Image wrap covers entirely on mobile */
  .discover-grid-card--1 .discover-grid-card-image-wrap,
  .discover-grid-card--2 .discover-grid-card-image-wrap,
  .discover-grid-card--3 .discover-grid-card-image-wrap,
  .discover-grid-card--4 .discover-grid-card-image-wrap {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    height: 100% !important;
    border-radius: 0 !important;
    margin: 0 !important;
    padding: 0 !important;
    display: block !important;
    background-color: transparent !important;
  }

  .discover-grid-card--1 .discover-grid-card-picture,
  .discover-grid-card--2 .discover-grid-card-picture,
  .discover-grid-card--3 .discover-grid-card-picture,
  .discover-grid-card--4 .discover-grid-card-picture {
    display: block !important;
    width: 100% !important;
    height: 100% !important;
  }

  .discover-grid-card--1 .discover-grid-card-image,
  .discover-grid-card--2 .discover-grid-card-image,
  .discover-grid-card--3 .discover-grid-card-image,
  .discover-grid-card--4 .discover-grid-card-image {
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.discover_grid.name",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "DISCOVER"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "DIAMONDS, DESIGNED FOR YOU"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Explore our finest diamond creations, crafted for every occasion, every emotion, every you."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fdfbf7"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "t:sections.discover_grid.blocks.card.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.discover_grid.blocks.card.settings.image_desktop"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "t:sections.discover_grid.blocks.card.settings.image_mobile"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.discover_grid.blocks.card.settings.link"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "t:sections.discover_grid.name",
      "blocks": [
        {
          "type": "card"
        },
        {
          "type": "card"
        },
        {
          "type": "card"
        },
        {
          "type": "card"
        }
      ]
    }
  ]
}
{% endschema %}
