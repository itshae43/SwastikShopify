<div class="discover-grid-section" style="--bg-color: {{ section.settings.bg_color }};">
  <div class="discover-grid-header">
    {%- if section.settings.subheading != blank -%}
      <span class="discover-grid-subheading">{{ section.settings.subheading | escape }}</span>
    {%- endif -%}
    {%- if section.settings.title != blank -%}
      <h2 class="discover-grid-title">{{ section.settings.title | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.description != blank -%}
      <p class="discover-grid-description">{{ section.settings.description | escape }}</p>
    {%- endif -%}
  </div>

  <div class="discover-grid-container">
    {%- for block in section.blocks -%}
      {%- liquid
        assign card_class = 'discover-grid-card--' | append: block.settings.color_scheme
        assign loop_index = forloop.index
      -%}
      <a href="{{ block.settings.link | default: '#' }}" class="discover-grid-card discover-grid-card--{{ loop_index }} {{ card_class }}" {{ block.shopify_attributes }}>
        <div class="discover-grid-card-content">
          <div class="discover-grid-card-number">
            {{ block.settings.number | escape }}
          </div>
          <h3 class="discover-grid-card-title">
            {{ block.settings.title | escape }}
          </h3>
          <span class="discover-grid-card-link">
            {{ 'sections.discover_grid.explore' | t | default: 'EXPLORE' }}
            <span class="discover-grid-card-arrow">&rarr;</span>
          </span>
        </div>
        <div class="discover-grid-card-image-wrap">
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', class: 'discover-grid-card-image' }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'discover-grid-card-image placeholder-svg' }}
          {%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
.discover-grid-section {
  background-color: var(--bg-color, #ffffff);
  padding: 60px 20px;
  width: 100%;
  box-sizing: border-box;
}

.discover-grid-header {
  text-align: center;
  max-width: 600px;
  margin: 0 auto 40px auto;
}

.discover-grid-subheading {
  display: block;
  font-size: 14px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #c5a47e;
  margin-bottom: 12px;
  font-weight: 600;
}

.discover-grid-title {
  font-family: Georgia, serif;
  font-size: 32px;
  line-height: 1.2;
  text-transform: uppercase;
  color: #0b2e27;
  margin: 0 0 16px 0;
  font-weight: normal;
  letter-spacing: 0.05em;
}

.discover-grid-description {
  font-size: 16px;
  line-height: 1.6;
  color: #555555;
  margin: 0;
}

.discover-grid-container {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  grid-template-rows: repeat(2, minmax(220px, auto));
  gap: 20px;
  max-width: 1200px;
  margin: 0 auto;
}

.discover-grid-card {
  display: flex;
  position: relative;
  text-decoration: none;
  border-radius: 12px;
  overflow: hidden;
  box-sizing: border-box;
  padding: 30px;
  height: 100%;
  min-height: 220px;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.discover-grid-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
}

/* Color Themes */
.discover-grid-card--cream {
  background-color: #f7f3eb;
  color: #0b2e27;
}

.discover-grid-card--dark-green {
  background-color: #0b2e27;
  color: #ffffff;
}

/* Desktop Grid Assignments */
.discover-grid-card--1 {
  grid-column: 1;
  grid-row: 1 / 3;
  flex-direction: column;
  justify-content: space-between;
  min-height: 460px;
}

.discover-grid-card--2 {
  grid-column: 2;
  grid-row: 1;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.discover-grid-card--3 {
  grid-column: 3;
  grid-row: 1;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.discover-grid-card--4 {
  grid-column: 2 / 4;
  grid-row: 2;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

/* Card Elements Layout */
.discover-grid-card-content {
  display: flex;
  flex-direction: column;
  z-index: 2;
  max-width: 50%;
}

.discover-grid-card--1 .discover-grid-card-content {
  max-width: 100%;
}

.discover-grid-card-number {
  font-size: 16px;
  font-weight: bold;
  color: #c5a47e;
  margin-bottom: 12px;
  position: relative;
  display: inline-block;
}

.discover-grid-card-number::after {
  content: '';
  position: absolute;
  left: 0;
  bottom: -4px;
  width: 15px;
  height: 2px;
  background-color: #c5a47e;
}

.discover-grid-card-title {
  font-family: Georgia, serif;
  font-size: 24px;
  font-weight: normal;
  margin: 0 0 20px 0;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  line-height: 1.2;
}

.discover-grid-card-link {
  font-size: 12px;
  font-weight: bold;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  display: flex;
  align-items: center;
}

.discover-grid-card-arrow {
  margin-left: 6px;
  transition: transform 0.3s ease;
}

.discover-grid-card:hover .discover-grid-card-arrow {
  transform: translateX(4px);
}

/* Card Images positioning */
.discover-grid-card-image-wrap {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 50%;
  height: 100%;
  overflow: hidden;
  z-index: 1;
  pointer-events: none;
}

.discover-grid-card--1 .discover-grid-card-image-wrap {
  width: 100%;
  height: 60%;
  position: relative;
}

.discover-grid-card-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease;
}

.discover-grid-card:hover .discover-grid-card-image {
  transform: scale(1.05);
}

.placeholder-svg {
  background-color: rgba(0, 0, 0, 0.05);
}

/* Mobile Layout */
@media screen and (max-width: 768px) {
  .discover-grid-section {
    padding: 40px 15px;
  }

  .discover-grid-container {
    grid-template-columns: 1fr;
    grid-template-rows: auto;
    gap: 15px;
  }

  .discover-grid-card {
    grid-column: auto !important;
    grid-row: auto !important;
    flex-direction: row !important;
    justify-content: space-between !important;
    align-items: center !important;
    min-height: 180px !important;
    padding: 20px;
  }

  .discover-grid-card-content {
    max-width: 60% !important;
  }

  .discover-grid-card-image-wrap {
    width: 40% !important;
    height: 100% !important;
    position: absolute !important;
    right: 0 !important;
    bottom: 0 !important;
  }

  .discover-grid-card-title {
    font-size: 20px;
    margin-bottom: 12px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.discover_grid.name",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "DISCOVER"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "DIAMONDS, DESIGNED FOR YOU"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Explore our finest diamond creations, crafted for every occasion, every emotion, every you."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fdfbf7"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "t:sections.discover_grid.blocks.card.name",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "t:sections.discover_grid.blocks.card.settings.number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.discover_grid.blocks.card.settings.title",
          "default": "RINGS"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.discover_grid.blocks.card.settings.image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.discover_grid.blocks.card.settings.link"
        },
        {
          "type": "select",
          "id": "color_scheme",
          "label": "t:sections.discover_grid.blocks.card.settings.color_scheme",
          "options": [
            {
              "value": "cream",
              "label": "t:sections.discover_grid.blocks.card.settings.cream"
            },
            {
              "value": "dark-green",
              "label": "t:sections.discover_grid.blocks.card.settings.dark_green"
            }
          ],
          "default": "cream"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "t:sections.discover_grid.name",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "number": "01",
            "title": "RINGS",
            "color_scheme": "cream"
          }
        },
        {
          "type": "card",
          "settings": {
            "number": "02",
            "title": "EARRINGS",
            "color_scheme": "dark-green"
          }
        },
        {
          "type": "card",
          "settings": {
            "number": "03",
            "title": "PENDANTS",
            "color_scheme": "cream"
          }
        },
        {
          "type": "card",
          "settings": {
            "number": "04",
            "title": "TENNIS COLLECTION",
            "color_scheme": "dark-green"
          }
        }
      ]
    }
  ]
}
{% endschema %}
