<div class="mobile-promo-cards" style="--padding-top: {{ section.settings.padding_top }}px; --padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="mobile-promo-cards__slider">
    {% for block in section.blocks %}
      {%- liquid
        assign bg_start = block.settings.bg_color_start | default: '#9B1A22'
        assign bg_end = block.settings.bg_color_end | default: '#540D12'
      -%}
      <div class="mobile-promo-cards__card" {{ block.shopify_attributes }} style="--bg-start: {{ bg_start }}; --bg-end: {{ bg_end }};">
        
        {%- if block.settings.link != blank -%}
          <a href="{{ block.settings.link }}" class="mobile-promo-cards__link">
        {%- endif -%}

        <!-- Wavy Background Effect -->
        <div class="mobile-promo-cards__bg-wave mobile-promo-cards__bg-wave--1"></div>
        <div class="mobile-promo-cards__bg-wave mobile-promo-cards__bg-wave--2"></div>
        
        <div class="mobile-promo-cards__content">
          <div class="mobile-promo-cards__main-offer">
            <div class="mobile-promo-cards__top-text serif-font">{{ block.settings.small_top_text }}</div>
            <div class="mobile-promo-cards__offer-group">
              <div class="mobile-promo-cards__number serif-font">{{ block.settings.huge_number }}</div>
              <div class="mobile-promo-cards__suffix-wrap">
                {%- if block.settings.show_divider -%}
                  <div class="mobile-promo-cards__divider"></div>
                {%- endif -%}
                <div class="mobile-promo-cards__suffix serif-font">{{ block.settings.suffix_text }}</div>
                {%- if block.settings.show_divider -%}
                  <div class="mobile-promo-cards__divider mobile-promo-cards__divider--bottom">
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" class="mobile-promo-cards__star">
                      <path d="M6 0L6.75 4.5L12 6L6.75 7.5L6 12L5.25 7.5L0 6L5.25 4.5L6 0Z" fill="currentColor"/>
                    </svg>
                  </div>
                {%- endif -%}
              </div>
            </div>
          </div>
          
          <div class="mobile-promo-cards__subtitles">
            {%- if block.settings.subtitle_1 != blank -%}
              <p class="mobile-promo-cards__subtitle">{{ block.settings.subtitle_1 }}</p>
            {%- endif -%}
            {%- if block.settings.subtitle_2 != blank -%}
              <p class="mobile-promo-cards__subtitle">{{ block.settings.subtitle_2 }}</p>
            {%- endif -%}
          </div>
          
          {%- if block.settings.bottom_text != blank -%}
            <div class="mobile-promo-cards__bottom-text">
              {{ block.settings.bottom_text }}
            </div>
          {%- endif -%}
        </div>

        {%- if block.settings.link != blank -%}
          </a>
        {%- endif -%}

      </div>
    {% endfor %}
  </div>
</div>

{% stylesheet %}
  /* Desktop hidden */
  @media screen and (min-width: 769px) {
    .mobile-promo-cards {
      display: none !important;
    }
  }

  .mobile-promo-cards {
    padding-top: var(--padding-top);
    padding-bottom: var(--padding-bottom);
    width: 100%;
    overflow: hidden;
    background-color: #ffffff; /* Match background if needed */
  }

  .mobile-promo-cards__slider {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: 1.6rem;
    padding: 0 2rem;
    -ms-overflow-style: none; /* IE and Edge */
    scrollbar-width: none; /* Firefox */
  }

  .mobile-promo-cards__slider::-webkit-scrollbar {
    display: none;
  }

  .mobile-promo-cards__card {
    flex: 0 0 calc(100vw - 4rem - 3rem); /* Show part of the next card */
    min-width: 280px;
    max-width: 340px;
    height: 400px;
    border-radius: 20px;
    position: relative;
    overflow: hidden;
    scroll-snap-align: center;
    background: linear-gradient(135deg, var(--bg-start) 0%, var(--bg-end) 100%);
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    color: #ffffff;
    display: flex;
    flex-direction: column;
  }

  /* Wavy background shapes */
  .mobile-promo-cards__bg-wave {
    position: absolute;
    width: 150%;
    height: 150%;
    background: linear-gradient(180deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0) 100%);
    border-radius: 50%;
    z-index: 1;
    pointer-events: none;
  }

  .mobile-promo-cards__bg-wave--1 {
    top: 50%;
    left: -25%;
    transform: rotate(-15deg);
  }

  .mobile-promo-cards__bg-wave--2 {
    bottom: 40%;
    right: -30%;
    transform: rotate(20deg);
    background: linear-gradient(0deg, rgba(0,0,0,0.15) 0%, rgba(0,0,0,0) 100%);
  }

  .mobile-promo-cards__link {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
    color: inherit;
    position: absolute;
    top: 0;
    left: 0;
    z-index: 3;
  }

  .mobile-promo-cards__content {
    position: relative;
    z-index: 2;
    padding: 3rem 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    height: 100%;
    text-align: center;
  }

  .mobile-promo-cards__main-offer {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 2rem;
  }

  .mobile-promo-cards__top-text {
    font-size: 1.4rem;
    letter-spacing: 0.1em;
    margin-bottom: -1rem;
    align-self: flex-start;
    margin-left: 2rem;
  }

  .mobile-promo-cards__offer-group {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .mobile-promo-cards__number {
    font-size: 11rem;
    line-height: 1;
    font-weight: 300;
    letter-spacing: -0.02em;
    margin-right: 0.5rem;
  }

  .mobile-promo-cards__suffix-wrap {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    position: relative;
    margin-top: 2rem;
  }

  .mobile-promo-cards__suffix {
    font-size: 2.8rem;
    line-height: 1.2;
    font-weight: 400;
    padding: 0.5rem 0;
  }

  .mobile-promo-cards__divider {
    width: 120%;
    height: 1px;
    background-color: rgba(255, 255, 255, 0.6);
    position: relative;
  }

  .mobile-promo-cards__divider--bottom {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .mobile-promo-cards__star {
    position: absolute;
    color: #ffffff;
    width: 14px;
    height: 14px;
    background: transparent;
  }

  .mobile-promo-cards__subtitles {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .mobile-promo-cards__subtitle {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.1rem;
    letter-spacing: 0.15em;
    margin: 0;
    text-transform: uppercase;
    font-weight: 400;
    opacity: 0.9;
  }

  .mobile-promo-cards__bottom-text {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.85rem;
    opacity: 0.7;
  }
{% endstylesheet %}

