{%- liquid
  assign bg_color = section.settings.bg_color | default: '#ffffff'
  assign padding_top = section.settings.padding_top | default: 60
  assign padding_bottom = section.settings.padding_bottom | default: 60
-%}

<div class="latest-collections" style="--bg-color: {{ bg_color }}; --padding-top: {{ padding_top }}px; --padding-bottom: {{ padding_bottom }}px;">
  <div class="latest-collections__container">
    {%- if section.settings.title != blank -%}
      <h2 class="latest-collections__heading serif-font">{{ section.settings.title | escape }}</h2>
    {%- endif -%}

    <div class="latest-collections__grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign title = block.settings.title
          assign subtitle = block.settings.subtitle
          assign image = block.settings.image
          assign link = block.settings.link | default: '#'
          assign text_pos = block.settings.text_position | default: 'middle-center'
          assign title_style = block.settings.title_style | default: 'white'
          assign custom_color = block.settings.custom_title_color | default: '#ffffff'
          assign subtitle_color = block.settings.subtitle_color | default: '#ffffff'
          assign font_sz_desktop = block.settings.title_font_size_desktop | default: 28
          assign font_sz_mobile = block.settings.title_font_size_mobile | default: 20
          assign font_weight = block.settings.title_font_weight | default: '400'
          
          assign fallback_image_name = ''
          assign title_downcase = title | downcase
          if title_downcase contains 'clay'
            assign fallback_image_name = 'bond_mothers.png'
          elsif title_downcase contains 'gem'
            assign fallback_image_name = 'testimonial_bg_silk.png'
          elsif title_downcase contains 'raw'
            assign fallback_image_name = 'bond_brides.png'
          else
            assign cycle_index = forloop.index | modulo: 3
            if cycle_index == 1
              assign fallback_image_name = 'bond_mothers.png'
            elsif cycle_index == 2
              assign fallback_image_name = 'testimonial_bg_silk.png'
            else
              assign fallback_image_name = 'bond_brides.png'
            endif
          endif

          assign is_center = false
          if section.blocks.size == 3 and forloop.index == 2
            assign is_center = true
          elsif section.blocks.size != 3 and forloop.index == 2
            assign is_center = true
          endif
        -%}
        
        <div class="latest-collections__col{% if is_center %} latest-collections__col--center{% else %} latest-collections__col--side{% endif %}">
          <div class="latest-collections__card{% if is_center %} latest-collections__card--center{% else %} latest-collections__card--side{% endif %}" {{ block.shopify_attributes }}>
            <a href="{{ link }}" class="latest-collections__card-link" aria-label="{{ title | escape }}">
              <div class="latest-collections__image-wrap">
                {%- if image != blank -%}
                  {{ image | image_url: width: 1000 | image_tag: loading: 'lazy', alt: title, class: 'latest-collections__img' }}
                {%- else -%}
                  <img src="{{ fallback_image_name | asset_url }}" alt="{{ title | escape }}" loading="lazy" class="latest-collections__img" width="800" height="550">
                {%- endif -%}
              </div>
              
              <div class="latest-collections__card-overlay latest-collections__card-overlay--{{ text_pos }}">
                <div class="latest-collections__card-content">
                  <h3 class="latest-collections__card-title latest-collections__card-title--{{ title_style }} serif-font" 
                      style="--custom-color: {{ custom_color }}; --font-size-desktop: {{ font_sz_desktop }}px; --font-size-mobile: {{ font_sz_mobile }}px; --font-weight: {{ font_weight }};">
                    {{ title | escape }}
                  </h3>
                  {%- if subtitle != blank -%}
                    <p class="latest-collections__card-subtitle" style="--subtitle-color: {{ subtitle_color }};">
                      {{ subtitle | escape }}
                    </p>
                  {%- endif -%}
                </div>
              </div>
            </a>
          </div>

          {%- if is_center and section.settings.button_label != blank -%}
            <div class="latest-collections__button-container">
              <a href="{{ section.settings.button_link | default: '#' }}" 
                 class="latest-collections__btn pill-button"
                 style="--btn-bg: {{ section.settings.btn_bg_color }}; --btn-text: {{ section.settings.btn_text_color }}; --btn-hover-bg: {{ section.settings.btn_hover_bg_color }}; --btn-hover-text: {{ section.settings.btn_hover_text_color }};">
                {{ section.settings.button_label | escape }}
              </a>
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .latest-collections {
    background-color: var(--bg-color);
    padding-top: var(--padding-top);
    padding-bottom: var(--padding-bottom);
    width: 100%;
    box-sizing: border-box;
  }

  .latest-collections__container {
    max-width: 1600px;
    margin: 0 auto;
    padding-left: 4.8rem;
    padding-right: 4.8rem;
    box-sizing: border-box;
  }

  .latest-collections__heading {
    font-size: 3.6rem;
    color: var(--color-primary, #013F3E);
    margin-bottom: 6rem;
    font-weight: 500;
    text-align: center;
    letter-spacing: 0.05em;
  }

  .latest-collections__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4rem;
    align-items: end;
  }

  .latest-collections__col {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .latest-collections__col--side {
    justify-content: flex-end;
  }

  .latest-collections__col--center {
    align-items: center;
    justify-content: flex-end;
  }

  .latest-collections__card {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    width: 100%;
    background-color: #faf7f2;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .latest-collections__card--center {
    box-shadow: 0 16px 40px rgba(1, 63, 62, 0.08);
    border: 1px solid rgba(212, 175, 55, 0.25);
  }

  .latest-collections__card--side {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(1, 63, 62, 0.05);
  }

  .latest-collections__card:hover {
    transform: translateY(-8px);
  }

  .latest-collections__card--center:hover {
    box-shadow: 0 24px 50px rgba(1, 63, 62, 0.15);
    border-color: rgba(212, 175, 55, 0.5);
  }

  .latest-collections__card--side:hover {
    box-shadow: 0 16px 36px rgba(0, 0, 0, 0.08);
  }

  .latest-collections__card-link {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
  }

  .latest-collections__image-wrap {
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .latest-collections__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .latest-collections__card:hover .latest-collections__img {
    transform: scale(1.05);
  }

  .latest-collections__card-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    padding: 3.2rem;
    box-sizing: border-box;
    z-index: 2;
    background: linear-gradient(to top, rgba(1, 63, 62, 0.75) 0%, rgba(1, 63, 62, 0.2) 50%, rgba(0, 0, 0, 0) 100%);
    pointer-events: none;
  }

  .latest-collections__card-content {
    display: flex;
    flex-direction: column;
    max-width: 100%;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .latest-collections__card:hover .latest-collections__card-content {
    transform: translateY(-4px);
  }

  .latest-collections__card-overlay--top-left,
  .latest-collections__card-overlay--top-center,
  .latest-collections__card-overlay--top-right {
    align-items: flex-start;
  }
  
  .latest-collections__card-overlay--middle-left,
  .latest-collections__card-overlay--middle-center,
  .latest-collections__card-overlay--middle-right {
    align-items: center;
  }
  
  .latest-collections__card-overlay--bottom-left,
  .latest-collections__card-overlay--bottom-center,
  .latest-collections__card-overlay--bottom-right {
    align-items: flex-end;
  }

  .latest-collections__card-overlay--top-left,
  .latest-collections__card-overlay--middle-left,
  .latest-collections__card-overlay--bottom-left {
    justify-content: flex-start;
    text-align: left;
  }
  
  .latest-collections__card-overlay--top-center,
  .latest-collections__card-overlay--middle-center,
  .latest-collections__card-overlay--bottom-center {
    justify-content: center;
    text-align: center;
  }
  
  .latest-collections__card-overlay--top-right,
  .latest-collections__card-overlay--middle-right,
  .latest-collections__card-overlay--bottom-right {
    justify-content: flex-end;
    text-align: right;
  }

  .latest-collections__card-title {
    font-size: var(--font-size-desktop);
    font-weight: var(--font-weight);
    margin: 0;
    line-height: 1.2;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .latest-collections__card-title--white {
    color: #ffffff;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.15);
  }

  .latest-collections__card-title--gold {
    color: var(--color-accent, #D4AF37);
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
  }

  .latest-collections__card-title--gradient {
    background: linear-gradient(90deg, #ffffff 0%, var(--color-accent, #D4AF37) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: inline-block;
  }

  .latest-collections__card-title--custom {
    color: var(--custom-color);
  }

  .latest-collections__card-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 1.1rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--subtitle-color);
    margin: 0.8rem 0 0 0;
    opacity: 0.95;
  }

  .latest-collections__button-container {
    display: flex;
    justify-content: center;
    width: 100%;
    margin-top: 3.2rem;
  }

  .latest-collections__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1.4rem 4rem;
    background-color: var(--btn-bg, #013F3E);
    color: var(--btn-text, #ffffff);
    font-family: 'Inter', sans-serif;
    font-size: 1.3rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    text-decoration: none;
    border-radius: 5rem;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    border: 1px solid rgba(1, 63, 62, 0.1);
    box-shadow: 0 4px 15px rgba(1, 63, 62, 0.08);
  }

  .latest-collections__btn:hover {
    background-color: var(--btn-hover-bg, #025654);
    color: var(--btn-hover-text, #ffffff);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(1, 63, 62, 0.16);
  }

  @media screen and (max-width: 1200px) {
    .latest-collections__container {
      padding-left: 3rem;
      padding-right: 3rem;
    }
    .latest-collections__grid {
      gap: 3rem;
    }
  }

  @media screen and (max-width: 768px) {
    .latest-collections {
      padding-top: 5rem;
      padding-bottom: 5rem;
    }
    
    .latest-collections__container {
      padding-left: 2rem;
      padding-right: 2rem;
    }

    .latest-collections__heading {
      font-size: 2.8rem;
      margin-bottom: 4rem;
    }

    .latest-collections__grid {
      display: flex;
      flex-direction: column;
      gap: 4.8rem;
      align-items: center;
    }

    .latest-collections__col {
      max-width: 450px;
    }

    .latest-collections__card {
      aspect-ratio: 4 / 5;
    }

    .latest-collections__card-title {
      font-size: var(--font-size-mobile);
    }

    .latest-collections__card-subtitle {
      font-size: 1rem;
      letter-spacing: 0.15em;
    }

    .latest-collections__card-overlay {
      padding: 2.4rem;
    }

    .latest-collections__button-container {
      margin-top: 2.4rem;
    }

    .latest-collections__btn {
      padding: 1.2rem 3.2rem;
      font-size: 1.2rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Latest Collections",
  "class": "section",
  "tag": "section",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Browse Latest Jewellery Collections"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    },
    {
      "type": "header",
      "content": "Footer Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Browse Collections"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "btn_bg_color",
      "label": "Button Background Color",
      "default": "#013F3E"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_hover_bg_color",
      "label": "Button Hover Background Color",
      "default": "#025654"
    },
    {
      "type": "color",
      "id": "btn_hover_text_color",
      "label": "Button Hover Text Color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Collection Title"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Card Link"
        },
        {
          "type": "select",
          "id": "text_position",
          "label": "Text Position",
          "default": "middle-center",
          "options": [
            { "value": "top-left", "label": "Top Left" },
            { "value": "top-center", "label": "Top Center" },
            { "value": "top-right", "label": "Top Right" },
            { "value": "middle-left", "label": "Middle Left" },
            { "value": "middle-center", "label": "Middle Center" },
            { "value": "middle-right", "label": "Middle Right" },
            { "value": "bottom-left", "label": "Bottom Left" },
            { "value": "bottom-center", "label": "Bottom Center" },
            { "value": "bottom-right", "label": "Bottom Right" }
          ]
        },
        {
          "type": "select",
          "id": "title_style",
          "label": "Title Style",
          "default": "white",
          "options": [
            { "value": "white", "label": "White Text" },
            { "value": "gold", "label": "Gold Text" },
            { "value": "gradient", "label": "Red-Gold Gradient" },
            { "value": "custom", "label": "Custom Color" }
          ]
        },
        {
          "type": "color",
          "id": "custom_title_color",
          "label": "Custom Title Color",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "subtitle_color",
          "label": "Subtitle Color",
          "default": "#ffffff"
        },
        {
          "type": "range",
          "id": "title_font_size_desktop",
          "min": 16,
          "max": 48,
          "step": 2,
          "unit": "px",
          "label": "Title Font Size (Desktop)",
          "default": 28
        },
        {
          "type": "range",
          "id": "title_font_size_mobile",
          "min": 12,
          "max": 32,
          "step": 2,
          "unit": "px",
          "label": "Title Font Size (Mobile)",
          "default": 20
        },
        {
          "type": "select",
          "id": "title_font_weight",
          "label": "Title Font Weight",
          "default": "400",
          "options": [
            { "value": "300", "label": "Light" },
            { "value": "400", "label": "Regular" },
            { "value": "500", "label": "Medium" },
            { "value": "600", "label": "Semi-bold" },
            { "value": "700", "label": "Bold" }
          ]
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Latest Collections",
      "blocks": [
        {
          "type": "collection_card",
          "settings": {
            "title": "CLAY WHISPERS",
            "text_position": "middle-center",
            "title_style": "white"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "title": "GEMPHONY",
            "subtitle": "EVERY COLOR IS AN EMOTION",
            "text_position": "bottom-center",
            "title_style": "gradient"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "title": "RAW REVERIE",
            "text_position": "middle-right",
            "title_style": "gold"
          }
        }
      ]
    }
  ]
}
{% endschema %}
