  .pp-btn-wishlist-big {
    height: 48px;
    width: 48px;
    border: 1px solid var(--pp-border);
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--pp-radius-btn);
    cursor: pointer;
