<script>
  function initProductPage() {
    const sections = document.querySelectorAll('.product-single');
    
    sections.forEach(section => {
      // Prevent double initialization
      if (section.dataset.initialized) return;
      section.dataset.initialized = 'true';

      // 1. Thumbnail Selector & main image change logic
      const thumbnails = section.querySelectorAll('.thumbnail-btn');
      const mainImage = section.querySelector('#main-product-image') || section.querySelector('.product-single__main-image-wrapper img');
      
      const imageUrls = Array.from(thumbnails).map(btn => btn.getAttribute('data-image-url'));
      let activeIdx = 0;

      function updateActiveImage(idx) {
        if (imageUrls.length === 0) return;
        activeIdx = (idx + imageUrls.length) % imageUrls.length;
        
        if (mainImage) {
          mainImage.style.opacity = 0;
          setTimeout(() => {
            mainImage.src = imageUrls[activeIdx];
            mainImage.style.opacity = 1;
          }, 150);
        }

        thumbnails.forEach((t, i) => {
          if (i === activeIdx) {
            t.classList.add('active');
            t.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'nearest' });
          } else {
            t.classList.remove('active');
          }
        });
      }

      thumbnails.forEach((btn, idx) => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          updateActiveImage(idx);
        });
      });

      const prevBtn = section.querySelector('.prev-btn');
      const nextBtn = section.querySelector('.next-btn');

      if (prevBtn) {
        prevBtn.addEventListener('click', (e) => {
          e.preventDefault();
          updateActiveImage(activeIdx - 1);
        });
      }

      if (nextBtn) {
        nextBtn.addEventListener('click', (e) => {
          e.preventDefault();
          updateActiveImage(activeIdx + 1);
        });
      }

      if (mainImage) {
        mainImage.style.transition = 'opacity 0.15s ease-in-out';
      }

      // 2. Variant Selector Logic
      const variantDataTag = section.querySelector('[id^="ProductJson-"]');
      let variants = [];
      if (variantDataTag) {
        try {
          variants = JSON.parse(variantDataTag.textContent || variantDataTag.innerHTML);
        } catch (e) {
          console.error('Error parsing product variants JSON', e);
        }
      }

      const optionSelectorsWrapper = section.querySelector('#product-option-selectors');
      const optionGroups = optionSelectorsWrapper ? optionSelectorsWrapper.querySelectorAll('.product-single__option-group') : [];
      
      function formatMoney(cents) {
        return '₹' + (cents / 100).toLocaleString('en-IN', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
      }

      function onVariantChange() {
        if (variants.length === 0) return;

        const selectedOptions = Array.from(optionGroups).map(group => {
          const activePill = group.querySelector('.option-pill-btn.active');
          return activePill ? activePill.getAttribute('data-value') : null;
        });

        const currentVariant = variants.find(variant => {
          if (!variant.options) return false;
          return variant.options.every((opt, index) => opt === selectedOptions[index]);
        });

        if (currentVariant) {
          const idInput = section.querySelector('#product-variant-id');
          if (idInput) idInput.value = currentVariant.id;

          if (history.replaceState) {
            const newurl = window.location.protocol + '//' + window.location.host + window.location.pathname + '?variant=' + currentVariant.id;
            window.history.replaceState({ path: newurl }, '', newurl);
          }

          const priceContainer = section.querySelector('#product-price-display');
          if (priceContainer) {
            const currentPriceEl = priceContainer.querySelector('.price-current');
            const originalPriceEl = priceContainer.querySelector('.price-original');
            const discountEl = priceContainer.querySelector('.price-discount');

            if (currentPriceEl) currentPriceEl.textContent = formatMoney(currentVariant.price);
            
            if (currentVariant.compare_at_price > currentVariant.price) {
              if (originalPriceEl) {
                 originalPriceEl.textContent = formatMoney(currentVariant.compare_at_price);
                 originalPriceEl.style.display = 'inline';
              }
              if (discountEl) {
                 const discount = Math.round(((currentVariant.compare_at_price - currentVariant.price) / currentVariant.compare_at_price) * 100);
                 discountEl.textContent = discount + '% OFF';
                 discountEl.style.display = 'inline-block';
              }
            } else {
              if (originalPriceEl) originalPriceEl.style.display = 'none';
              if (discountEl) discountEl.style.display = 'none';
            }
          }
        }
      }

      optionGroups.forEach(group => {
        const pills = group.querySelectorAll('.option-pill-btn');
        pills.forEach(pill => {
          pill.addEventListener('click', (e) => {
            e.preventDefault();
            if (pill.classList.contains('active')) return;
            
            pills.forEach(p => p.classList.remove('active'));
            pill.classList.add('active');

            onVariantChange();
          });
        });
      });

      // 3. Quantity Increment/Decrement
      const qtyRow = section.querySelector('.product-single__qty-row');
      if (qtyRow) {
        const input = qtyRow.querySelector('input');
        const decBtn = qtyRow.querySelector('.decrement');
        const incBtn = qtyRow.querySelector('.increment');

        if (input && decBtn && incBtn) {
          decBtn.addEventListener('click', (e) => {
            e.preventDefault();
            let val = parseInt(input.value) || 1;
            if (val > 1) {
              input.value = val - 1;
            }
          });

          incBtn.addEventListener('click', (e) => {
            e.preventDefault();
            let val = parseInt(input.value) || 1;
            input.value = val + 1;
          });
        }
      }

      // 4. Accordion Toggle logic
      const accordions = section.querySelectorAll('.accordion-item');
      accordions.forEach(item => {
        const header = item.querySelector('.accordion-header');
        const content = item.querySelector('.accordion-content');

        if (header && content) {
          header.addEventListener('click', (e) => {
            e.preventDefault();
            const isOpen = item.classList.contains('open');

            accordions.forEach(otherItem => {
              if (otherItem !== item) {
                otherItem.classList.remove('open');
                const otherContent = otherItem.querySelector('.accordion-content');
                if (otherContent) otherContent.style.maxHeight = null;
                otherItem.querySelector('.accordion-header').setAttribute('aria-expanded', 'false');
              }
            });

            if (isOpen) {
              item.classList.remove('open');
              content.style.maxHeight = null;
              header.setAttribute('aria-expanded', 'false');
            } else {
              item.classList.add('open');
              content.style.maxHeight = content.scrollHeight + 'px';
              header.setAttribute('aria-expanded', 'true');
            }
          });
        }
      });

      // 5. Form Submit (AJAX Add to Cart)
      const form = section.querySelector('.product-single__form');
      const addBtn = section.querySelector('.btn-add-to-cart');

      if (form) {
        form.addEventListener('submit', (e) => {
          e.preventDefault();
          e.stopPropagation();
          if (addBtn) addBtn.classList.add('btn-loading');

          const formData = new FormData(form);

          fetch((window.Shopify?.routes?.root || '/') + 'cart/add.js', {
            method: 'POST',
            body: formData
          })
          .then(response => {
            if (!response.ok) throw new Error('Network error');
            return response.json();
          })
          .then(data => {
            if (addBtn) addBtn.classList.remove('btn-loading');
            if (window.openCartDrawer) {
              window.openCartDrawer();
            } else if (window.showSwastikToast) {
              window.showSwastikToast('Added to Cart', 'Your item was added successfully!', true);
            }
          })
          .catch(error => {
            if (addBtn) addBtn.classList.remove('btn-loading');
            console.error('Error:', error);
            if (window.showSwastikToast) {
              window.showSwastikToast('Error', 'Could not add to cart. Please try again.', false);
            }
          });
        });
      }

      // 6. Buy It Now handler
      const buyBtn = section.querySelector('.btn-buy-now');
      if (buyBtn) {
        buyBtn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          if (!form) return;
          
          buyBtn.classList.add('btn-loading');
          
          const formData = new FormData(form);

          fetch((window.Shopify?.routes?.root || '/') + 'cart/add.js', {
            method: 'POST',
            body: formData
          })
          .then(response => {
            if (!response.ok) throw new Error('Network error');
            return response.json();
          })
          .then(() => {
            window.location.href = '/checkout';
          })
          .catch(error => {
            buyBtn.classList.remove('btn-loading');
            console.error('Error in Buy It Now:', error);
            if (window.showSwastikToast) {
              window.showSwastikToast('Error', 'Could not process Buy It Now. Please try again.', false);
            }
          });
        });
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initProductPage);
  } else {
    initProductPage();
  }

  document.addEventListener('shopify:section:load', (e) => {
    if (e.target.querySelector('.product-single')) {
      initProductPage();
    }
  });
</script>

