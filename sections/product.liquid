  .pp-btn-wishlist-big:hover { border-color: var(--pp-green); color: var(--pp-green); }

  .pp-trust {
    display: flex;
    justify-content: space-between;
    gap: 8px;
    background: var(--pp-beige);
    padding: 20px;
    border-radius: var(--pp-radius-box);
    margin-top: 8px;
  }
  .pp-trust-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 8px;
    font-size: 11px;
    color: var(--pp-text-light);
    line-height: 1.3;
    flex: 1;
