{% comment %}
  Redesigns the Product Details page with a premium, high-converting layout.
  Includes interactive image slideshow, variant selection pills, accordion information,
  and synchronized AJAX cart and wishlist handlers.
{% endcomment %}

{% assign current_variant = product.selected_or_first_available_variant %}
{% assign original_price = product.compare_at_price %}
{% assign price = product.price %}
{% assign title = product.title %}
{% assign description = product.description %}

{% comment %} Set up product images, falling back to mock assets if empty {% endcomment %}
{% assign has_images = false %}
{% if product.images.size > 0 %}
  {% assign has_images = true %}
{% endif %}

<div class="product-single" data-product-id="{{ product.id }}" data-url="{{ product.url }}">
  <div class="product-single__container">
    
    {% assign breadcrumb_collection = collection | default: product.collections.first %}
    
    <!-- Breadcrumb Navigation -->
    <nav class="product-single__breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      
      {% if breadcrumb_collection %}
        <span class="breadcrumb-separator">
          <svg width="6" height="10" viewBox="0 0 6 10" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M1 9L5 5L1 1" stroke="#A8A8A8" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
        <a href="{{ breadcrumb_collection.url }}">{{ breadcrumb_collection.title }}</a>
      {% endif %}

      <span class="breadcrumb-separator">
        <svg width="6" height="10" viewBox="0 0 6 10" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1 9L5 5L1 1" stroke="#A8A8A8" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
      <span class="breadcrumb-current">{{ title }}</span>
    </nav>

    <!-- Main Two-Column Layout -->
    <div class="product-single__layout">
      
      <!-- Left Column: Interactive Media Gallery -->
      <div class="product-single__media">
        <div class="product-single__gallery">
          
          <!-- Center Main Image View -->
          <div class="product-single__main-image-container">
            <!-- Discount Tag badge (only shown for a real markdown) -->
            {% if product.compare_at_price > product.price %}
              <div class="product-single__discount-badge">{{ product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round }}% OFF</div>
            {% endif %}

            <!-- Main Image -->
            <div class="product-single__main-image-wrapper">
              {% if has_images %}
                <img id="main-product-image" src="{{ product.featured_image | image_url: width: 800, height: 800 }}" alt="{{ title | escape }}" loading="eager" width="600" height="600">
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'product-single__placeholder-svg' }}
              {% endif %}
            </div>

            <!-- Navigation Arrows -->
            <button class="gallery-nav-btn prev-btn" aria-label="Previous Image">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
              </svg>
            </button>
            <button class="gallery-nav-btn next-btn" aria-label="Next Image">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
              </svg>
            </button>

            <!-- Bottom Left: Hallmark Badge -->
            <div class="product-single__hallmark-pill">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
              </svg>
              <span>BIS Hallmarked</span>
            </div>

            <!-- Bottom Right: Zoom Trigger -->
            <button class="product-single__zoom-btn" aria-label="Expand Image">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M20.25 3.75v4.5m0-4.5h-4.5m4.5 0L15 9m-11.25 11.25v-4.5m0 4.5h4.5m-4.5 0L9 15m11.25 5.25v-4.5m0 4.5h-4.5m4.5 0L15 15" />
              </svg>
            </button>
          </div>

          <!-- Horizontal Thumbnails Row (only when the product has real images) -->
          {% if has_images and product.images.size > 1 %}
            <div class="product-single__thumbnails">
              {% for image in product.images %}
                <button class="thumbnail-btn {% if forloop.first %}active{% endif %}" data-image-url="{{ image | image_url: width: 800, height: 800 }}" aria-label="View Image {{ forloop.index }}">
                  <img src="{{ image | image_url: width: 150, height: 150 }}" alt="{{ image.alt | escape }}" loading="lazy" width="80" height="80">
                </button>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      </div>

      <!-- Right Column: Product Details & Options Selector -->
      <div class="product-single__info">
        
        {% comment %}
          Ratings/reviews intentionally removed. To show real reviews, install a
          reviews app (e.g. Shopify Product Reviews, Judge.me, Loox) and render its
          block/snippet here, or drive stars from a `product.metafields.reviews.rating`.
        {% endcomment %}

        <!-- Title -->
        <h1 class="product-single__heading serif-font">{{ title }}</h1>

        <!-- Pricing Row -->
        <div class="product-single__price-row" id="product-price-display">
          <span class="price-current">₹{{ price | money_without_currency | remove: ".00" }}</span>
          {% if product.compare_at_price > product.price %}
            <span class="price-original">₹{{ product.compare_at_price | money_without_currency | remove: ".00" }}</span>
            <span class="price-discount">
              {{ product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round }}% OFF
            </span>
          {% endif %}
        </div>
        <p class="product-single__taxes-text">Inclusive of all taxes</p>

        <!-- Divider -->
        <hr class="product-single__divider">

        <!-- Variant Options Form -->
        {% form 'product', product, class: 'product-single__form' %}
          <input type="hidden" name="id" id="product-variant-id" value="{{ current_variant.id }}">
          
          <script type="application/json" id="ProductJson-{{ section.id }}">
            {{ product.variants | json }}
          </script>

          <div id="product-option-selectors">
            {%- unless product.has_only_default_variant -%}
              {%- for option in product.options_with_values -%}
                <div class="product-single__option-group" data-option-index="{{ forloop.index0 }}">
                  <span class="option-label">{{ option.name | upcase }}</span>
                  <div class="option-pills">
                    {%- for value in option.values -%}
                      <button type="button" class="option-pill-btn {% if option.selected_value == value %}active{% endif %}" data-value="{{ value | escape }}">
                        {{ value | escape }}
                      </button>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endfor -%}
            {%- endunless -%}
          </div>

          <!-- QUANTITY Selector -->
          <div class="product-single__option-group">
            <span class="option-label">QUANTITY</span>
            <div class="product-single__qty-row">
              <div class="qty-selector">
                <button type="button" class="qty-btn decrement" aria-label="Decrease Quantity">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/></svg>
                </button>
                <input type="number" name="quantity" min="1" value="1" readonly>
                <button type="button" class="qty-btn increment" aria-label="Increase Quantity">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
                </button>
              </div>
              <div class="stock-status">
                {% if product.available %}
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  <span>IN STOCK</span>
                {% else %}
                  <span style="color:#B00020;">OUT OF STOCK</span>
                {% endif %}
              </div>
            </div>
          </div>

          <!-- Call To Action Button Group -->
          <div class="product-single__buttons-group">
            <button type="submit" class="btn-add-to-cart btn-add-cart" {% unless product.available %}disabled{% endunless %}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
              </svg>
              {% if product.available %}ADD TO CART{% else %}SOLD OUT{% endif %}
            </button>
            <button type="button" class="btn-buy-now" {% unless product.available %}disabled{% endunless %}>
              BUY IT NOW
            </button>
            <button type="button" class="product-single__wishlist-btn" aria-label="Add to Wishlist">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </button>
          </div>
        {% endform %}

        <!-- Quick trust badges below CTAs -->
        <div class="product-single__trust-icons">
          <div class="trust-icon-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
            </svg>
            <span>BIS Hallmarked</span>
          </div>
          <div class="trust-icon-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
            </svg>
            <span>Secure Payment</span>
          </div>
          <div class="trust-icon-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 0 0-3.7-3.7 48.656 48.656 0 0 0-7.324 0 4.006 4.006 0 0 0-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3-3-3M3-1.5" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h-.008v.008h.008v-.008Zm-.375 2.25h-.008v.008h.008v-.008Zm-.375 2.25h-.008v.008h.008v-.008Zm-.375 2.25h-.008v.008h.008v-.008Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 15h.008v.008H9V15Zm0 2.25h.008v.008H9v-.008Zm0 2.25h.008v.008H9v-.008Zm6.75-4.5h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008v-.008Zm-3.375-4.5h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008v-.008Zm-3.375-4.5h.008v.008H9v-.008Zm0 2.25h.008v.008H9v-.008Zm0 2.25h.008v.008H9v-.008Z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12a7.5 7.5 0 1 1-15 0c0-1.638.526-3.152 1.423-4.382l2.42-2.42" />
            </svg>
            <span>Easy Returns</span>
          </div>
          <div class="trust-icon-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125a1.125 1.125 0 0 0 1.125-1.125V9.75m-4.875 9h-6.75m9.75-4.5V9h-3v4.5m0-4.5V6.75A2.25 2.25 0 0 0 14.25 4.5h-4.5A2.25 2.25 0 0 0 7.5 6.75V9" />
            </svg>
            <span>Free Shipping</span>
          </div>
        </div>

        <!-- Accordion Info Panels -->
        <div class="product-single__accordion">
          
          <!-- Accordion 1 -->
          <div class="accordion-item">
            <button type="button" class="accordion-header" aria-expanded="false">
              <span>Product Details & Specifications</span>
              <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="accordion-content">
              <div class="accordion-inner">
                <p>{{ description }}</p>
                {%- assign m = product.metafields.custom -%}
                {%- if m.gold_purity != blank or m.gold_weight != blank or m.diamond_clarity != blank or m.hallmarking_center != blank -%}
                  <table class="specs-table">
                    {% if m.gold_purity != blank %}<tr><td>Gold Purity</td><td>{{ m.gold_purity }}</td></tr>{% endif %}
                    {% if m.gold_weight != blank %}<tr><td>Approx Gold Weight</td><td>{{ m.gold_weight }}</td></tr>{% endif %}
                    {% if m.diamond_clarity != blank %}<tr><td>Diamond Color &amp; Clarity</td><td>{{ m.diamond_clarity }}</td></tr>{% endif %}
                    {% if m.hallmarking_center != blank %}<tr><td>Hallmarking Center</td><td>{{ m.hallmarking_center }}</td></tr>{% endif %}
                  </table>
                {%- endif -%}
              </div>
            </div>
          </div>

          <!-- Accordion 2 -->
          <div class="accordion-item">
            <button type="button" class="accordion-header" aria-expanded="false">
              <span>Shipping & Delivery</span>
              <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="accordion-content">
              <div class="accordion-inner">
                <p>We provide free insured shipping on all orders throughout India. Typical delivery timeframes are:</p>
                <ul>
                  <li>Metro Cities: 3 - 5 business days</li>
                  <li>Rest of India: 5 - 7 business days</li>
                  <li>Custom/Personalized pieces: 10 - 14 business days</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Accordion 3 -->
          <div class="accordion-item">
            <button type="button" class="accordion-header" aria-expanded="false">
              <span>Care Instructions</span>
              <svg class="chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="accordion-content">
              <div class="accordion-inner">
                <p>Keep your gold jewelry sparkling by following these simple care tips:</p>
                <ul>
                  <li>Store separately in our provided velvet box to avoid scratches.</li>
                  <li>Clean gently with a soft microfiber cloth after wear.</li>
                  <li>Avoid direct exposure to perfumes, sanitizers, and harsh household chemicals.</li>
                </ul>
              </div>
            </div>
          </div>

        </div>

      </div>

    </div>

    <!-- Full-Width Bottom Trust Banner -->
    <div class="product-single__trust-banner">
      <div class="trust-banner-grid">
        
        <div class="trust-card">
          <div class="trust-card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
            </svg>
          </div>
          <div class="trust-card-info">
            <h4>100% BIS Hallmarked</h4>
            <p>Certified Authentic Jewellery</p>
          </div>
        </div>

        <div class="trust-card">
          <div class="trust-card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
            </svg>
          </div>
          <div class="trust-card-info">
            <h4>Secure & Safe Payments</h4>
            <p>Multiple payment options</p>
          </div>
        </div>

        <div class="trust-card">
          <div class="trust-card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12c0-1.232-.046-2.453-.138-3.662a4.006 4.006 0 0 0-3.7-3.7 48.656 48.656 0 0 0-7.324 0 4.006 4.006 0 0 0-3.7 3.7c-.017.22-.032.441-.046.662M19.5 12l3-3m-3 3-3-3M3-1.5" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12a7.5 7.5 0 1 1-15 0c0-1.638.526-3.152 1.423-4.382l2.42-2.42" />
            </svg>
          </div>
          <div class="trust-card-info">
            <h4>Easy 7-Day Returns</h4>
            <p>No questions asked</p>
          </div>
        </div>

        <div class="trust-card">
          <div class="trust-card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125a1.125 1.125 0 0 0 1.125-1.125V9.75m-4.875 9h-6.75m9.75-4.5V9h-3v4.5m0-4.5V6.75A2.25 2.25 0 0 0 14.25 4.5h-4.5A2.25 2.25 0 0 0 7.5 6.75V9" />
            </svg>
          </div>
          <div class="trust-card-info">
            <h4>Free Insured Shipping</h4>
            <p>Pan India Delivery</p>
          </div>
        </div>

      </div>
    </div>

  </div>
</div>

{% stylesheet %}
  .product-single {
    background-color: var(--color-background, #FFFFFF);
    padding-top: 3rem;
    padding-bottom: 8rem;
  }

  .product-single__container {
    max-width: 1300px;
    margin: 0 auto;
    padding-left: 2.4rem;
    padding-right: 2.4rem;
  }

  /* Breadcrumb Navigation Styles */
  .product-single__breadcrumb {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    margin-bottom: 4rem;
    font-family: 'Montserrat', sans-serif;
    font-size: 1.3rem;
  }
  .product-single__breadcrumb a {
    color: #888888;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .product-single__breadcrumb a:hover {
    color: var(--color-primary, #013F3E);
  }
  .breadcrumb-separator {
    display: flex;
    align-items: center;
  }
  .breadcrumb-current {
    color: var(--color-primary, #013F3E);
    font-weight: 500;
  }

  /* Main Info Columns Layout */
  .product-single__layout {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 6.4rem;
    margin-bottom: 6rem;
  }

  /* Left Column Gallery layout */
  .product-single__gallery {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }

  /* Thumbnails Column styles */
  .product-single__thumbnails {
    display: flex;
    flex-direction: row;
    gap: 1.6rem;
    flex-shrink: 0;
    overflow-x: auto;
    padding-bottom: 0.8rem; /* Space for scrollbar if needed */
  }
  .thumbnail-btn {
    border: 1px solid rgba(1, 63, 62, 0.08);
    background-color: var(--color-secondary-bg, #FDFBF7);
    border-radius: 6px;
    padding: 0.4rem;
    width: 8.8rem;
    height: 8.8rem;
    cursor: pointer;
