    display: flex;
    flex-direction: column;
  }
  .pp-delivery-text .label {
    font-size: 13px;
    color: var(--pp-text-light);
  }
  .pp-delivery-text .value {
    font-size: 15px;
    font-weight: 600;
    color: var(--pp-text);
  }
  .pp-delivery-link {
    margin-left: auto;
    font-size: 13px;
    font-weight: 600;
    color: var(--pp-green);
    text-decoration: underline;
  }

  @media(max-width: 600px) {
    .pp-actions {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 12px;
    }
    .pp-qty { grid-column: 1 / -1; justify-content: space-between; }
    .pp-btn-add, .pp-btn-buy { width: 100%; justify-content: center; }
    .pp-btn-wishlist-big { display: none; }
    .pp-trust { flex-wrap: wrap; }
    .pp-trust-item { min-width: 30%; margin-bottom: 12px; }
  }

  /* Full Width Accordions */
  .pp-full-accordions {
    max-width: 1200px;
    margin: 60px auto 0 auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .pp-full-accordion-item {
    background: #F5F5F5;
  }
  .pp-full-accordion-header {
    width: 100%;
    text-align: left;
    background: none;
    border: none;
    padding: 20px 24px;
    font-size: 16px;
    font-weight: 600;
    color: var(--pp-text);
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
  }
  .pp-full-accordion-content {
    padding: 0 24px 24px 24px;
    font-size: 14px;
    color: var(--pp-text-light);
    line-height: 1.6;
    display: none;
  }
  .pp-full-accordion-item.is-open .pp-full-accordion-content {
    display: block;
  }
  .pp-full-accordion-item .icon-minus { display: none; }
  .pp-full-accordion-item.is-open .icon-minus { display: block; }
  .pp-full-accordion-item.is-open .icon-plus { display: none; }
{% endstylesheet %}

<script>
document.addEventListener('DOMContentLoaded', () => {
  // Gallery
  const thumbs = document.querySelectorAll('.pp-thumb-item');
  const mainImg = document.getElementById('pp-main-image');
  const prevBtn = document.querySelector('.pp-nav-prev');
  const nextBtn = document.querySelector('.pp-nav-next');
  let activeIndex = 0;

  function setMainImage(index) {
    if(!thumbs.length) return;
    activeIndex = (index + thumbs.length) % thumbs.length;
    thumbs.forEach(t => t.classList.remove('is-active'));
    thumbs[activeIndex].classList.add('is-active');
    
    if(mainImg) {
      mainImg.style.opacity = 0;
      setTimeout(() => {
        mainImg.src = thumbs[activeIndex].getAttribute('data-image');
        mainImg.style.opacity = 1;
      }, 150);
    }
  }

  thumbs.forEach((t, i) => {
    t.addEventListener('click', () => setMainImage(i));
  });

  if(prevBtn) prevBtn.addEventListener('click', () => setMainImage(activeIndex - 1));
  if(nextBtn) nextBtn.addEventListener('click', () => setMainImage(activeIndex + 1));
  if(mainImg) mainImg.style.transition = 'opacity 0.2s ease-in-out';

  // Accordions
  const accHeaders = document.querySelectorAll('.pp-full-accordion-header');
  accHeaders.forEach(h => {
    h.addEventListener('click', () => {
      const item = h.parentElement;
      const isOpen = item.classList.contains('is-open');
      
      document.querySelectorAll('.pp-full-accordion-item').forEach(i => i.classList.remove('is-open'));
      
      if (!isOpen) {
        item.classList.add('is-open');
      }
    });
  });

  // Variant Picking
  const variantsJsonEl = document.getElementById('pp-variants-json');
  let variants = [];
  try {
    if(variantsJsonEl) variants = JSON.parse(variantsJsonEl.textContent);
  } catch(e){}

  const formatMoney = (cents) => '₹' + (cents/100).toLocaleString('en-IN', {minimumFractionDigits: 0, maximumFractionDigits: 0});

  const optGroups = document.querySelectorAll('.pp-option-group');
  optGroups.forEach(group => {
    const btns = group.querySelectorAll('.pp-opt-btn');
    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        btns.forEach(b => b.classList.remove('is-active'));
        btn.classList.add('is-active');
        
        // Find matching variant
        const selectedOptions = Array.from(optGroups).map(g => {
          const activeBtn = g.querySelector('.is-active');
          return activeBtn ? activeBtn.getAttribute('data-value') : null;
        });

        const currentVariant = variants.find(v => {
          return v.options && v.options.every((opt, i) => opt === selectedOptions[i]);
        });

        if(currentVariant) {
          const idInput = document.getElementById('pp-variant-id');
          if(idInput) idInput.value = currentVariant.id;

          const priceEl = document.getElementById('pp-price');
          if(priceEl) priceEl.textContent = formatMoney(currentVariant.price);

          const compPriceEl = document.getElementById('pp-compare-price');
          const discountEl = document.querySelector('.pp-price-discount');
          if(compPriceEl) {
             if(currentVariant.compare_at_price > currentVariant.price) {
               compPriceEl.textContent = formatMoney(currentVariant.compare_at_price);
               compPriceEl.style.display = 'inline';
               if(discountEl) {
                 const diff = currentVariant.compare_at_price - currentVariant.price;
                 const pct = Math.round((diff / currentVariant.compare_at_price) * 100);
                 discountEl.textContent = pct + '% OFF';
                 discountEl.style.display = 'inline';
               }
             } else {
               compPriceEl.style.display = 'none';
               if(discountEl) discountEl.style.display = 'none';
             }
          }
          
          if(history.replaceState) {
            const url = window.location.protocol + '//' + window.location.host + window.location.pathname + '?variant=' + currentVariant.id;
            window.history.replaceState({path: url}, '', url);
          }
        }
      });
    });
  });

  // Qty
  const qtyInput = document.querySelector('.pp-qty-val');
  const qtyDec = document.querySelector('.pp-qty-btn.dec');
  const qtyInc = document.querySelector('.pp-qty-btn.inc');

  if(qtyDec && qtyInc && qtyInput) {
    qtyDec.addEventListener('click', () => {
      let val = parseInt(qtyInput.value) || 1;
      if(val > 1) qtyInput.value = val - 1;
    });
    qtyInc.addEventListener('click', () => {
      let val = parseInt(qtyInput.value) || 1;
      qtyInput.value = val + 1;
    });
  }

  // Add to Cart
  const form = document.getElementById('pp-product-form');
  const btnAdd = document.querySelector('.pp-btn-add');
  if(form && btnAdd) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const origHtml = btnAdd.innerHTML;
      btnAdd.innerHTML = 'Adding...';
      fetch((window.Shopify?.routes?.root || '/') + 'cart/add.js', {
        method: 'POST',
        body: new FormData(form)
      })
      .then(() => {
        btnAdd.innerHTML = 'Added!';
        if(window.openCartDrawer) window.openCartDrawer();
        setTimeout(() => btnAdd.innerHTML = origHtml, 2000);
      })
      .catch(() => {
        btnAdd.innerHTML = 'Error';
        setTimeout(() => btnAdd.innerHTML = origHtml, 2000);
      });
    });
  }

  // Buy Now
  const btnBuy = document.getElementById('pp-buy-now');
  if(form && btnBuy) {
    btnBuy.addEventListener('click', (e) => {
      e.preventDefault();
      btnBuy.textContent = 'Processing...';
      fetch((window.Shopify?.routes?.root || '/') + 'cart/add.js', {
        method: 'POST',
        body: new FormData(form)
      })
      .then(() => {
        window.location.href = '/checkout';
      })
      .catch(() => {
        btnBuy.textContent = 'Error';
        setTimeout(() => btnBuy.textContent = 'Buy Now', 2000);
      });
    });
  }
});
</script>

