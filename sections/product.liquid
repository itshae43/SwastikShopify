{% assign current_variant = product.selected_or_first_available_variant %}
{% assign price = current_variant.price %}
{% assign compare_at_price = current_variant.compare_at_price %}
{% assign title = product.title %}
{% assign description = product.description %}
{% assign has_images = false %}
{% if product.images.size > 0 %}
  {% assign has_images = true %}
{% endif %}

<div class="product-page" data-product-id="{{ product.id }}" data-url="{{ product.url }}">
  <div class="product-page__container">
    
    <div class="product-page__layout">
      <!-- Left Column: Gallery -->
      <div class="product-page__gallery">
        <div class="product-page__main-image">
          <button class="gallery-nav prev-btn" aria-label="Previous image">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 19l-7-7 7-7"/></svg>
          </button>
          
          <div class="main-image-wrapper">
             {% if has_images %}
               <img id="main-product-image" src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ title | escape }}" width="{{ product.featured_image.width }}" height="{{ product.featured_image.height }}">
             {% else %}
               {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
             {% endif %}
          </div>
          
          <button class="gallery-nav next-btn" aria-label="Next image">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>

        {% if has_images and product.images.size > 1 %}
        <div class="product-page__thumbnails">
          {% for image in product.images %}
            <button class="thumbnail-btn {% if forloop.first %}active{% endif %}" data-image-url="{{ image | image_url: width: 800 }}" aria-label="View image {{ forloop.index }}">
              <img src="{{ image | image_url: width: 150 }}" alt="{{ image.alt | escape }}" width="{{ image.width }}" height="{{ image.height }}">
            </button>
          {% endfor %}
        </div>
        {% endif %}
      </div>

      <!-- Right Column: Info -->
      <div class="product-page__info">
        {% assign breadcrumb_collection = collection | default: product.collections.first %}
        {% if breadcrumb_collection %}
          <div class="product-page__category">{{ breadcrumb_collection.title }}</div>
        {% else %}
          <div class="product-page__category">{{ product.type | default: 'Product' }}</div>
        {% endif %}

        <div class="product-page__title-row">
          <h1 class="product-page__title">{{ title }}</h1>
          {% if current_variant.available %}
            <span class="stock-badge">In Stock</span>
          {% else %}
            <span class="stock-badge out-of-stock">Out of Stock</span>
          {% endif %}
        </div>

        <div class="product-page__reviews">
          <div class="stars">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="#F5C518"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="#F5C518"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="#F5C518"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="#F5C518"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="#F5C518"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
          </div>
          <span class="reviews-text">4.9 (245 Review)</span>
        </div>

        <div class="product-page__pricing" id="product-price-display">
          <span class="price-current">{{ price | money }}</span>
          {% if compare_at_price > price %}
            <span class="price-original">{{ compare_at_price | money }}</span>
          {% endif %}
        </div>

        <div class="product-page__description">
          {% if description != blank %}
            {{ description | strip_html | truncatewords: 25 }}
          {% else %}
            Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna.
          {% endif %}
        </div>

        {% form 'product', product, class: 'product-page__form' %}
          <input type="hidden" name="id" id="product-variant-id" value="{{ current_variant.id }}">
          <script type="application/json" id="ProductJson-{{ section.id }}">
            {{ product.variants | json }}
          </script>

          <div id="product-option-selectors">
            {%- unless product.has_only_default_variant -%}
              {%- for option in product.options_with_values -%}
                <div class="product-page__option-group" data-option-index="{{ forloop.index0 }}">
                  <span class="option-name">{{ option.name }} : <span class="selected-value">{{ option.selected_value }}</span></span>
                  <div class="option-values">
                    {%- for value in option.values -%}
                      {%- assign option_name_down = option.name | downcase -%}
                      {%- if option_name_down == 'color' or option_name_down == 'colour' -%}
                        <button type="button" class="color-swatch {% if option.selected_value == value %}active{% endif %}" data-value="{{ value | escape }}" style="background-color: {{ value | downcase | replace: ' ', '' }}" aria-label="{{ value }}"></button>
                      {%- else -%}
                        <button type="button" class="text-swatch {% if option.selected_value == value %}active{% endif %}" data-value="{{ value | escape }}">{{ value }}</button>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                </div>
              {%- endfor -%}
            {%- endunless -%}
          </div>

          <div class="product-page__actions-row">
            <div class="qty-box">
              <button type="button" class="qty-btn dec" aria-label="Decrease quantity">-</button>
              <input type="number" name="quantity" class="qty-input" value="1" min="1" readonly>
              <button type="button" class="qty-btn inc" aria-label="Increase quantity">+</button>
            </div>
            
            <button type="submit" class="btn-add-cart" {% unless current_variant.available %}disabled{% endunless %}>
              {% if current_variant.available %}Add To Cart{% else %}Sold Out{% endif %}
            </button>
            
            <button type="button" class="btn-buy-now" {% unless current_variant.available %}disabled{% endunless %}>
              Buy Now
            </button>

            <button type="button" class="btn-wishlist" aria-label="Wishlist">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
            </button>
          </div>
        {% endform %}

        <div class="product-page__meta">
          <div class="meta-item">
            <span class="meta-label">SKU :</span>
            <span class="meta-val" id="product-sku">{{ current_variant.sku | default: 'FTNC8768-1AEC' }}</span>
          </div>
          <div class="meta-item">
            <span class="meta-label">Tags :</span>
            <span class="meta-val">
              {% if product.tags.size > 0 %}
                {{ product.tags | join: ', ' }}
              {% else %}
                Furniture, Office, Gaming Chair, Chair
              {% endif %}
            </span>
          </div>
          <div class="meta-item share-row">
            <span class="meta-label">Share :</span>
            <div class="share-icons">
              <a href="https://www.facebook.com/sharer.php?u={{ shop.url | append: product.url }}" target="_blank" class="share-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg></a>
              <a href="https://twitter.com/share?url={{ shop.url | append: product.url }}" target="_blank" class="share-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"/></svg></a>
              <a href="https://pinterest.com/pin/create/button/?url={{ shop.url | append: product.url }}" target="_blank" class="share-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.72-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738.098.119.112.224.083.345l-.279 1.14c-.038.154-.127.189-.286.115-1.068-.498-1.736-2.056-1.736-3.313 0-2.695 1.96-5.174 5.656-5.174 3.013 0 5.353 2.146 5.353 5.014 0 2.996-1.888 5.411-4.512 5.411-.88 0-1.708-.458-1.992-.998l-.544 2.072c-.197.751-.73 1.688-1.088 2.261C9.645 23.834 10.8 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg></a>
              <a href="#" class="share-icon"><svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="16"></line><line x1="8" y1="12" x2="16" y2="12"></line></svg></a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .product-page {
    background-color: #FFFFFF;
    padding: 6rem 2.4rem;
    font-family: 'Inter', 'Montserrat', sans-serif;
  }
  .product-page__container {
    max-width: 1200px;
    margin: 0 auto;
  }
  .product-page__layout {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 6rem;
    align-items: start;
  }
  
  /* Left Column */
  .product-page__gallery {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .product-page__main-image {
    position: relative;
    background-color: #F8F8F8;
    border-radius: 12px;
    display: flex;
    justify-content: center;
    align-items: center;
    aspect-ratio: 1/1;
    overflow: hidden;
  }
  .main-image-wrapper {
    width: 80%;
    height: 80%;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .main-image-wrapper img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }
  .gallery-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: #013F3E;
    color: white;
    border: none;
    width: 4rem;
    height: 4rem;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
    transition: background 0.2s;
  }
  .gallery-nav:hover {
    background: #012b2a;
  }
  .prev-btn { left: 1.5rem; }
  .next-btn { right: 1.5rem; }
  
  .product-page__thumbnails {
    display: flex;
    gap: 1.6rem;
    overflow-x: auto;
    padding-bottom: 0.5rem;
  }
  .product-page__thumbnails::-webkit-scrollbar {
    height: 6px;
  }
  .product-page__thumbnails::-webkit-scrollbar-thumb {
    background: #E0E0E0;
    border-radius: 4px;
  }
  .thumbnail-btn {
    border: 2px solid transparent;
    background: #F8F8F8;
    border-radius: 8px;
    padding: 0.8rem;
    width: 9rem;
    height: 9rem;
    flex-shrink: 0;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .thumbnail-btn.active {
    border-color: #013F3E;
  }
  .thumbnail-btn img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* Right Column */
  .product-page__info {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }
  .product-page__category {
    color: #888;
    font-size: 1.4rem;
    text-transform: capitalize;
  }
  .product-page__title-row {
    display: flex;
    align-items: center;
    gap: 1.6rem;
    flex-wrap: wrap;
  }
  .product-page__title {
    font-size: 3rem;
    font-weight: 600;
    color: #333;
    margin: 0;
    line-height: 1.2;
  }
  .stock-badge {
    background: #E8F5E9;
    color: #2E7D32;
    border: 1px solid #C8E6C9;
    padding: 0.4rem 1.2rem;
    border-radius: 50px;
    font-size: 1.2rem;
    font-weight: 500;
    white-space: nowrap;
  }
  .stock-badge.out-of-stock {
    background: #FFEBEE;
    color: #C62828;
    border-color: #FFCDD2;
  }
  
  .product-page__reviews {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .stars {
    display: flex;
    gap: 0.2rem;
  }
  .reviews-text {
    color: #666;
    font-size: 1.3rem;
  }

  .product-page__pricing {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    margin-top: 0.8rem;
  }
  .price-current {
    font-size: 2.4rem;
    font-weight: 700;
    color: #333;
  }
  .price-original {
    font-size: 1.8rem;
    color: #999;
    text-decoration: line-through;
  }

  .product-page__description {
    color: #666;
    font-size: 1.4rem;
    line-height: 1.6;
    margin-top: 0.8rem;
  }

  /* Variants */
  .product-page__form {
    margin-top: 1.6rem;
  }
  .product-page__option-group {
    margin-bottom: 2.4rem;
  }
  .option-name {
    display: block;
    font-size: 1.4rem;
    font-weight: 600;
    margin-bottom: 1.2rem;
    color: #333;
  }
  .selected-value {
    font-weight: 400;
    color: #666;
  }
  .option-values {
    display: flex;
    gap: 1.2rem;
    flex-wrap: wrap;
  }
  .color-swatch {
    width: 3.2rem;
    height: 3.2rem;
    border-radius: 50%;
    border: 3px solid white;
    box-shadow: 0 0 0 1px #DDD;
    cursor: pointer;
    transition: box-shadow 0.2s;
  }
  .color-swatch.active {
    box-shadow: 0 0 0 2px #013F3E;
  }
  .text-swatch {
    padding: 0.8rem 1.6rem;
    border: 1px solid #DDD;
    border-radius: 4px;
    background: #FFF;
    font-size: 1.4rem;
    cursor: pointer;
    transition: all 0.2s;
  }
  .text-swatch:hover {
    border-color: #013F3E;
  }
  .text-swatch.active {
    border-color: #013F3E;
    background: #013F3E;
    color: #FFF;
  }

  /* Actions */
  .product-page__actions-row {
    display: flex;
    align-items: center;
    gap: 1.6rem;
    margin-top: 1rem;
    flex-wrap: wrap;
  }
  .qty-box {
    display: flex;
    align-items: center;
    border: 1px solid #E0E0E0;
    border-radius: 24px;
    height: 4.8rem;
    background: #FFF;
  }
  .qty-btn {
    background: none;
    border: none;
    width: 4rem;
    height: 100%;
    font-size: 1.8rem;
    cursor: pointer;
    color: #666;
  }
  .qty-btn:hover {
    color: #333;
  }
  .qty-input {
    width: 3.2rem;
    border: none;
    text-align: center;
    font-size: 1.4rem;
    font-weight: 600;
    -moz-appearance: textfield;
  }
  .qty-input::-webkit-outer-spin-button,
  .qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .btn-add-cart {
    background: #013F3E;
    color: white;
    border: none;
    height: 4.8rem;
    padding: 0 3.2rem;
    border-radius: 24px;
    font-size: 1.4rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s;
  }
  .btn-add-cart:hover {
    background: #012b2a;
  }
  .btn-buy-now {
    background: #F4B840; /* Yellow matching mockup */
    color: #333;
    border: none;
    height: 4.8rem;
    padding: 0 3.2rem;
    border-radius: 24px;
    font-size: 1.4rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s;
  }
  .btn-buy-now:hover {
    background: #dfa32b;
  }
  .btn-wishlist {
    background: #FFF;
    border: 1px solid #E0E0E0;
    width: 4.8rem;
    height: 4.8rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #666;
    transition: all 0.2s;
  }
  .btn-wishlist:hover, .btn-wishlist.active {
    border-color: #013F3E;
    color: #013F3E;
  }
  .btn-wishlist.active svg {
    fill: #013F3E;
  }

  /* Meta info (SKU, Tags, Share) */
  .product-page__meta {
    margin-top: 3.2rem;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    border-top: 1px solid #EEE;
    padding-top: 2.4rem;
  }
  .meta-item {
    font-size: 1.4rem;
    color: #666;
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .meta-label {
    font-weight: 600;
    color: #333;
    min-width: 60px;
  }
  .share-icons {
    display: flex;
    gap: 1.2rem;
  }
  .share-icon {
    background: #E8F5E9;
    color: #013F3E;
    width: 2.8rem;
    height: 2.8rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: background 0.2s;
  }
  .share-icon:hover {
    background: #C8E6C9;
  }

  /* Mobile */
  @media screen and (max-width: 990px) {
    .product-page__layout {
      grid-template-columns: 1fr;
      gap: 4.8rem;
    }
  }

  @media screen and (max-width: 600px) {
    .product-page {
      padding: 2.4rem 1.6rem;
    }
    .product-page__title {
      font-size: 2.4rem;
    }
    .product-page__gallery {
      gap: 1.2rem;
    }
    .product-page__thumbnails {
      justify-content: center;
    }
    .thumbnail-btn {
      width: 7rem;
      height: 7rem;
    }
    .product-page__actions-row {
      display: grid;
      grid-template-columns: 1fr 1fr auto;
      gap: 1.2rem;
    }
    .qty-box {
      grid-column: 1 / span 3;
      width: 100%;
      justify-content: space-between;
    }
    .btn-add-cart, .btn-buy-now {
      width: 100%;
      padding: 0;
    }
    .btn-wishlist {
      grid-column: 3;
      grid-row: 2;
    }
    .btn-add-cart {
      grid-column: 1 / span 2;
      grid-row: 2;
    }
    .btn-buy-now {
      grid-column: 1 / span 3;
      grid-row: 3;
    }
  }
{% endstylesheet %}

<script>
document.addEventListener('DOMContentLoaded', () => {
  const productPage = document.querySelector('.product-page');
  if (!productPage) return;

  // Gallery
  const mainImg = productPage.querySelector('#main-product-image');
  const thumbs = productPage.querySelectorAll('.thumbnail-btn');
  const prevBtn = productPage.querySelector('.prev-btn');
  const nextBtn = productPage.querySelector('.next-btn');
  let activeIndex = 0;

  function updateImage(idx) {
    if (!thumbs.length) return;
    activeIndex = (idx + thumbs.length) % thumbs.length;
    thumbs.forEach(t => t.classList.remove('active'));
    thumbs[activeIndex].classList.add('active');
    
    if (mainImg) {
      mainImg.style.opacity = 0;
      setTimeout(() => {
        mainImg.src = thumbs[activeIndex].getAttribute('data-image-url');
        mainImg.style.opacity = 1;
      }, 150);
    }
  }

  thumbs.forEach((btn, idx) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      updateImage(idx);
    });
  });
  
  if (prevBtn) {
    prevBtn.addEventListener('click', (e) => {
      e.preventDefault();
      updateImage(activeIndex - 1);
    });
  }
  
  if (nextBtn) {
    nextBtn.addEventListener('click', (e) => {
      e.preventDefault();
      updateImage(activeIndex + 1);
    });
  }
  
  if (mainImg) {
    mainImg.style.transition = 'opacity 0.15s ease-in-out';
  }

  // Variants
  const variantJson = document.querySelector('#ProductJson-' + {{ section.id | json }});
  let variants = [];
  try {
    if (variantJson) variants = JSON.parse(variantJson.innerHTML || variantJson.textContent);
  } catch (e) {
    console.error('Error parsing product variants');
  }

  const optionGroups = productPage.querySelectorAll('.product-page__option-group');
  
  function formatMoney(cents) {
    if (window.formatMoney) {
      return window.formatMoney(cents);
    }
    return '₹' + (cents / 100).toLocaleString('en-IN', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }

  function handleVariantChange() {
    if (!variants.length) return;
    
    const selectedOptions = Array.from(optionGroups).map(g => {
      const activeBtn = g.querySelector('.active');
      return activeBtn ? activeBtn.getAttribute('data-value') : null;
    });

    const currentVariant = variants.find(v => {
      if (!v.options) return false;
      return v.options.every((opt, i) => opt === selectedOptions[i]);
    });
    
    if (currentVariant) {
      const idInput = productPage.querySelector('#product-variant-id');
      if (idInput) idInput.value = currentVariant.id;

      if (history.replaceState) {
        const url = window.location.protocol + '//' + window.location.host + window.location.pathname + '?variant=' + currentVariant.id;
        window.history.replaceState({ path: url }, '', url);
      }

      const priceCur = productPage.querySelector('.price-current');
      const priceOrig = productPage.querySelector('.price-original');
      if (priceCur) priceCur.textContent = formatMoney(currentVariant.price);
      
      if (priceOrig) {
        if (currentVariant.compare_at_price > currentVariant.price) {
          priceOrig.textContent = formatMoney(currentVariant.compare_at_price);
          priceOrig.style.display = 'inline';
        } else {
          priceOrig.style.display = 'none';
        }
      }

      const skuEl = productPage.querySelector('#product-sku');
      if (skuEl) skuEl.textContent = currentVariant.sku || 'N/A';
      
      const btnAdd = productPage.querySelector('.btn-add-cart');
      const btnBuy = productPage.querySelector('.btn-buy-now');
      const stockBadge = productPage.querySelector('.stock-badge');
      
      if (currentVariant.available) {
        if (btnAdd) {
          btnAdd.disabled = false;
          btnAdd.textContent = 'Add To Cart';
        }
        if (btnBuy) btnBuy.disabled = false;
        if (stockBadge) {
          stockBadge.textContent = 'In Stock';
          stockBadge.classList.remove('out-of-stock');
        }
      } else {
        if (btnAdd) {
          btnAdd.disabled = true;
          btnAdd.textContent = 'Sold Out';
        }
        if (btnBuy) btnBuy.disabled = true;
        if (stockBadge) {
          stockBadge.textContent = 'Out of Stock';
          stockBadge.classList.add('out-of-stock');
        }
      }
    }
  }

  optionGroups.forEach(group => {
    const btns = group.querySelectorAll('button');
    const selectedText = group.querySelector('.selected-value');
    btns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        btns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        if (selectedText) selectedText.textContent = btn.getAttribute('data-value');
        handleVariantChange();
      });
    });
  });

  // Quantity
  const qtyInput = productPage.querySelector('.qty-input');
  const btnDec = productPage.querySelector('.qty-btn.dec');
  const btnInc = productPage.querySelector('.qty-btn.inc');
  
  if (qtyInput && btnDec && btnInc) {
    btnDec.addEventListener('click', (e) => {
      e.preventDefault();
      let val = parseInt(qtyInput.value) || 1;
      if (val > 1) qtyInput.value = val - 1;
    });
    btnInc.addEventListener('click', (e) => {
      e.preventDefault();
      let val = parseInt(qtyInput.value) || 1;
      qtyInput.value = val + 1;
    });
  }

  // Add to Cart
  const form = productPage.querySelector('.product-page__form');
  const btnAdd = productPage.querySelector('.btn-add-cart');
  if (form && btnAdd) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const originalText = btnAdd.textContent;
      btnAdd.textContent = 'Adding...';
      const formData = new FormData(form);
      
      fetch((window.Shopify?.routes?.root || '/') + 'cart/add.js', {
        method: 'POST',
        body: formData
      })
      .then(res => res.json())
      .then(data => {
        btnAdd.textContent = 'Added';
        if (window.openCartDrawer) window.openCartDrawer();
        setTimeout(() => { btnAdd.textContent = originalText; }, 2000);
      })
      .catch(err => {
        console.error(err);
        btnAdd.textContent = 'Error';
        setTimeout(() => { btnAdd.textContent = originalText; }, 2000);
      });
    });
  }

  // Buy Now
  const btnBuy = productPage.querySelector('.btn-buy-now');
  if (btnBuy && form) {
    btnBuy.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const originalText = btnBuy.textContent;
      btnBuy.textContent = 'Processing...';
      const formData = new FormData(form);
      
      fetch((window.Shopify?.routes?.root || '/') + 'cart/add.js', {
        method: 'POST',
        body: formData
      })
      .then(() => {
        window.location.href = '/checkout';
      })
      .catch(err => {
        console.error('Error in Buy It Now:', err);
        btnBuy.textContent = 'Error';
        setTimeout(() => { btnBuy.textContent = originalText; }, 2000);
      });
    });
  }
  
  // Wishlist toggle
  const wishlistBtn = productPage.querySelector('.btn-wishlist');
  if (wishlistBtn) {
    wishlistBtn.addEventListener('click', (e) => {
      e.preventDefault();
      wishlistBtn.classList.toggle('active');
    });
  }
});
</script>

