  .pp-btn-add:hover { background: #f0f7f6; }
  .pp-btn-buy {
    height: 48px;
    padding: 0 16px;
    background: var(--pp-gold);
    color: var(--pp-text);
    border: none;
    border-radius: var(--pp-radius-btn);
    font-size: 14px;
    font-weight: 600;
