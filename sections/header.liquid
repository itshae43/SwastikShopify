      <div style="position: relative;">
        <svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path stroke-linecap="round" stroke-linejoin="round" d="M16 10a4 4 0 0 1-8 0"></path></svg>
