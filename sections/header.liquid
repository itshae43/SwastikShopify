{% comment %}
  Renders the main store header, styled on a dark brand green background with gold logo and white navigation menus.
{% endcomment %}

<div class="header-section-wrapper">
  {% if section.settings.show_announcement %}
    <div class="announcement-bar">
      <div class="announcement-bar__marquee">
        <div class="announcement-bar__track">
          <!-- Item 1: Location -->
          <div class="announcement-bar__item">
            <svg class="announcement-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
            <span class="announcement-bar__text">{{ section.settings.announcement_left_text | escape }}</span>
          </div>
          
          <!-- Item 2: Brand Statement -->
          <div class="announcement-bar__item">
            <span class="announcement-bar__text">{{ section.settings.announcement_center_text | escape }}</span>
          </div>
          
          <!-- Item 3: Shipping -->
          <div class="announcement-bar__item">
            <svg class="announcement-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10" />
              <line x1="2" y1="12" x2="22" y2="12" />
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
            </svg>
            <span class="announcement-bar__text">{{ section.settings.announcement_right_text | escape }}</span>
          </div>
          
          <!-- Duplicates for mobile looping -->
          <div class="announcement-bar__item announcement-bar__item--duplicate">
            <svg class="announcement-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
            <span class="announcement-bar__text">{{ section.settings.announcement_left_text | escape }}</span>
          </div>
          
          <div class="announcement-bar__item announcement-bar__item--duplicate">
            <span class="announcement-bar__text">{{ section.settings.announcement_center_text | escape }}</span>
          </div>
          
          <div class="announcement-bar__item announcement-bar__item--duplicate">
            <svg class="announcement-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10" />
              <line x1="2" y1="12" x2="22" y2="12" />
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
            </svg>
            <span class="announcement-bar__text">{{ section.settings.announcement_right_text | escape }}</span>
          </div>
        </div>
      </div>
    </div>
  {% endif %}

  <header class="header">
    <!-- Left: Hamburger button for mobile menu -->
    <button type="button" class="header__hamburger" aria-label="Open menu" aria-controls="MobileNavDrawer" aria-expanded="false">
      <svg class="icon icon-hamburger" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

    <!-- Left: Brand Logo -->
    <div class="header__logo">
      <a href="{{ routes.root_url }}" class="header__logo-link">
        <img src="{{ 'logo.png' | asset_url }}" 
             alt="Swastik Jewels" 
             class="header__logo-img" 
             width="65"
             height="65"
             style="max-width: {{ section.settings.logo_width }}px; height: auto; object-fit: contain;">
        <div class="header__logo-text-wrapper">
          <span class="header__logo-title">Swastik</span>
          <span class="header__logo-subtitle">JEWELS</span>
        </div>
      </a>
    </div>

    <!-- Center: Navigation Menu -->
    <nav class="header__nav" role="navigation">
      <ul class="header__menu-list">
        {% if section.settings.menu != blank %}
          {% for link in section.settings.menu.links %}
            {%- assign downcase_title = link.title | downcase -%}
            {%- assign show_dropdown = false -%}
            {%- if link.links != blank -%}
              {%- if downcase_title != 'our story' -%}
                {%- assign show_dropdown = true -%}
              {%- endif -%}
            {%- endif -%}
            <li class="header__menu-item {% if show_dropdown %}header__menu-item--has-dropdown{% endif %}">
              <a href="{{ link.url }}" class="header__menu-link {% if link.active %}header__menu-link--active{% endif %}">
                {{ link.title }}
                {% if show_dropdown %}
                  <svg class="icon icon-chevron-down" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                  </svg>
                {% endif %}
              </a>
              {% if show_dropdown %}
                <ul class="header__dropdown-menu">
                  {% for childlink in link.links %}
                    <li>
                      <a href="{{ childlink.url }}">{{ childlink.title }}</a>
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}
            </li>
          {% endfor %}
        {% else %}
          <!-- Fallback menu matching the request exactly -->
          <li class="header__menu-item header__menu-item--has-dropdown">
            <a href="#" class="header__menu-link">
              Jewellery
              <svg class="icon icon-chevron-down" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
              </svg>
            </a>
            <ul class="header__dropdown-menu">
              <li><a href="{{ routes.collections_url }}/rings">Rings</a></li>
              <li><a href="{{ routes.collections_url }}/necklaces">Necklaces</a></li>
              <li><a href="{{ routes.collections_url }}/earrings">Earrings</a></li>
              <li><a href="{{ routes.collections_url }}/bracelets">Bracelets</a></li>
            </ul>
          </li>
          <li class="header__menu-item">
            <a href="{{ routes.collections_url }}/bridal" class="header__menu-link">Bridal</a>
          </li>
          <li class="header__menu-item">
            <a href="{{ routes.collections_url }}/diamonds" class="header__menu-link">Diamonds</a>
          </li>
          <li class="header__menu-item header__menu-item--has-dropdown">
            <a href="#" class="header__menu-link">
              Collections
              <svg class="icon icon-chevron-down" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
              </svg>
            </a>
            <ul class="header__dropdown-menu">
              <li><a href="{{ routes.collections_url }}/festive">Festive Collection</a></li>
              <li><a href="{{ routes.collections_url }}/heritage">Heritage Edit</a></li>
              <li><a href="{{ routes.collections_url }}/daily">Daily Wear</a></li>
            </ul>
          </li>
          <li class="header__menu-item">
            <a href="/pages/about-us" class="header__menu-link">Our Story</a>
          </li>
        {% endif %}
      </ul>
    </nav>

    <!-- Right: Gold Rate Pill, Wishlist, Cart, Profile Actions -->
    <div class="header__icons">
      <!-- Currency Selector -->
      <div class="header__localization">
        {%- form 'localization', id: 'HeaderLanguageForm', class: 'localization-form' -%}
          <!-- Hidden input that holds the selected country code -->
          <input type="hidden" name="country_code" id="HeaderCountryCode" value="{{ localization.country.iso_code }}">
          
          <div class="custom-currency-selector" id="CustomCurrencySelector">
            <button type="button" class="custom-currency-selector__trigger" id="CurrencySelectorTrigger" aria-expanded="false" aria-haspopup="listbox">
              <span class="custom-currency-selector__trigger-text">{{ localization.country.currency.iso_code }}</span>
              <svg class="icon icon-chevron-down" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
              </svg>
            </button>
            
            <ul class="custom-currency-selector__list" id="CurrencySelectorList" role="listbox" aria-label="Currency select" tabindex="-1">
              {%- assign custom_currencies = "INR:IN,USD:US,EUR:FR,GBP:GB,CAD:CA,AUD:AU" | split: "," -%}
              {%- for item in custom_currencies -%}
                {%- assign parts = item | split: ":" -%}
                {%- assign curr_code = parts[0] -%}
                {%- assign country_iso = parts[1] -%}
                
                {%- assign is_active = false -%}
                {%- if localization.country.iso_code == country_iso -%}
                  {%- assign is_active = true -%}
                {%- elsif localization.country.currency.iso_code == 'EUR' and curr_code == 'EUR' -%}
                  {%- assign is_active = true -%}
                {%- elsif localization.country.currency.iso_code == 'USD' and curr_code == 'USD' -%}
                  {%- assign is_active = true -%}
                {%- elsif localization.country.currency.iso_code == 'GBP' and curr_code == 'GBP' -%}
                  {%- assign is_active = true -%}
                {%- elsif localization.country.currency.iso_code == 'CAD' and curr_code == 'CAD' -%}
                  {%- assign is_active = true -%}
                {%- elsif localization.country.currency.iso_code == 'AUD' and curr_code == 'AUD' -%}
                  {%- assign is_active = true -%}
                {%- endif -%}

                {%- assign submit_iso = country_iso -%}
                {%- for av_country in localization.available_countries -%}
                  {%- if av_country.currency.iso_code == curr_code -%}
                    {%- assign submit_iso = av_country.iso_code -%}
                    {%- break -%}
                  {%- endif -%}
                {%- endfor -%}

                <li class="custom-currency-selector__item{% if is_active %} custom-currency-selector__item--active{% endif %}" 
                    role="option" 
                    data-value="{{ submit_iso }}"
                    aria-selected="{% if is_active %}true{% else %}false{% endif %}">
                  {%- if curr_code == 'EUR' -%}
                    <img src="https://flagcdn.com/w40/eu.png" 
                         alt="EUR flag" 
                         class="custom-currency-selector__flag"
                         loading="lazy"
                         width="20"
                         height="15">
                  {%- else -%}
                    <img src="https://flagcdn.com/w40/{{ country_iso | downcase }}.png" 
                         alt="{{ curr_code }} flag" 
                         class="custom-currency-selector__flag"
                         loading="lazy"
                         width="20"
                         height="15">
                  {%- endif -%}
                  <span class="custom-currency-selector__code">{{ curr_code }}</span>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endform -%}
      </div>

      <script>
        document.addEventListener('DOMContentLoaded', () => {
          const selector = document.getElementById('CustomCurrencySelector');
          if (!selector) return;
          
          const trigger = selector.querySelector('#CurrencySelectorTrigger');
          const hiddenInput = document.getElementById('HeaderCountryCode');
          const form = document.getElementById('HeaderLanguageForm');
          
          // Toggle dropdown
          trigger.addEventListener('click', (e) => {
            e.stopPropagation();
            const isOpen = selector.classList.toggle('open');
            trigger.setAttribute('aria-expanded', isOpen);
          });
          
          // Close dropdown on click outside
          document.addEventListener('click', (e) => {
            if (!selector.contains(e.target)) {
              selector.classList.remove('open');
              trigger.setAttribute('aria-expanded', 'false');
            }
          });
          
          // Select option
          selector.querySelectorAll('.custom-currency-selector__item').forEach(item => {
            item.addEventListener('click', () => {
              const countryCode = item.getAttribute('data-value');
              if (hiddenInput && form) {
                hiddenInput.value = countryCode;
                form.submit();
              }
            });
          });
        });
      </script>

      <!-- Gold price pill -->
      <div class="header__gold-price">
        <span class="gold-text">Gold {{ shop.metafields.custom.daily_gold_rate.value | default: '15,620' }}/10g</span>
      </div>

      <!-- Wishlist Link & Count -->
      <a href="javascript:void(0)" onclick="if(window.openWishlistDrawer) window.openWishlistDrawer(); return false;" class="header__icon-link header__wishlist-trigger" aria-label="Wishlist">
        <svg class="icon icon-wishlist" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
        </svg>
        {% assign wishlist_count = 0 %}
        <span class="header__badge" id="wishlist-count-badge" style="display: none;">0</span>
      </a>

      <!-- Cart Link & Count -->
      <a href="javascript:void(0)" onclick="if(window.openCartDrawer) window.openCartDrawer(); return false;" class="header__icon-link header__cart-trigger" aria-label="Cart">
        <svg class="icon icon-cart" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007Z" />
        </svg>
        {% assign cart_count = cart.item_count | default: 0 %}
        <span class="header__badge" id="cart-count-badge" {% if cart_count == 0 %}style="display: none;"{% endif %}>{{ cart_count }}</span>
      </a>

      <!-- Profile Link -->
      <a href="{{ routes.account_url }}" class="header__icon-link header__profile-trigger" aria-label="Account">
        <svg class="icon icon-profile" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
        </svg>
      </a>
    </div>
  </header>

  <!-- Mobile Navigation Drawer -->
  <div class="mobile-menu-drawer" id="MobileNavDrawer" aria-hidden="true">
    <div class="mobile-menu-drawer__overlay" id="MobileNavOverlay"></div>
    <div class="mobile-menu-drawer__content">
      <div class="mobile-menu-drawer__header">
        <div class="mobile-menu-drawer__logo">
          <div class="header__logo-text-wrapper" style="align-items: flex-start; filter: none;">
            <span class="header__logo-title" style="font-size: 1.6rem; color: #D4AF37; -webkit-text-stroke: 0; background: none; -webkit-text-fill-color: #D4AF37;">Swastik</span>
            <span class="header__logo-subtitle" style="font-size: 0.55rem; letter-spacing: 0.4em; color: #D4AF37; margin-top: 2px;">JEWELS</span>
          </div>
        </div>
        <button type="button" class="mobile-menu-drawer__close" id="MobileNavClose" aria-label="Close menu">
          <svg viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 28px; height: 28px;">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>

      <nav class="mobile-menu-drawer__nav">
        <div class="mobile-menu-drawer__main-tabs">
          <button type="button" class="mobile-main-tab active" data-maintab="women">Women</button>
          <button type="button" class="mobile-main-tab" data-maintab="men">Men</button>
        </div>

        <div class="mobile-menu-drawer__divider">
          <span class="line"></span>
          <span class="text">Shop Categories</span>
          <span class="line"></span>
        </div>

        <div class="mobile-main-content active" id="maintab-women">
          <ul class="mobile-menu-drawer__accordion">
            <!-- RINGS -->
            <li class="mobile-accordion-item">
              <button class="mobile-accordion-header" aria-expanded="true">
                <div class="accordion-title">
                  <svg class="category-icon" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="1.5">
                    <circle cx="12" cy="14" r="6" />
                    <path d="M9.5 8h5l1.5-4h-8z" />
                  </svg>
                  <span>RINGS</span>
                </div>
                <svg class="icon-chevron" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m6 9 6 6 6-6" /></svg>
              </button>
              <div class="mobile-accordion-content" style="display: block;">
                <div class="mobile-subtabs">
                  <button class="mobile-subtab active" data-sub="rings-style">Shop By Style</button>
                  <button class="mobile-subtab" data-sub="rings-price">Shop By Price</button>
                  <button class="mobile-subtab" data-sub="rings-metal">Shop By Metal</button>
                </div>
                
                <div class="mobile-subcontent active" id="rings-style">
                  <ul class="mobile-sublist">
                    <li>
                      <a href="{{ routes.collections_url }}/engagement-rings">
                        <div class="item-left">
                          <img src="https://cdn.shopify.com/s/files/1/0805/0121/1413/files/engagement_ring_icon.png" onerror="this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' viewBox=\'0 0 24 24\' fill=\'none\' stroke=\'%23D4AF37\' stroke-width=\'1.5\'><circle cx=\'12\' cy=\'14\' r=\'6\'/><path d=\'M9.5 8h5l1.5-4h-8z\'/></svg>'">
                          <span>Engagement Rings</span>
                        </div>
                        <svg class="icon-arrow" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6" /></svg>
                      </a>
                    </li>
                    <li>
                      <a href="{{ routes.collections_url }}/couple-bands">
                        <div class="item-left">
                          <img src="https://cdn.shopify.com/s/files/1/0805/0121/1413/files/couple_bands_icon.png" onerror="this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' viewBox=\'0 0 24 24\' fill=\'none\' stroke=\'%23D4AF37\' stroke-width=\'1.5\'><ellipse cx=\'10\' cy=\'12\' rx=\'6\' ry=\'3\' transform=\'rotate(-15 10 12)\'/><ellipse cx=\'14\' cy=\'14\' rx=\'6\' ry=\'3\' transform=\'rotate(-15 14 14)\'/></svg>'">
                          <span>Couple Bands</span>
                        </div>
                        <svg class="icon-arrow" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6" /></svg>
                      </a>
                    </li>
                    <li>
                      <a href="{{ routes.collections_url }}/casual-rings">
                        <div class="item-left">
                          <img src="https://cdn.shopify.com/s/files/1/0805/0121/1413/files/casual_rings_icon.png" onerror="this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' viewBox=\'0 0 24 24\' fill=\'none\' stroke=\'%23D4AF37\' stroke-width=\'1.5\'><circle cx=\'12\' cy=\'12\' r=\'6\'/><circle cx=\'12\' cy=\'6\' r=\'1.5\'/></svg>'">
                          <span>Casual Rings</span>
                        </div>
                        <svg class="icon-arrow" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6" /></svg>
                      </a>
                    </li>
                    <li>
                      <a href="{{ routes.collections_url }}/eternity-rings">
                        <div class="item-left">
                          <img src="https://cdn.shopify.com/s/files/1/0805/0121/1413/files/eternity_rings_icon.png" onerror="this.src='data:image/svg+xml;utf8,<svg xmlns=\'http://www.w3.org/2000/svg\' viewBox=\'0 0 24 24\' fill=\'none\' stroke=\'%23D4AF37\' stroke-width=\'1.5\'><ellipse cx=\'12\' cy=\'12\' rx=\'8\' ry=\'3\' stroke-dasharray=\'2 2\'/></svg>'">
                          <span>Eternity Rings</span>
                        </div>
                        <svg class="icon-arrow" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6" /></svg>
                      </a>
                    </li>
                  </ul>
                </div>
                
                <div class="mobile-subcontent" id="rings-price">
                  <ul class="mobile-sublist mobile-sublist--text">
                    <li><a href="{{ routes.collections_url }}/rings?filter.v.price.gte=&filter.v.price.lte=10000"><span>Under ₹10,000</span><svg class="icon-arrow" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6" /></svg></a></li>
                    <li><a href="{{ routes.collections_url }}/rings?filter.v.price.gte=10000&filter.v.price.lte=20000"><span>₹10,000 - ₹20,000</span><svg class="icon-arrow" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6" /></svg></a></li>
                    <li><a href="{{ routes.collections_url }}/rings?filter.v.price.gte=20000&filter.v.price.lte=30000"><span>₹20,000 - ₹30,000</span><svg class="icon-arrow" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6" /></svg></a></li>
                    <li><a href="{{ routes.collections_url }}/rings?filter.v.price.gte=30000&filter.v.price.lte=50000"><span>₹30,000 - ₹50,000</span><svg class="icon-arrow" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6" /></svg></a></li>
                    <li><a href="{{ routes.collections_url }}/rings?filter.v.price.gte=50000&filter.v.price.lte=100000"><span>₹50,000 - ₹1,00,000</span><svg class="icon-arrow" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6" /></svg></a></li>
                    <li><a href="{{ routes.collections_url }}/rings?filter.v.price.gte=100000"><span>Above ₹1,00,000</span><svg class="icon-arrow" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6" /></svg></a></li>
                  </ul>
                </div>
                
                <div class="mobile-subcontent" id="rings-metal">
                  <ul class="mobile-sublist">
                    <li>
