  /* Mobile Drawer styling */
  .mobile-menu-drawer {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1000;
    visibility: hidden;
    transition: visibility 0.35s ease;
  }
  
  .mobile-menu-drawer--open {
    visibility: visible;
  }

  .mobile-menu-drawer__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 46, 40, 0.4);
    backdrop-filter: blur(5px);
    opacity: 0;
    transition: opacity 0.35s ease;
  }

  .mobile-menu-drawer--open .mobile-menu-drawer__overlay {
    opacity: 1;
  }

  .mobile-menu-drawer__content {
    position: absolute;
    top: 0;
    left: 0;
    width: 85%;
    max-width: 340px;
    height: 100%;
    background-color: #00221D; /* slightly darker green for luxury contrast */
    border-right: 1px solid rgba(212, 175, 55, 0.25);
    box-shadow: 10px 0 30px rgba(0, 0, 0, 0.4);
    display: flex;
    flex-direction: column;
    transform: translateX(-100%);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    box-sizing: border-box;
    padding: 2.4rem;
  }

  .mobile-menu-drawer--open .mobile-menu-drawer__content {
    transform: translateX(0);
  }

  .mobile-menu-drawer__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 3rem;
  }

  .mobile-menu-drawer__logo {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .mobile-menu-drawer__logo-img {
    height: auto;
    object-fit: contain;
  }

  .mobile-menu-drawer__close {
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.8);
    cursor: pointer;
    padding: 0.8rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.25s ease;
  }

  .mobile-menu-drawer__close svg {
    width: 2.4rem;
    height: 2.4rem;
  }

  .mobile-menu-drawer__close:hover {
    color: var(--color-accent, #D4AF37);
  }

  .mobile-menu-drawer__nav {
    flex: 1;
    overflow-y: auto;
    margin-bottom: 2rem;
    /* Hide scrollbar */
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .mobile-menu-drawer__nav::-webkit-scrollbar {
    display: none;
  }

  .mobile-menu-drawer__menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .mobile-menu-drawer__item {
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .mobile-menu-drawer__link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    padding: 1.6rem 0;
    background: none;
    border: none;
    text-align: left;
    font-family: 'Montserrat', sans-serif;
    font-size: 1.5rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.95);
    text-decoration: none;
    cursor: pointer;
    transition: color 0.25s ease;
  }

  .mobile-menu-drawer__link svg {
    width: 1.4rem;
    height: 1.4rem;
    color: var(--color-accent, #D4AF37);
    transition: transform 0.25s ease;
  }

  .mobile-menu-drawer__link:hover {
    color: var(--color-accent, #D4AF37);
  }

  .mobile-menu-drawer__link[aria-expanded="true"] {
    color: var(--color-accent, #D4AF37);
  }

  .mobile-menu-drawer__link[aria-expanded="true"] svg {
    transform: rotate(180deg);
  }

  .mobile-menu-drawer__submenu {
    list-style: none;
    padding: 0 0 1.6rem 1.6rem;
    margin: 0;
  }

  .mobile-menu-drawer__subitem {
    margin-bottom: 1.2rem;
  }

  .mobile-menu-drawer__subitem:last-child {
    margin-bottom: 0;
  }

  .mobile-menu-drawer__sublink {
    display: block;
    font-family: 'Montserrat', sans-serif;
    font-size: 1.3rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition: color 0.25s ease;
  }

  .mobile-menu-drawer__sublink:hover {
    color: var(--color-accent, #D4AF37);
  }

  .mobile-menu-drawer__footer {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 2rem;
    margin-top: auto;
  }

  .mobile-menu-drawer__gold-price {
