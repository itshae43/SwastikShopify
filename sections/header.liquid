{% javascript %}
  function initMobileMenu() {
    const hamburger = document.querySelector('.header__hamburger');
    const drawer = document.getElementById('MobileNavDrawer');
    const closeBtn = document.getElementById('MobileNavClose');
    const overlay = document.getElementById('MobileNavOverlay');
    const body = document.body;

    if (!hamburger || !drawer) return;
    if (hamburger.dataset.menuInitialized === 'true') return;
    hamburger.dataset.menuInitialized = 'true';

    hamburger.addEventListener('click', function() {
      const expanded = hamburger.getAttribute('aria-expanded') === 'true';
      hamburger.setAttribute('aria-expanded', !expanded);
      drawer.classList.add('mobile-menu-drawer--open');
      drawer.setAttribute('aria-hidden', 'false');
      body.classList.add('body-lock');
    });

    function closeDrawer() {
      hamburger.setAttribute('aria-expanded', 'false');
      drawer.classList.remove('mobile-menu-drawer--open');
      drawer.setAttribute('aria-hidden', 'true');
      body.classList.remove('body-lock');
    }

    if (closeBtn) closeBtn.addEventListener('click', closeDrawer);
    if (overlay) overlay.addEventListener('click', closeDrawer);

    // Main Tabs (Women, Men, Kids)
    const mainTabs = document.querySelectorAll('.mobile-main-tab');
    const mainContents = document.querySelectorAll('.mobile-main-content');
    
    mainTabs.forEach(tab => {
      tab.addEventListener('click', function() {
        mainTabs.forEach(t => t.classList.remove('active'));
        mainContents.forEach(c => c.classList.remove('active'));
        
        this.classList.add('active');
        const targetId = 'maintab-' + this.getAttribute('data-maintab');
        const targetContent = document.getElementById(targetId);
        if (targetContent) targetContent.classList.add('active');
      });
    });

    // Accordions (e.g. Rings)
    const accordions = document.querySelectorAll('.mobile-accordion-header');
    accordions.forEach(acc => {
      acc.addEventListener('click', function(e) {
        if(this.tagName.toLowerCase() === 'a') return; // Skip if it's a direct link
        e.preventDefault();
        const expanded = this.getAttribute('aria-expanded') === 'true';
        this.setAttribute('aria-expanded', !expanded);
        const content = this.nextElementSibling;
        if (content) {
          content.style.display = expanded ? 'none' : 'block';
        }
      });
    });

    // Currency Dropdown
    const currBtn = document.getElementById('MobileCurrencyBtn');
    const currDropdown = document.getElementById('MobileCurrencyDropdown');
    if (currBtn && currDropdown) {
      currBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        currDropdown.style.display = currDropdown.style.display === 'none' ? 'block' : 'none';
      });
      document.addEventListener('click', function(e) {
        if (!currBtn.contains(e.target) && !currDropdown.contains(e.target)) {
          currDropdown.style.display = 'none';
        }
      });
    }

    // Sub Tabs (Style, Price, Metal)
    const subtabs = document.querySelectorAll('.mobile-subtab');
    subtabs.forEach(tab => {
      tab.addEventListener('click', function() {
        const container = this.closest('.mobile-accordion-content');
        container.querySelectorAll('.mobile-subtab').forEach(t => t.classList.remove('active'));
        container.querySelectorAll('.mobile-subcontent').forEach(c => c.classList.remove('active'));
        
        this.classList.add('active');
        const targetId = this.getAttribute('data-sub');
        const targetContent = container.querySelector('#' + targetId);
        if (targetContent) targetContent.classList.add('active');
      });
    });
  }

  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMobileMenu);
  } else {
    initMobileMenu();
  }
  document.addEventListener('shopify:section:load', initMobileMenu);
{% endjavascript %}

<script>
  window.updateGlobalCartCount = function(count) {
    const badge = document.getElementById('cart-count-badge');
    const mobileBadge = document.getElementById('mobile-cart-badge');
    if (badge) {
      badge.textContent = count;
      if (count > 0) {
        badge.style.display = 'flex';
      } else {
        badge.style.display = 'none';
      }
    }
    if (mobileBadge) {
      mobileBadge.textContent = count;
      if (count > 0) {
        mobileBadge.style.display = 'flex';
      } else {
        mobileBadge.style.display = 'none';
      }
    }
  };
</script>

