{% comment %}
  Renders the main store header, styled on a dark brand green background with gold logo and white navigation menus.
{% endcomment %}

<div class="header-section-wrapper">
  {% if section.settings.show_announcement %}
    <div class="announcement-bar">
      <div class="announcement-bar__marquee">
        <div class="announcement-bar__track">
          <!-- Item 1: Location -->
          <div class="announcement-bar__item">
            <svg class="announcement-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
            <span class="announcement-bar__text">{{ section.settings.announcement_left_text | escape }}</span>
          </div>
          
          <!-- Item 2: Brand Statement -->
          <div class="announcement-bar__item">
            <span class="announcement-bar__text">{{ section.settings.announcement_center_text | escape }}</span>
          </div>
          
          <!-- Item 3: Shipping -->
          <div class="announcement-bar__item">
            <svg class="announcement-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10" />
              <line x1="2" y1="12" x2="22" y2="12" />
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
            </svg>
            <span class="announcement-bar__text">{{ section.settings.announcement_right_text | escape }}</span>
          </div>
          
          <!-- Duplicates for mobile looping -->
          <div class="announcement-bar__item announcement-bar__item--duplicate">
            <svg class="announcement-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
            <span class="announcement-bar__text">{{ section.settings.announcement_left_text | escape }}</span>
          </div>
          
          <div class="announcement-bar__item announcement-bar__item--duplicate">
            <span class="announcement-bar__text">{{ section.settings.announcement_center_text | escape }}</span>
          </div>
          
          <div class="announcement-bar__item announcement-bar__item--duplicate">
            <svg class="announcement-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10" />
              <line x1="2" y1="12" x2="22" y2="12" />
              <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
            </svg>
            <span class="announcement-bar__text">{{ section.settings.announcement_right_text | escape }}</span>
          </div>
        </div>
      </div>
    </div>
  {% endif %}

  <header class="header">
    <!-- Left: Hamburger button for mobile menu -->
    <button type="button" class="header__hamburger" aria-label="Open menu" aria-controls="MobileNavDrawer" aria-expanded="false">
      <div class="header__hamburger-lines">
        <span class="line line-1"></span>
        <span class="line line-2"></span>
      </div>
    </button>

    <!-- Left: Brand Logo -->
    <div class="header__logo">
      <a href="{{ routes.root_url }}" class="header__logo-link">
        <img src="{{ 'Swastik_logo.png' | asset_url }}" 
             alt="Swastik Jewels" 
             class="header__logo-img" 
             width="65"
             height="65"
             style="max-width: {{ section.settings.logo_width }}px; height: auto; object-fit: contain;">
        <div class="header__logo-text-wrapper">
          <span class="header__logo-title">Swastik</span>
          <span class="header__logo-subtitle">JEWELS</span>
        </div>
      </a>
    </div>

    <!-- Center: Navigation Menu -->
    <nav class="header__nav" role="navigation">
      <ul class="header__menu-list">
        {% if section.settings.menu != blank %}
          {% for link in section.settings.menu.links %}
            {%- assign downcase_title = link.title | downcase -%}
            {%- assign show_dropdown = false -%}
            {%- if link.links != blank -%}
              {%- if downcase_title != 'our story' -%}
                {%- assign show_dropdown = true -%}
              {%- endif -%}
            {%- endif -%}
            <li class="header__menu-item {% if show_dropdown %}header__menu-item--has-dropdown{% endif %}">
              <a href="{{ link.url }}" class="header__menu-link {% if link.active %}header__menu-link--active{% endif %}">
                {{ link.title }}
                {% if show_dropdown %}
                  <svg class="icon icon-chevron-down" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                  </svg>
                {% endif %}
              </a>
              {% if show_dropdown %}
                <ul class="header__dropdown-menu">
                  {% for childlink in link.links %}
                    <li>
                      <a href="{{ childlink.url }}">{{ childlink.title }}</a>
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}
            </li>
          {% endfor %}
        {% else %}
          <!-- Fallback menu matching the request exactly -->
          <li class="header__menu-item header__menu-item--has-dropdown">
            <a href="#" class="header__menu-link">
              Jewellery
              <svg class="icon icon-chevron-down" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
              </svg>
            </a>
            <ul class="header__dropdown-menu">
              <li><a href="{{ routes.collections_url }}/rings">Rings</a></li>
              <li><a href="{{ routes.collections_url }}/necklaces">Necklaces</a></li>
              <li><a href="{{ routes.collections_url }}/earrings">Earrings</a></li>
              <li><a href="{{ routes.collections_url }}/bracelets">Bracelets</a></li>
            </ul>
          </li>
          <li class="header__menu-item">
            <a href="{{ routes.collections_url }}/bridal" class="header__menu-link">Bridal</a>
          </li>
          <li class="header__menu-item">
            <a href="{{ routes.collections_url }}/diamonds" class="header__menu-link">Diamonds</a>
          </li>
          <li class="header__menu-item header__menu-item--has-dropdown">
            <a href="#" class="header__menu-link">
              Collections
              <svg class="icon icon-chevron-down" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
              </svg>
            </a>
            <ul class="header__dropdown-menu">
              <li><a href="{{ routes.collections_url }}/festive">Festive Collection</a></li>
              <li><a href="{{ routes.collections_url }}/heritage">Heritage Edit</a></li>
              <li><a href="{{ routes.collections_url }}/daily">Daily Wear</a></li>
            </ul>
          </li>
          <li class="header__menu-item">
            <a href="/pages/about-us" class="header__menu-link">Our Story</a>
          </li>
        {% endif %}
      </ul>
    </nav>

    <!-- Right: Gold Rate Pill, Wishlist, Cart, Profile Actions -->
    <div class="header__icons">
      <!-- Currency Selector -->
      <div class="header__localization">
        {%- form 'localization', id: 'HeaderLanguageForm', class: 'localization-form' -%}
          <!-- Hidden input that holds the selected country code -->
          <input type="hidden" name="country_code" id="HeaderCountryCode" value="{{ localization.country.iso_code }}">
          
          <div class="custom-currency-selector" id="CustomCurrencySelector">
            <button type="button" class="custom-currency-selector__trigger" id="CurrencySelectorTrigger" aria-expanded="false" aria-haspopup="listbox">
              <span class="custom-currency-selector__trigger-text">{{ localization.country.currency.iso_code }}</span>
              <svg class="icon icon-chevron-down" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
              </svg>
            </button>
            
            <ul class="custom-currency-selector__list" id="CurrencySelectorList" role="listbox" aria-label="Currency select" tabindex="-1">
              {%- assign custom_currencies = "INR:IN,USD:US,EUR:FR,GBP:GB,CAD:CA,AUD:AU" | split: "," -%}
              {%- for item in custom_currencies -%}
                {%- assign parts = item | split: ":" -%}
                {%- assign curr_code = parts[0] -%}
                {%- assign country_iso = parts[1] -%}
                
                {%- assign is_active = false -%}
                {%- if localization.country.iso_code == country_iso -%}
                  {%- assign is_active = true -%}
                {%- elsif localization.country.currency.iso_code == 'EUR' and curr_code == 'EUR' -%}
                  {%- assign is_active = true -%}
                {%- elsif localization.country.currency.iso_code == 'USD' and curr_code == 'USD' -%}
                  {%- assign is_active = true -%}
                {%- elsif localization.country.currency.iso_code == 'GBP' and curr_code == 'GBP' -%}
                  {%- assign is_active = true -%}
                {%- elsif localization.country.currency.iso_code == 'CAD' and curr_code == 'CAD' -%}
                  {%- assign is_active = true -%}
                {%- elsif localization.country.currency.iso_code == 'AUD' and curr_code == 'AUD' -%}
                  {%- assign is_active = true -%}
                {%- endif -%}

                {%- assign submit_iso = country_iso -%}
                {%- for av_country in localization.available_countries -%}
                  {%- if av_country.currency.iso_code == curr_code -%}
                    {%- assign submit_iso = av_country.iso_code -%}
                    {%- break -%}
                  {%- endif -%}
                {%- endfor -%}

                <li class="custom-currency-selector__item{% if is_active %} custom-currency-selector__item--active{% endif %}" 
                    role="option" 
                    data-value="{{ submit_iso }}"
                    aria-selected="{% if is_active %}true{% else %}false{% endif %}">
                  {%- if curr_code == 'EUR' -%}
                    <img src="https://flagcdn.com/w40/eu.png" 
                         alt="EUR flag" 
                         class="custom-currency-selector__flag"
                         loading="lazy"
                         width="20"
                         height="15">
                  {%- else -%}
                    <img src="https://flagcdn.com/w40/{{ country_iso | downcase }}.png" 
                         alt="{{ curr_code }} flag" 
                         class="custom-currency-selector__flag"
                         loading="lazy"
                         width="20"
                         height="15">
                  {%- endif -%}
                  <span class="custom-currency-selector__code">{{ curr_code }}</span>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endform -%}
      </div>

      <script>
        document.addEventListener('DOMContentLoaded', () => {
          const selector = document.getElementById('CustomCurrencySelector');
          if (!selector) return;
          
          const trigger = selector.querySelector('#CurrencySelectorTrigger');
          const hiddenInput = document.getElementById('HeaderCountryCode');
          const form = document.getElementById('HeaderLanguageForm');
          
          // Toggle dropdown
          trigger.addEventListener('click', (e) => {
            e.stopPropagation();
            const isOpen = selector.classList.toggle('open');
            trigger.setAttribute('aria-expanded', isOpen);
          });
          
          // Close dropdown on click outside
          document.addEventListener('click', (e) => {
            if (!selector.contains(e.target)) {
              selector.classList.remove('open');
              trigger.setAttribute('aria-expanded', 'false');
            }
          });
          
          // Select option
          selector.querySelectorAll('.custom-currency-selector__item').forEach(item => {
            item.addEventListener('click', () => {
              const countryCode = item.getAttribute('data-value');
              if (hiddenInput && form) {
                hiddenInput.value = countryCode;
                form.submit();
              }
            });
          });
        });
      </script>

      <!-- Gold price pill -->
      <div class="header__gold-price">
        <span class="gold-text">Gold {{ shop.metafields.custom.daily_gold_rate.value | default: '14,422' }}/1g</span>
      </div>

      <!-- Wishlist Link & Count -->
      <a href="javascript:void(0)" onclick="if(window.openWishlistDrawer) window.openWishlistDrawer(); return false;" class="header__icon-link header__wishlist-trigger" aria-label="Wishlist">
        <svg class="icon icon-wishlist" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
        </svg>
        {% assign wishlist_count = 0 %}
        <span class="header__badge" id="wishlist-count-badge" style="display: none;">0</span>
      </a>

      <!-- Cart Link & Count -->
      <a href="javascript:void(0)" onclick="if(window.openCartDrawer) window.openCartDrawer(); return false;" class="header__icon-link header__cart-trigger" aria-label="Cart">
        <svg class="icon icon-cart" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 1 0-7.5 0v4.5m11.356-1.993 1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 0 1-1.12-1.243l1.264-12A1.125 1.125 0 0 1 5.513 7.5h12.974c.576 0 1.059.435 1.119 1.007Z" />
        </svg>
        {% assign cart_count = cart.item_count | default: 0 %}
        <span class="header__badge" id="cart-count-badge" {% if cart_count == 0 %}style="display: none;"{% endif %}>{{ cart_count }}</span>
      </a>

      <!-- Vertical Divider Line -->
      <span class="header__icon-divider"></span>

      <!-- Profile Link -->
      <a href="{{ routes.account_url }}" class="header__icon-link header__profile-trigger" aria-label="Account">
        <svg class="icon icon-profile" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
        </svg>
      </a>
    </div>
  </header>

  <!-- Mobile Navigation Drawer (Bespoke Swastik Jewels Design) -->
  <div class="mobile-menu-drawer" id="MobileNavDrawer" aria-hidden="true">
    <div class="mobile-menu-drawer__overlay" id="MobileNavOverlay"></div>
    <div class="mobile-menu-drawer__content">
      <!-- Drawer Header -->
      <div class="mobile-menu-drawer__header">
        <div class="mobile-menu-drawer__logo">
          <a href="{{ routes.root_url }}" class="header__logo-link">
            <img src="{{ 'Swastik_logo.png' | asset_url }}" alt="Swastik Jewels" class="header__logo-img" width="34" height="34" style="max-height: 2.8rem; width: auto; object-fit: contain;">
            <div class="header__logo-text-wrapper" style="align-items: flex-start;">
              <span class="header__logo-title" style="font-size: 1.85rem; color: #111111; -webkit-text-fill-color: initial; background: none; -webkit-text-stroke: 0; font-weight: 700;">Swastik</span>
              <span class="header__logo-subtitle" style="font-size: 0.62rem; letter-spacing: 0.45em; color: #888888; margin-top: -0.1rem;">JEWELS • SINCE 1997</span>
            </div>
          </a>
        </div>
        <button type="button" class="mobile-menu-drawer__close" id="MobileNavClose" aria-label="Close menu">
          <svg viewBox="0 0 24 24" fill="none" stroke="#111111" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="width: 22px; height: 22px;">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>

      <!-- Live Gold Rate Banner -->
      <div class="mobile-drawer-gold-rate">
        <span class="gold-rate-pulse"></span>
        <span class="gold-rate-label">LIVE RATE</span>
        <span class="gold-rate-val">{{ section.settings.gold_price | default: "Gold 15,620/g" }}</span>
      </div>

      <!-- Search Bar -->
      <div class="mobile-drawer-search">
        <form action="{{ routes.search_url }}" method="get" role="search" style="position: relative; width: 100%;">
          <input type="search" name="q" class="mobile-drawer-search__input" placeholder="Search Solitaires, Diamonds, Polki..." value="{{ search.terms | escape }}">
          <input type="hidden" name="options[prefix]" value="last">
          <button type="submit" class="mobile-drawer-search__btn" aria-label="Search">
            <svg viewBox="0 0 24 24" fill="none" stroke="#013F3E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 18px; height: 18px;">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </button>
        </form>
      </div>

      <!-- Drawer Nav Items (Dynamic Desktop & Detailed Swastik Categories) -->
      <nav class="mobile-menu-drawer__nav">
        <ul class="mobile-menu-list">
          {%- assign menu_links = section.settings.menu.links -%}
          {%- if menu_links != blank -%}
            {%- for link in menu_links -%}
              {%- assign has_sub = false -%}
              {%- if link.links != blank -%}
                {%- assign downcase_t = link.title | downcase -%}
                {%- if downcase_t != 'our story' -%}
                  {%- assign has_sub = true -%}
                {%- endif -%}
              {%- endif -%}

              <li class="mobile-menu-item{% if has_sub %} mobile-menu-item--has-sub{% endif %}">
                {%- if has_sub -%}
                  <button type="button" class="mobile-menu-trigger" aria-expanded="false">
                    <span class="mobile-menu-title">{{ link.title | upcase }}</span>
                    <svg class="mobile-menu-arrow" viewBox="0 0 24 24" fill="none" stroke="#222222" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6" />
                    </svg>
                  </button>
                  <ul class="mobile-submenu" style="display: none;">
                    {%- for child in link.links -%}
                      <li>
                        <a href="{{ child.url }}">{{ child.title }}</a>
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- else -%}
                  <a href="{{ link.url }}" class="mobile-menu-link">
                    <span class="mobile-menu-title">{{ link.title | upcase }}</span>
                  </a>
                {%- endif -%}
              </li>
            {%- endfor -%}
          {%- else -%}
            <!-- Bespoke Swastik Categories -->
            <li class="mobile-menu-item mobile-menu-item--has-sub">
              <button type="button" class="mobile-menu-trigger" aria-expanded="false">
                <span class="mobile-menu-title">SOLITAIRES</span>
                <svg class="mobile-menu-arrow" viewBox="0 0 24 24" fill="none" stroke="#222222" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6" /></svg>
              </button>
              <ul class="mobile-submenu" style="display: none;">
                <li><a href="{{ routes.collections_url }}/solitaires/solitaire-rings">Solitaire Rings</a></li>
                <li><a href="{{ routes.collections_url }}/solitaires/solitaire-earrings">Solitaire Earrings</a></li>
                <li><a href="{{ routes.collections_url }}/solitaires/solitaire-pendants">Solitaire Pendants</a></li>
                <li><a href="{{ routes.collections_url }}/solitaires?filter.v.price.lte=50000">Under ₹50,000</a></li>
              </ul>
            </li>

            <li class="mobile-menu-item mobile-menu-item--has-sub">
              <button type="button" class="mobile-menu-trigger" aria-expanded="false">
                <span class="mobile-menu-title">DIAMONDS</span>
                <svg class="mobile-menu-arrow" viewBox="0 0 24 24" fill="none" stroke="#222222" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6" /></svg>
              </button>
              <ul class="mobile-submenu" style="display: none;">
                <li><a href="{{ routes.collections_url }}/diamonds/natural-diamonds">Natural Diamonds</a></li>
                <li><a href="{{ routes.collections_url }}/diamonds/lab-grown-diamonds">Lab Grown Diamonds</a></li>
                <li><a href="{{ routes.collections_url }}/diamonds/diamond-bangles">Diamond Bangles & Bracelets</a></li>
              </ul>
            </li>

            <li class="mobile-menu-item mobile-menu-item--has-sub">
              <button type="button" class="mobile-menu-trigger" aria-expanded="false">
                <span class="mobile-menu-title">POLKI & HERITAGE</span>
                <svg class="mobile-menu-arrow" viewBox="0 0 24 24" fill="none" stroke="#222222" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6" /></svg>
              </button>
              <ul class="mobile-submenu" style="display: none;">
                <li><a href="{{ routes.collections_url }}/polki/uncut-diamond-sets">Uncut Diamond Sets</a></li>
                <li><a href="{{ routes.collections_url }}/polki/kundan-polki">Kundan & Meenakari</a></li>
                <li><a href="{{ routes.collections_url }}/polki/royal-chokers">Royal Heritage Chokers</a></li>
              </ul>
            </li>

            <li class="mobile-menu-item">
              <a href="{{ routes.collections_url }}/quick-ship" class="mobile-menu-link">
                <span class="mobile-menu-title" style="color: #D4AF37; font-weight: 600;">SHIPS IN 3 DAYS</span>
              </a>
            </li>

            <li class="mobile-menu-item mobile-menu-item--has-sub">
              <button type="button" class="mobile-menu-trigger" aria-expanded="false">
                <span class="mobile-menu-title">COLLECTIONS</span>
                <svg class="mobile-menu-arrow" viewBox="0 0 24 24" fill="none" stroke="#222222" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m9 18 6-6-6-6" /></svg>
              </button>
              <ul class="mobile-submenu" style="display: none;">
                <li><a href="{{ routes.collections_url }}/bridal">Bridal Collection</a></li>
                <li><a href="{{ routes.collections_url }}/everyday-luxe">Everyday Luxe</a></li>
                <li><a href="{{ routes.collections_url }}/for-every-you">For Every You</a></li>
              </ul>
            </li>

            <li class="mobile-menu-item">
              <a href="{{ routes.collections_url }}/gifting" class="mobile-menu-link">
                <span class="mobile-menu-title">GIFTING</span>
              </a>
            </li>

            <li class="mobile-menu-item">
              <a href="/pages/stores" class="mobile-menu-link">
                <span class="mobile-menu-title">STORES & EXPERIENCE CENTERS</span>
              </a>
            </li>

            <li class="mobile-menu-item">
              <a href="/pages/franchise-enquiry" class="mobile-menu-link">
                <span class="mobile-menu-title">FRANCHISE ENQUIRY</span>
              </a>
            </li>
          {%- endif -%}
        </ul>
      </nav>

      <!-- Bespoke Drawer Footer -->
      <div class="mobile-menu-drawer__footer">
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <button type="button" class="mobile-drawer-currency-btn">
            <span>INR ₹</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="width: 14px; height: 14px;">
              <path d="m6 9 6 6 6-6"/>
            </svg>
          </button>
