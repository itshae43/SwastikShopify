<div id="WishlistDrawer" class="wishlist-drawer" aria-hidden="true">
  <div class="wishlist-drawer__overlay" onclick="closeWishlistDrawer()"></div>
  <div class="wishlist-drawer__content">
    <div class="wishlist-drawer__header">
      <h2 class="wishlist-drawer__title">Your Wishlist (<span id="WishlistDrawerCount">0</span>)</h2>
      <button type="button" class="wishlist-drawer__close" aria-label="Close wishlist" onclick="closeWishlistDrawer()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <div class="wishlist-drawer__body" id="WishlistDrawerBody">
      <div class="wishlist-drawer__empty">
        <svg class="empty-wishlist-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
        </svg>
        <p>Your wishlist is currently empty.</p>
        <button type="button" class="btn-continue" onclick="closeWishlistDrawer()">Continue Shopping</button>
      </div>
    </div>
  </div>
</div>

{% style %}
  .wishlist-drawer {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 9999;
    display: flex;
    justify-content: flex-end;
    visibility: hidden;
    pointer-events: none;
    font-family: 'Montserrat', sans-serif;
  }
  .wishlist-drawer.is-open {
    visibility: visible;
    pointer-events: auto;
  }
  .wishlist-drawer__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.4);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .wishlist-drawer.is-open .wishlist-drawer__overlay {
    opacity: 1;
  }
  .wishlist-drawer__content {
    position: relative;
    width: 100%;
    max-width: 450px;
    height: 100%;
    background-color: #FAF8F2;
    box-shadow: -5px 0 30px rgba(0, 0, 0, 0.1);
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    display: flex;
    flex-direction: column;
  }
  .wishlist-drawer.is-open .wishlist-drawer__content {
    transform: translateX(0);
  }
  
  .wishlist-drawer__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 2rem 2.4rem;
    border-bottom: 1px solid rgba(1, 63, 62, 0.1);
  }
  .wishlist-drawer__title {
    margin: 0;
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.8rem;
    font-weight: 500;
    color: var(--color-primary, #013F3E);
  }
  .wishlist-drawer__close {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-primary, #013F3E);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    transition: background-color 0.2s ease;
  }
  .wishlist-drawer__close:hover {
    background-color: rgba(1, 63, 62, 0.05);
  }
  .wishlist-drawer__close svg {
    width: 2rem;
    height: 2rem;
  }

  .wishlist-drawer__body {
    flex: 1;
    overflow-y: auto;
    padding: 2.4rem;
  }
  
  /* Empty state */
  .wishlist-drawer__empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    text-align: center;
    color: #666666;
  }
  .empty-wishlist-icon {
    width: 6.4rem;
    height: 6.4rem;
    margin-bottom: 2rem;
    color: rgba(1, 63, 62, 0.2);
  }
  
  .btn-continue {
    margin-top: 2rem;
    padding: 1.2rem 2.4rem;
    background-color: transparent;
    color: var(--color-primary, #013F3E);
    border: 1px solid var(--color-primary, #013F3E);
    border-radius: 4px;
    cursor: pointer;
    font-weight: 500;
    transition: all 0.2s ease;
  }
  .btn-continue:hover {
    background-color: var(--color-primary, #013F3E);
    color: #FFFFFF;
  }

  /* Wishlist Items */
  .wishlist-item {
    display: flex;
    gap: 1.6rem;
    padding-bottom: 2rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid rgba(1, 63, 62, 0.08);
  }
  .wishlist-item:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }
  .wishlist-item__image {
    width: 90px;
    height: 90px;
    object-fit: cover;
    border-radius: 4px;
    border: 1px solid rgba(1, 63, 62, 0.05);
  }
  .wishlist-item__details {
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .wishlist-item__title {
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--color-primary, #013F3E);
    text-decoration: none;
    margin-bottom: 0.8rem;
    display: block;
  }
  .wishlist-item__title:hover {
    text-decoration: underline;
  }
  .wishlist-item__price {
    font-weight: 600;
    color: var(--color-primary, #013F3E);
    font-size: 1.3rem;
  }
  
  .wishlist-item__bottom {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    margin-top: auto;
  }
  
  .wishlist-item__remove {
    background: none;
    border: none;
    color: #999;
    font-size: 1.15rem;
    text-decoration: underline;
    cursor: pointer;
    font-family: inherit;
    transition: color 0.2s ease;
  }
  .wishlist-item__remove:hover {
    color: #D32F2F;
  }
{% endstyle %}

<script>
  function formatMoneyWishlist(cents) {
    if (window.formatMoney) {
      return window.formatMoney(cents);
    }
    if (!cents) return '₹0';
    return '₹' + (cents / 100).toLocaleString('en-IN', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
  }

  function renderWishlistDrawer() {
    const body = document.getElementById('WishlistDrawerBody');
    const countBadge = document.getElementById('WishlistDrawerCount');
    
    let items = [];
    try {
      const stored = localStorage.getItem('wishlist_items_data');
      if (stored) {
        items = JSON.parse(stored);
      }
    } catch(e) {
      console.error('Error reading wishlist from localStorage', e);
    }

    countBadge.textContent = items.length;
    
    // Update navbar badge if it exists
    const navbarBadge = document.getElementById('wishlist-count-badge');
    if (navbarBadge) {
        navbarBadge.textContent = items.length;
        navbarBadge.style.display = items.length > 0 ? 'flex' : 'none';
    }

    if (items.length === 0) {
      body.innerHTML = `
        <div class="wishlist-drawer__empty">
          <svg class="empty-wishlist-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12Z" />
          </svg>
          <p>Your wishlist is currently empty.</p>
          <button type="button" class="btn-continue" onclick="closeWishlistDrawer()">Continue Shopping</button>
        </div>
      `;
      return;
    }

    let html = '';
    items.forEach(item => {
      html += `
        <div class="wishlist-item" data-id="${item.id}">
          <img src="${item.image || '//cdn.shopify.com/s/images/themes/product-1.png'}" alt="${item.title}" class="wishlist-item__image">
          <div class="wishlist-item__details">
            <a href="${item.url || '#'}" class="wishlist-item__title">${item.title}</a>
            <div class="wishlist-item__price">${formatMoneyWishlist(item.price)}</div>
            
            <div class="wishlist-item__bottom">
              <button type="button" class="wishlist-item__remove" onclick="removeWishlistItem('${item.id}')">Remove</button>
            </div>
          </div>
        </div>
      `;
    });

    body.innerHTML = html;
  }

  window.removeWishlistItem = function(id) {
    let items = [];
    try {
      const stored = localStorage.getItem('wishlist_items_data');
      if (stored) {
        items = JSON.parse(stored);
      }
    } catch(e) {}

    items = items.filter(i => i.id !== id);
    localStorage.setItem('wishlist_items_data', JSON.stringify(items));
    
    let wishlistIds = [];
    try {
      const storedIds = localStorage.getItem('wishlist');
      if (storedIds) {
        wishlistIds = JSON.parse(storedIds);
      }
    } catch(e) {}
    
    wishlistIds = wishlistIds.filter(i => i !== id);
    localStorage.setItem('wishlist', JSON.stringify(wishlistIds));

    // Optional: uncheck the heart icon on the main product grid if it's visible on the page
    const heartBtn = document.querySelector(`[data-product-id="${id}"] .wishlist-btn.active`);
    if (heartBtn) {
       heartBtn.classList.remove('active');
    }

    renderWishlistDrawer();
  };

  window.openWishlistDrawer = function() {
    document.getElementById('WishlistDrawer').classList.add('is-open');
    document.body.style.overflow = 'hidden';
    document.body.classList.add('drawer-open');
    renderWishlistDrawer();
  };

  window.closeWishlistDrawer = function() {
    document.getElementById('WishlistDrawer').classList.remove('is-open');
    document.body.style.overflow = '';
    document.body.classList.remove('drawer-open');
  };
</script>

{% schema %}
{
  "name": "Wishlist Drawer",
  "settings": []
}
{% endschema %}
