      "label": "Title (Him)",
      "default": "Him"
    },
    {
      "type": "url",
      "id": "link_him",
      "label": "Link (Him)"
    },
    {
      "type": "header",
      "content": "Right Block (Her)"
    },
    {
      "type": "image_picker",
      "id": "image_her",
      "label": "Image (Her) - Desktop"
    },
    {
      "type": "image_picker",
      "id": "image_her_mobile",
      "label": "Image (Her) - Mobile"
    },
    {
      "type": "text",
      "id": "title_her",
      "label": "Title (Her)",
      "default": "Her"
    },
    {
      "type": "url",
      "id": "link_her",
      "label": "Link (Her)"
    },
    {
      "type": "header",
      "content": "Design Styling"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F8F5EF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#0a2a26"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#b38245"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#ebe7df"
    }
  ],
  "presets": [
    {
      "name": "Gifts for Him & Her"
    }
  ]
}
{% endschema %}
