
{%- liquid

  assign bg_color = section.settings.bg_color | default: '#fbf6f0'
  assign text_color = section.settings.text_color | default: '#0a2a26'
  assign accent_color = section.settings.accent_color | default: '#b38245'
-%}

<div class="gold-showcase" style="--bg-color: {{ bg_color }}; --text-color: {{ text_color }}; --accent-color: {{ accent_color }};">
  <div class="gold-showcase__wrapper">
    <!-- Left Banner -->
    <div class="gold-showcase__banner">
      {%- if section.settings.subheading != blank -%}
        <span class="gold-showcase__subheading">{{ section.settings.subheading | escape }}</span>
      {%- endif -%}
      
      <div class="gold-showcase__tagline-divider">
        <span class="gold-showcase__tagline-line"></span>
        <span class="gold-showcase__tagline-sparkle">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M12,2L14.8,9.2L22,12L14.8,14.8L12,22L9.2,14.8L2,12L9.2,9.2L12,2Z"/>
          </svg>
        </span>
      </div>

      {%- if section.settings.heading != blank -%}
        <h2 class="gold-showcase__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      <span class="gold-showcase__heading-underline"></span>

      {%- if section.settings.description != blank -%}
        <p class="gold-showcase__description">{{ section.settings.description | escape }}</p>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="gold-showcase__btn">
          {{ section.settings.button_label | escape }}
          <span class="gold-showcase__btn-arrow">&rarr;</span>
        </a>
      {%- endif -%}
    </div>

    <!-- Right Collections Grid -->
    <div class="gold-showcase__grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign collection = block.settings.collection
          assign custom_title = block.settings.title
          assign custom_image = block.settings.image
          
          assign collection_title = collection.title | default: 'Collection'
          if custom_title != blank
            assign collection_title = custom_title
          endif
          
          assign collection_image = collection.featured_image
          if custom_image != blank
            assign collection_image = custom_image
          endif
          
          assign collection_url = collection.url | default: routes.all_products_collection_url
        -%}
        <div class="gold-showcase__item" {{ block.shopify_attributes }}>
          <a href="{{ collection_url }}" class="gold-showcase__img-link" aria-label="{{ collection_title | escape }}">
            <div class="gold-showcase__img-container">
              {%- if collection_image != blank -%}
                {{ collection_image | image_url: width: 400, height: 550, crop: 'center' | image_tag: loading: 'lazy', alt: collection_title, class: 'gold-showcase__img' }}
              {%- else -%}
                {%- capture placeholder_index -%}{% cycle 1, 2, 3, 4, 5 %}{%- endcapture -%}
                {{ 'collection-' | append: placeholder_index | placeholder_svg_tag: 'gold-showcase__img placeholder-svg' }}
              {%- endif -%}
            </div>
          </a>
          
          <div class="gold-showcase__item-divider">
            <svg viewBox="0 0 24 24" fill="currentColor">
              <path d="M12,6L13.8,10.2L18,12L13.8,13.8L12,18L10.2,13.8L6,12L10.2,10.2L12,6Z"/>
            </svg>
          </div>

          <h3 class="gold-showcase__item-title">{{ collection_title | escape }}</h3>
          
          <a href="{{ collection_url }}" class="gold-showcase__explore">
            {{ 'sections.gold_collection_showcase.explore' | t | default: 'EXPLORE' }}
            <span class="gold-showcase__explore-arrow">&rarr;</span>
          </a>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
.gold-showcase {
  background-color: var(--bg-color);
  padding: 80px 40px;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}

.gold-showcase__wrapper {
  display: grid;
  grid-template-columns: 320px 1fr;
  gap: 60px;
  align-items: center;
  max-width: 1400px;
  margin: 0 auto;
}

.gold-showcase__banner {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  text-align: left;
}

.gold-showcase__subheading {
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.15em;
  color: var(--accent-color);
  text-transform: uppercase;
  display: block;
  margin-bottom: 12px;
}

.gold-showcase__tagline-divider {
  display: flex;
  align-items: center;
  margin-bottom: 25px;
  width: 100px;
}

.gold-showcase__tagline-line {
  flex-grow: 1;
  height: 1px;
  background-color: var(--accent-color);
  opacity: 0.6;
}

.gold-showcase__tagline-sparkle {
  width: 10px;
  height: 10px;
  color: var(--accent-color);
  margin-left: 8px;
  display: flex;
  align-items: center;
}

.gold-showcase__tagline-sparkle svg {
  width: 100%;
  height: 100%;
}

.gold-showcase__heading {
  font-family: Georgia, serif;
  font-size: 44px;
  line-height: 1.15;
  text-transform: uppercase;
  color: var(--text-color);
  margin: 0 0 20px 0;
  font-weight: normal;
  letter-spacing: 0.05em;
}

.gold-showcase__heading-underline {
  display: block;
  width: 60px;
  height: 1px;
  background-color: var(--accent-color);
  margin-bottom: 30px;
}

.gold-showcase__description {
  font-size: 15px;
  line-height: 1.6;
  color: var(--text-color);
  opacity: 0.85;
  margin: 0 0 10px 0;
  font-weight: 400;
  max-width: 280px;
}

.gold-showcase__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background-color: var(--text-color);
  color: var(--bg-color);
  border: 1px solid var(--text-color);
  padding: 13px 26px;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-decoration: none;
  text-transform: uppercase;
  border-radius: 2px;
  transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  cursor: pointer;
  margin-top: 25px;
}

.gold-showcase__btn:hover {
  background-color: transparent;
  color: var(--text-color);
  border-color: var(--text-color);
}

.gold-showcase__btn-arrow {
  margin-left: 8px;
  transition: transform 0.3s ease;
}

.gold-showcase__btn:hover .gold-showcase__btn-arrow {
  transform: translateX(4px);
}

.gold-showcase__grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 20px;
}

.gold-showcase__item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.gold-showcase__img-link {
  display: block;
  width: 100%;
  text-decoration: none;
}

.gold-showcase__img-container {
  aspect-ratio: 1 / 1.38;
  border-radius: 50%;
  overflow: hidden;
  position: relative;
  border: 1px solid rgba(0, 0, 0, 0.03);
  transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1);
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
}

.gold-showcase__img-container:hover {
  transform: scale(1.025);
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.05);
}

.gold-showcase__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
}

.gold-showcase__img-container:hover .gold-showcase__img {
  transform: scale(1.04);
}

.gold-showcase__img.placeholder-svg {
  background-color: rgba(0, 0, 0, 0.04);
  padding: 20px;
  box-sizing: border-box;
}

.gold-showcase__item-divider {
  width: 10px;
  height: 10px;
  color: var(--accent-color);
  margin: 18px auto 12px auto;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.8;
}

.gold-showcase__item-divider svg {
  width: 100%;
  height: 100%;
}

.gold-showcase__item-title {
  font-family: inherit;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-color);
  margin: 0 0 10px 0;
}

.gold-showcase__explore {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-color);
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  position: relative;
  padding-bottom: 2px;
}

.gold-showcase__explore::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 1px;
  background-color: var(--accent-color);
  transform: scaleX(0.4);
  transform-origin: center;
  transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.gold-showcase__explore:hover::after {
  transform: scaleX(1);
}

.gold-showcase__explore-arrow {
  margin-left: 5px;
  transition: transform 0.3s ease;
}

.gold-showcase__explore:hover .gold-showcase__explore-arrow {
  transform: translateX(3px);
}

@media screen and (max-width: 1024px) {
  .gold-showcase__wrapper {
    gap: 40px;
  }
  .gold-showcase__grid {
    gap: 15px;
  }
  .gold-showcase__heading {
    font-size: 36px;
  }
}

@media screen and (max-width: 768px) {
  .gold-showcase {
    padding: 60px 20px;
  }
  
  .gold-showcase__wrapper {
    grid-template-columns: 1fr;
    gap: 40px;
  }
  
  .gold-showcase__banner {
    align-items: center;
    text-align: center;
  }
  
  .gold-showcase__description {
    max-width: 100%;
  }
  
  .gold-showcase__heading-underline {
    margin-left: auto;
    margin-right: auto;
  }
  
  .gold-showcase__tagline-divider {
    justify-content: center;
  }
  
  .gold-showcase__grid {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: 20px;
    padding-bottom: 20px;
    margin: 0 -20px;
    padding-left: 20px;
    padding-right: 20px;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; /* Firefox */
  }
  
  .gold-showcase__grid::-webkit-scrollbar {
    display: none; /* Chrome, Safari */
  }
  
  .gold-showcase__item {
    flex: 0 0 160px;
    scroll-snap-align: start;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.gold_collection_showcase.name",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.gold_collection_showcase.settings.subheading",
      "default": "TIMELESS. TRADITIONAL. YOU."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.gold_collection_showcase.settings.heading",
      "default": "GOLD JEWELLERY"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "t:sections.gold_collection_showcase.settings.description",
      "default": "Classic designs crafted in pure gold, made for every celebration."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.gold_collection_showcase.settings.button_label",
      "default": "EXPLORE GOLD COLLECTION"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:sections.gold_collection_showcase.settings.button_link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:sections.gold_collection_showcase.settings.bg_color",
      "default": "#fbf6f0"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:sections.gold_collection_showcase.settings.text_color",
      "default": "#0a2a26"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "t:sections.gold_collection_showcase.settings.accent_color",
      "default": "#b38245"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "t:sections.gold_collection_showcase.blocks.collection.name",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:sections.gold_collection_showcase.blocks.collection.settings.collection"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.gold_collection_showcase.blocks.collection.settings.title"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.gold_collection_showcase.blocks.collection.settings.image"
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "t:sections.gold_collection_showcase.name",
      "blocks": [
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        }
      ]
    }
  ]
}
{% endschema %}
