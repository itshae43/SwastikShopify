{%- style -%}
  .section-instagram-reels {
    background-color: {{ section.settings.bg_color }};
    padding: 60px 20px;
    font-family: var(--font-body-family, sans-serif);
  }

  .instagram-reels__header {
    text-align: center;
    margin-bottom: 40px;
  }

  .instagram-reels__subheading {
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 12px;
    color: #333;
    margin-bottom: 10px;
    display: block;
  }

  .instagram-reels__heading {
    font-family: var(--font-heading-family, serif);
    font-size: 36px;
    color: #111;
    margin: 0 0 20px 0;
  }

  .instagram-reels__divider {
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 20px 0;
  }

  .instagram-reels__divider::before,
  .instagram-reels__divider::after {
    content: '';
    height: 1px;
    background-color: #d8c3b1; /* Goldish color */
    width: 60px;
    display: block;
  }

  .instagram-reels__divider svg {
    margin: 0 15px;
    width: 24px;
    height: 24px;
    stroke: #9a7d65;
  }

  .instagram-reels__description {
    font-size: 16px;
    color: #555;
    margin-bottom: 0;
  }

  .instagram-reels__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (max-width: 991px) {
    .instagram-reels__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 767px) {
    .instagram-reels__grid {
      display: flex;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 15px;
      padding-bottom: 20px;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none; /* Firefox */
    }
    .instagram-reels__grid::-webkit-scrollbar {
      display: none; /* Chrome, Safari */
    }
  }

  .instagram-reel__card {
    background: #000;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08), 0 2px 8px rgba(0, 0, 0, 0.04);
    display: flex;
    flex-direction: column;
    scroll-snap-align: start;
    min-width: 260px; /* For mobile flex */
    transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1), box-shadow 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  @media (hover: hover) {
    .instagram-reel__card:hover {
      transform: translateY(-6px);
      box-shadow: 0 16px 32px rgba(0, 0, 0, 0.12), 0 4px 12px rgba(0, 0, 0, 0.06);
    }
  }

  .instagram-reel__media-container {
    position: relative;
    width: 100%;
    padding-top: 150%; /* 2:3 Aspect Ratio for better reel proportion */
    background-color: #f4f4f4;
    cursor: pointer;
  }

  .instagram-reel__media {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .instagram-reel__media video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }


  .instagram-reel__play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    z-index: 2;
    transition: all 0.3s ease;
  }

  .instagram-reel__play-btn:hover {
    transform: translate(-50%, -50%) scale(1.1);
  }

  .instagram-reel__play-btn svg {
    width: 20px;
    height: 20px;
    fill: white;
    stroke: white;
  }

  .instagram-reel__views {
    position: absolute;
    bottom: 15px;
    left: 15px;
    color: white;
    font-size: 14px;
    display: flex;
    align-items: center;
    gap: 5px;
    z-index: 2;
    font-weight: 500;
  }

  /* Overlay gradient to make text visible */
  .instagram-reel__media-container::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0) 30%, rgba(0,0,0,0) 70%, rgba(0,0,0,0.5) 100%);
    pointer-events: none;
    z-index: 1;
  }



  .instagram-reels__footer {
    text-align: center;
    margin-top: 40px;
  }

  .instagram-reels__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 12px 24px;
    border: 1px solid #d8c3b1;
    border-radius: 4px;
    background: transparent;
    color: #111;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .instagram-reels__button:hover {
    background: #fdfaf7;
  }

  .instagram-reels__button svg {
    width: 16px;
    height: 16px;
    transition: transform 0.3s ease;
  }

  .instagram-reels__button:hover svg {
    transform: translateX(5px);
  }

  .is-playing .instagram-reel__play-btn {
    opacity: 0;
    pointer-events: none;
  }
{%- endstyle -%}

<div class="section-instagram-reels" style="background-color: {{ section.settings.bg_color }}">
  <div class="instagram-reels__header">
    {% if section.settings.subheading != blank %}
      <span class="instagram-reels__subheading">{{ section.settings.subheading }}</span>
    {% endif %}
    
    {% if section.settings.heading != blank %}
      <h2 class="instagram-reels__heading">{{ section.settings.heading }}</h2>
    {% endif %}
    
    <div class="instagram-reels__divider">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="feather feather-instagram">
        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
        <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
        <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
      </svg>
    </div>
    
    {% if section.settings.description != blank %}
      <p class="instagram-reels__description">{{ section.settings.description }}</p>
    {% endif %}
  </div>

  <div class="instagram-reels__grid">
    {% for block in section.blocks %}
      <div class="instagram-reel__card" {{ block.shopify_attributes }}>
        <div class="instagram-reel__media-container" onclick="togglePlay(this)">

          {% if block.settings.video != blank %}
            {{ block.settings.video | video_tag: image_size: "600x", autoplay: true, loop: true, muted: true, controls: false, class: "instagram-reel__media" }}
          {% elsif block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 600 | image_tag: class: "instagram-reel__media" }}
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'instagram-reel__media placeholder-svg' }}
          {% endif %}
          
          <div class="instagram-reel__play-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="5 3 19 12 5 21 5 3"></polygon>
            </svg>
          </div>
          
          {% if block.settings.view_count != blank %}
            <div class="instagram-reel__views">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-eye">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
              {{ block.settings.view_count }}
            </div>
          {% endif %}
        </div>

      </div>
    {% endfor %}
  </div>

  {% if section.settings.button_label != blank %}
    <div class="instagram-reels__footer">
      <a href="{{ section.settings.button_link | default: '#' }}" class="instagram-reels__button">
        {{ section.settings.button_label }}
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>
  {% endif %}
</div>

{% javascript %}
  function togglePlay(container) {
    const video = container.querySelector('video');
    if (!video) return;

    if (video.paused) {
      video.play();
      container.classList.add('is-playing');
    } else {
      video.pause();
      container.classList.remove('is-playing');
    }
  }

  function initInstagramReels() {
    document.querySelectorAll('.instagram-reel__media-container').forEach(function(container) {
      const video = container.querySelector('video');
      if (video) {
        if (!video.paused) {
          container.classList.add('is-playing');
        }
        video.addEventListener('play', function() {
          container.classList.add('is-playing');
        });
        video.addEventListener('pause', function() {
          container.classList.remove('is-playing');
        });
      }
    });
  }

  document.addEventListener("DOMContentLoaded", initInstagramReels);
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    initInstagramReels();
  }
{% endjavascript %}

{% schema %}
{
  "name": "Instagram Reels",
  "tag": "section",
  "class": "section-instagram-reels",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "FROM INSTAGRAM"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Jewellery Inspo, Just a Reels Away"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Explore trending styles, behind-the-scenes & more on our Instagram."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "FOLLOW US ON INSTAGRAM"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fdfaf7"
    }
  ],
  "blocks": [
    {
      "type": "reel",
      "name": "Reel",
      "limit": 6,
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Shopify Hosted Video",
          "info": "Upload a vertical video (9:16 aspect ratio) for best results."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Fallback Image",
          "info": "Displays if video is empty."
        },
        {
          "type": "text",
          "id": "view_count",
          "label": "View Count",
          "default": "12.6K"

        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Instagram Reels",
      "blocks": [
        { "type": "reel", "settings": { "view_count": "12.6K" } },
        { "type": "reel", "settings": { "view_count": "9.8K" } },
        { "type": "reel", "settings": { "view_count": "15.2K" } },
        { "type": "reel", "settings": { "view_count": "8.3K" } }
      ]
    }
  ]
}
{% endschema %}
