<div class="custom-contact-container">
    <!-- LEFT SIDE: Google Map -->
  <div class="contact-map">
    {% if section.settings.map_embed != blank %}
      {{ section.settings.map_embed }}
    {% else %}
      <div style="background: #eee; height: 100%; display: flex; align-items: center; justify-content: center;">
        <p>Please add map iframe in editor</p>
      </div>
    {% endif %}
  </div>

  <!-- RIGHT SIDE: Contact Details -->
  <div class="contact-details-wrapper">
    <h2 class="contact-title">{{ section.settings.heading }}</h2>
    <p class="contact-subtitle">{{ section.settings.subheading }}</p>
    
    <div class="contact-description">
      {{ section.settings.description }}
    </div>

    <div class="contact-section">
      <h3 class="contact-heading">
        <svg aria-hidden="true" focusable="false" viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 8px; color: #d94182;"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
        How to Reach Use!
      </h3>
      <p class="contact-info-text">{{ section.settings.business_hours }}</p>
    </div>

    <div class="contact-line-items">
      <p>
        <span class="icon-dot">⭕</span>
        <strong>Legal Entity Name:</strong> {{ section.settings.legal_entity }}
      </p>

      <p>
        <span class="icon-emoji">✉️</span> 
        <strong>Email:</strong> <a href="mailto:{{ section.settings.email }}">{{ section.settings.email }}</a>
      </p>

      <p>
        <span class="icon-emoji">📱</span> 
        <strong>Phone / WhatsApp:</strong> <a href="tel:{{ section.settings.phone | replace: ' ', '' }}">{{ section.settings.phone }}</a>
      </p>

      <p>
        <span class="icon-emoji">🏢</span> 
        <strong>Office Address:</strong> {{ section.settings.address }}
      </p>
    </div>
  </div>
</div>

<style>
  .custom-contact-container {
    display: flex;
    flex-wrap: wrap;
    max-width: 1300px;
    margin: 0 auto;
    padding: 60px 20px;
    gap: 60px;
    font-family: inherit;
    color: #333;
  }
  
  .contact-map {
    flex: 1 1 500px;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
  }

  .contact-map iframe {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 500px;
  }
  
  .contact-details-wrapper {
    flex: 1 1 450px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .contact-title { font-size: 2.2rem; margin-bottom: 8px; font-weight: 600; }
  .contact-subtitle { font-size: 1.1rem; font-weight: 500; margin-bottom: 25px; color: #555; }
  .contact-description { font-size: 0.95rem; line-height: 1.6; margin-bottom: 20px; color: #444; }
  .contact-section { margin-top: 20px; margin-bottom: 25px; }
  .contact-heading { font-size: 1.5rem; margin-bottom: 10px; display: flex; align-items: center; }
  .contact-info-text { font-size: 0.95rem; color: #444; }
  .contact-line-items p { font-size: 0.95rem; line-height: 1.5; margin-bottom: 15px; }
  .contact-line-items a { color: #000; text-decoration: underline; }
  .icon-emoji { display: inline-block; width: 20px; text-align: center; margin-right: 4px; }
  .icon-dot { display: inline-block; width: 20px; text-align: center; margin-right: 4px; color: #d94182; font-size: 1.2rem; }

  @media screen and (max-width: 768px) {
    .custom-contact-container { flex-direction: column; padding: 40px 15px; gap: 40px; }
    .contact-map iframe { height: 400px; min-height: 400px; }
  }
</style>

{% schema %}
{
  "name": "Custom Contact Layout",
  "settings": [
    {
      "type": "html",
      "id": "map_embed",
      "label": "Google Map Embed Iframe Code",
      "info": "Paste your map iframe code here"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get in Touch With Us!"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Have a question? We're just a message away! 💬"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description Text",
      "default": "<p>Whether you're wondering about our latest jewellery collections, need help with a custom order, or just want to say hello? — we're all ears!</p>"
    },
    {
      "type": "text",
      "id": "business_hours",
      "label": "Business Hours",
      "default": "Monday to Saturday, 10 AM to 6 PM (IST)"
    },
    {
      "type": "text",
      "id": "legal_entity",
      "label": "Legal Entity Name",
      "default": "Swastik Jewels Private Limited"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email Address",
      "default": "support@swastikjewels.com"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone Number",
      "default": "+91 98765 43210"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "Office Address",
      "default": "123 Mock Address Lane, New Delhi"
    }
  ],
  "presets": [
    {
      "name": "Custom Contact Layout"
    }
  ]
}
{% endschema %}
