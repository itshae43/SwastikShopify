{% schema %}
{
  "name": "Video Scheduling Form",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Schedule a Video Consultation"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Book a time with our jewelry experts to view our collection via video call.</p>"
    }
  ],
  "presets": [
    {
      "name": "Video Scheduling Form",
      "category": "Forms"
    }
  ]
}
{% endschema %}

<div class="video-scheduling-section page-width">
  <div class="video-scheduling-container">
    {% if section.settings.heading != blank %}
      <h2 class="video-scheduling-title">{{ section.settings.heading }}</h2>
    {% endif %}
    {% if section.settings.description != blank %}
      <div class="video-scheduling-description">{{ section.settings.description }}</div>
    {% endif %}

    <form id="video-scheduling-form" class="video-scheduling-form">
      <div class="form-row">
        <div class="form-group">
          <label for="first_name">First Name *</label>
          <input type="text" id="first_name" name="first_name" required>
        </div>
        <div class="form-group">
          <label for="last_name">Last Name *</label>
          <input type="text" id="last_name" name="last_name" required>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="email">Email Address *</label>
          <input type="email" id="email" name="email" required>
        </div>
        <div class="form-group">
          <label for="whatsapp_number">WhatsApp Number *</label>
          <input type="tel" id="whatsapp_number" name="whatsapp_number" placeholder="+91..." required>
        </div>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="meeting_date">Preferred Date *</label>
          <input type="date" id="meeting_date" name="meeting_date" required>
        </div>
        <div class="form-group">
          <label for="meeting_time">Preferred Time *</label>
          <input type="time" id="meeting_time" name="meeting_time" required>
        </div>
      </div>
      
      <div class="form-row">
        <div class="form-group">
          <label for="meeting_platform">Preferred Meeting Platform *</label>
          <select id="meeting_platform" name="meeting_platform" required>
            <option value="Google Meet">Google Meet</option>
            <option value="WhatsApp">WhatsApp Video Call</option>
          </select>
        </div>
      </div>

      <div id="scheduling-success-message" class="form-message form-message--success" style="display: none;">
        Thank you! Your video consultation has been requested. We will contact you shortly to confirm.
      </div>
      <div id="scheduling-error-message" class="form-message form-message--error" style="display: none;">
        Sorry, there was an error submitting your request. Please try again later.
      </div>

      <button type="submit" class="button button--primary">Confirm & Schedule</button>
    </form>
  </div>
</div>

<style>
  .video-scheduling-section {
    padding: 4rem 2rem;
    max-width: 800px;
    margin: 0 auto;
  }
  .video-scheduling-container {
    background: #f9f9f9;
    padding: 3rem;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.05);
  }
  .video-scheduling-title {
    text-align: center;
    margin-bottom: 1rem;
    font-size: 2.4rem;
  }
  .video-scheduling-description {
    text-align: center;
    margin-bottom: 2rem;
    color: #555;
  }
  .video-scheduling-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .form-row {
    display: flex;
    gap: 1.5rem;
  }
  .form-group {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .form-group label {
    font-weight: 500;
    font-size: 1.2rem;
    letter-spacing: 0.5px;
  }
  .form-group input, .form-group select {
    padding: 1rem;
    border: 1px solid #ddd;
    border-radius: 4px;
    font-size: 1.4rem;
    width: 100%;
    box-sizing: border-box;
    transition: border-color 0.3s ease;
    background-color: white;
  }
  .form-group input:focus, .form-group select:focus {
    outline: none;
    border-color: #000;
  }
  .form-message {
    padding: 1.2rem;
    border-radius: 4px;
    text-align: center;
    font-size: 1.4rem;
  }
  .form-message--success {
    background-color: #d4edda;
    color: #155724;
    border: 1px solid #c3e6cb;
  }
  .form-message--error {
    background-color: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
  }
  .video-scheduling-form button {
    margin-top: 1rem;
    padding: 1.2rem;
    font-size: 1.4rem;
    cursor: pointer;
    width: 100%;
  }
  
  @media (max-width: 768px) {
    .form-row {
      flex-direction: column;
      gap: 1.5rem;
    }
    .video-scheduling-container {
      padding: 1.5rem;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('video-scheduling-form');
    if (!form) return;
    
    const submitButton = form.querySelector('button[type="submit"]');
    const successMessage = document.getElementById('scheduling-success-message');
    const errorMessage = document.getElementById('scheduling-error-message');

    // Set minimum date to today so users cannot pick past dates
    const dateInput = document.getElementById('meeting_date');
    if(dateInput) {
        const today = new Date().toISOString().split('T')[0];
        dateInput.setAttribute('min', today);
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      // UI Loading state - prevent double clicks
      submitButton.disabled = true;
      submitButton.textContent = 'Scheduling...';
      successMessage.style.display = 'none';
      errorMessage.style.display = 'none';

      const formData = new FormData(form);
      const data = {
        first_name: formData.get('first_name'),
        last_name: formData.get('last_name'),
        email: formData.get('email'),
        whatsapp_number: formData.get('whatsapp_number'),
        meeting_date: formData.get('meeting_date'),
        meeting_time: formData.get('meeting_time'),
        meeting_platform: formData.get('meeting_platform')
      };

      try {
        // Send the JSON payload to the CRM endpoint
        const response = await fetch('https://staging-api.swastikjewel.in/api/auth/lead/shopify-scheduling', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify(data)
        });

        if (response.ok) {
          // Success! Show message and clear form
          successMessage.style.display = 'block';
          form.reset();
        } else {
          // Server returned an error (e.g. 400 or 500)
          errorMessage.style.display = 'block';
          console.error('CRM Error:', await response.text());
        }
      } catch (error) {
        // Network error or CORS issue
        errorMessage.style.display = 'block';
        console.error('Network Error:', error);
      } finally {
        // Reset button state
        submitButton.disabled = false;
        submitButton.textContent = 'Confirm & Schedule';
      }
    });
  });
</script>
