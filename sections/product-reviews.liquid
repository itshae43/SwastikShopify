{% schema %}
{
  "name": "Product Reviews",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "What people are saying?"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Section Subheading",
      "default": "Don't just take our word for it—see what our customers have to say about their experience!"
    },
    {
      "type": "text",
      "id": "whatsapp_number",
      "label": "WhatsApp Number",
      "default": "+91 96500 90730"
    },
    {
      "type": "url",
      "id": "whatsapp_link",
      "label": "WhatsApp Chat Link"
    }
  ],
  "blocks": [
    {
      "type": "review_card",
      "name": "Review Card",
      "settings": [
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review Text",
          "default": "Absolutely stunning diamond ring! The craftsmanship is incredible and it sparkles beautifully."
        },
        {
          "type": "text",
          "id": "customer_name",
          "label": "Customer Name",
          "default": "Priya Sharma"
        },
        {
          "type": "text",
          "id": "customer_location",
          "label": "Customer Location",
          "default": "New Delhi, India"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Star Rating",
          "min": 1,
          "max": 5,
          "default": 5
        },
        {
          "type": "text",
          "id": "time",
          "label": "Message Time",
          "default": "10:30 AM"
        },
        {
          "type": "image_picker",
          "id": "chat_screenshot",
          "label": "WhatsApp Chat Screenshot (optional)"
        },
        {
          "type": "select",
          "id": "card_color",
          "label": "Card Background Color",
          "options": [
            { "value": "green", "label": "Light Green" },
            { "value": "pink", "label": "Light Pink" },
            { "value": "yellow", "label": "Light Yellow" },
            { "value": "blue", "label": "Light Blue" },
            { "value": "peach", "label": "Light Peach" },
            { "value": "lavender", "label": "Light Lavender" }
          ],
          "default": "green"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Reviews",
      "blocks": [
        {
          "type": "review_card",
          "settings": {
            "review_text": "The 18K gold necklace is absolutely breathtaking! The quality exceeded my expectations. Every detail is perfect and it sparkles like nothing I've seen before.",
            "customer_name": "Priya Sharma",
            "customer_location": "New Delhi, India",
            "rating": 5,
            "time": "9:30 AM",
            "card_color": "green"
          }
        },
        {
          "type": "review_card",
          "settings": {
            "review_text": "Ordered a diamond pendant for my anniversary. The packaging was luxurious and delivery was super fast. My wife absolutely loves it!",
            "customer_name": "Rajesh Gupta",
            "customer_location": "Mumbai, India",
            "rating": 5,
            "time": "10:12 AM",
            "card_color": "yellow"
          }
        },
        {
          "type": "review_card",
          "settings": {
            "review_text": "I never knew online jewellery shopping could be this good! The diamond clarity is amazing and the hallmarked gold feels so premium.",
            "customer_name": "Aisha Khan",
            "customer_location": "Hyderabad, India",
            "rating": 5,
            "time": "11:05 AM",
            "card_color": "pink"
          }
        },
        {
          "type": "review_card",
          "settings": {
            "review_text": "Been a loyal customer for 2 years now. Every piece I've bought from Swastik Jewels has been exceptional. The craftsmanship speaks for itself!",
            "customer_name": "Sneha Reddy",
            "customer_location": "Bangalore, India",
            "rating": 5,
            "time": "12:45 PM",
            "card_color": "blue"
          }
        },
        {
          "type": "review_card",
          "settings": {
            "review_text": "The engagement ring I ordered was absolutely perfect. The diamond quality, the gold finish, everything was exactly as shown. Highly recommend!",
            "customer_name": "Amit Patel",
            "customer_location": "Ahmedabad, India",
            "rating": 5,
            "time": "1:20 PM",
            "card_color": "peach"
          }
        },
        {
          "type": "review_card",
          "settings": {
            "review_text": "Bought earrings for my mother's birthday. She was thrilled! The packaging made it feel like a gift from a luxury boutique. Will definitely order again.",
            "customer_name": "Meera Iyer",
            "customer_location": "Chennai, India",
            "rating": 5,
            "time": "2:10 PM",
            "card_color": "lavender"
          }
        },
        {
          "type": "review_card",
          "settings": {
            "review_text": "I compared prices with many brands, Swastik Jewels offers the best value for certified diamond jewellery. 100% genuine and beautiful designs!",
            "customer_name": "Neha Saxena",
            "customer_location": "Jaipur, India",
            "rating": 5,
            "time": "3:15 PM",
            "card_color": "green"
          }
        },
        {
          "type": "review_card",
          "settings": {
            "review_text": "The buyback policy gave me so much confidence to order online. The bracelet arrived beautifully and fits perfectly. Outstanding service!",
            "customer_name": "Kavita Joshi",
            "customer_location": "Pune, India",
            "rating": 5,
            "time": "4:00 PM",
            "card_color": "yellow"
          }
        }
      ]
    }
  ]
}
{% endschema %}

<div class="wpr-section">
  <!-- Section Header -->
  <div class="wpr-header">
    <div class="wpr-header-ornament">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#D4AF37" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
    </div>
    <h2 class="wpr-title">{{ section.settings.heading }}</h2>
    <p class="wpr-subtitle">{{ section.settings.subheading }}</p>

    <!-- WhatsApp CTA Button -->
    <a href="{{ section.settings.whatsapp_link | default: '#' }}" class="wpr-wa-cta" target="_blank" rel="noopener noreferrer">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="#25D366"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 0 0-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
      <span>Chat with us on WhatsApp&nbsp;&nbsp;{{ section.settings.whatsapp_number }}</span>
    </a>
  </div>

  <!-- Row 1: Marquee scrolling RIGHT (text reviews) -->
  <div class="wpr-marquee-wrap">
    <div class="wpr-marquee wpr-marquee-row1" id="wpr-marquee-row1">
      {% for block in section.blocks %}
        {% if block.settings.chat_screenshot == blank %}
          <div class="wpr-card wpr-card--{{ block.settings.card_color }}" {{ block.shopify_attributes }}>
            <!-- Quote icon -->
            <div class="wpr-card-quote">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" opacity="0.15"><path d="M6 17h3l2-4V7H5v6h3l-2 4zm8 0h3l2-4V7h-6v6h3l-2 4z"/></svg>
            </div>
            <p class="wpr-card-text">{{ block.settings.review_text }}</p>

            <div class="wpr-card-footer">
              <div class="wpr-card-author">
                <span class="wpr-card-name">{{ block.settings.customer_name }}</span>
                <span class="wpr-card-location">{{ block.settings.customer_location }}</span>
              </div>
              <div class="wpr-card-meta">
                <div class="wpr-card-stars">
                  {% for i in (1..5) %}
                    {% if i <= block.settings.rating %}
                      <svg viewBox="0 0 24 24" width="14" height="14" fill="#F5C518"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                    {% else %}
                      <svg viewBox="0 0 24 24" width="14" height="14" fill="#E0E0E0"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                    {% endif %}
                  {% endfor %}
                </div>
                <span class="wpr-card-time">{{ block.settings.time }}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#53bdeb" stroke-width="2.5"><path d="M18 6L7 17l-5-5"/><path d="M22 10l-11 11"/></svg>
                </span>
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}

      {%- comment -%} Duplicate for seamless infinite scroll {%- endcomment -%}
      {% for block in section.blocks %}
        {% if block.settings.chat_screenshot == blank %}
          <div class="wpr-card wpr-card--{{ block.settings.card_color }}" aria-hidden="true">
