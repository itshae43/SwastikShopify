                </div>
                <span class="wpr-card-time">{{ block.settings.time }}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#53bdeb" stroke-width="2.5"><path d="M18 6L7 17l-5-5"/><path d="M22 10l-11 11"/></svg>
                </span>
              </div>
            </div>
          </div>
        {% else %}
          <!-- Text Card (duplicate in row 2 for fullness) -->
          <div class="wpr-card wpr-card--{{ block.settings.card_color }}" {{ block.shopify_attributes }}>
            <div class="wpr-card-quote">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" opacity="0.15"><path d="M6 17h3l2-4V7H5v6h3l-2 4zm8 0h3l2-4V7h-6v6h3l-2 4z"/></svg>
