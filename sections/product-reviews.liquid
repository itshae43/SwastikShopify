{% stylesheet %}
  /* ===== WhatsApp-Style Product Reviews Section ===== */
  .wpr-section {
    padding: 60px 0 70px 0;
    overflow: hidden;
    font-family: 'Inter', sans-serif;
    background: #FAFAFA;
  }

  /* Header */
  .wpr-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 40px auto;
    padding: 0 24px;
  }

  .wpr-header-ornament {
    margin-bottom: 8px;
    opacity: 0.7;
  }

  .wpr-title {
    font-family: 'Cormorant Garamond', 'Playfair Display', serif;
    font-size: 2.6rem;
    font-weight: 700;
    color: #013F3E;
    margin: 0 0 12px 0;
    line-height: 1.15;
  }

  .wpr-subtitle {
    font-size: 1rem;
    color: #666;
    margin: 0 0 24px 0;
    line-height: 1.6;
  }

  .wpr-wa-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #FFFFFF;
    border: 1.5px solid #25D366;
    border-radius: 50px;
    padding: 10px 28px;
    font-size: 14px;
    font-weight: 600;
    color: #333;
    text-decoration: none;
    transition: all 0.25s ease;
    box-shadow: 0 2px 10px rgba(37, 211, 102, 0.1);
  }

  .wpr-wa-cta:hover {
    background: #25D366;
    color: #FFFFFF;
    box-shadow: 0 6px 20px rgba(37, 211, 102, 0.25);
    transform: translateY(-1px);
  }

  .wpr-wa-cta:hover svg {
    fill: #FFFFFF;
  }

  /* ===== Marquee Container ===== */
  .wpr-marquee-wrap {
    overflow: hidden;
    position: relative;
    margin-bottom: 20px;
    padding: 4px 0;
  }

  /* Fade edges */
  .wpr-marquee-wrap::before,
  .wpr-marquee-wrap::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 80px;
    z-index: 2;
    pointer-events: none;
  }
  .wpr-marquee-wrap::before {
    left: 0;
    background: linear-gradient(to right, #FAFAFA 0%, transparent 100%);
  }
  .wpr-marquee-wrap::after {
    right: 0;
    background: linear-gradient(to left, #FAFAFA 0%, transparent 100%);
  }

  .wpr-marquee {
    display: flex;
    gap: 20px;
    width: max-content;
    will-change: transform;
  }

  /* Row 1 scrolls RIGHT */
  .wpr-marquee-row1 {
    animation: wpr-scroll-right 60s linear infinite;
  }

  /* Row 2 scrolls LEFT */
  .wpr-marquee-row2 {
    animation: wpr-scroll-left 65s linear infinite;
  }

  @keyframes wpr-scroll-right {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes wpr-scroll-left {
    0% { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }

  /* Pause on hover */
  .wpr-marquee-wrap:hover .wpr-marquee {
    animation-play-state: paused;
  }

  /* ===== Review Card ===== */
  .wpr-card {
    flex: 0 0 340px;
    border-radius: 16px;
    padding: 22px 24px 16px 24px;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    cursor: default;
    border: 1px solid rgba(0,0,0,0.06);
  }

  .wpr-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }

  /* Card color variants */
  .wpr-card--green {
    background: linear-gradient(145deg, #E8F5E9 0%, #F1F8E9 100%);
    border-color: #C8E6C9;
    color: #2E7D32;
  }
  .wpr-card--pink {
    background: linear-gradient(145deg, #FCE4EC 0%, #F8BBD0 30%, #FCE4EC 100%);
    border-color: #F8BBD0;
    color: #AD1457;
  }
  .wpr-card--yellow {
    background: linear-gradient(145deg, #FFF8E1 0%, #FFF3C4 100%);
    border-color: #FFE082;
    color: #F57F17;
  }
  .wpr-card--blue {
    background: linear-gradient(145deg, #E3F2FD 0%, #BBDEFB 40%, #E3F2FD 100%);
    border-color: #90CAF9;
    color: #1565C0;
  }
  .wpr-card--peach {
    background: linear-gradient(145deg, #FFF3E0 0%, #FFE0B2 40%, #FFF3E0 100%);
    border-color: #FFCC80;
    color: #E65100;
  }
  .wpr-card--lavender {
    background: linear-gradient(145deg, #F3E5F5 0%, #E1BEE7 40%, #F3E5F5 100%);
    border-color: #CE93D8;
    color: #6A1B9A;
  }

  .wpr-card-quote {
    position: absolute;
    top: 16px;
    left: 18px;
    line-height: 1;
  }

  .wpr-card-text {
    font-size: 14px;
    font-style: italic;
    line-height: 1.65;
    color: #333;
    margin: 8px 0 16px 0;
    padding-top: 12px;
    flex: 1;
  }

  /* Card Footer: Author + Stars + Time */
  .wpr-card-footer {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
    border-top: 1px solid rgba(0,0,0,0.06);
    padding-top: 12px;
    margin-top: auto;
  }

  .wpr-card-author {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .wpr-card-name {
    font-size: 13px;
    font-weight: 700;
    color: #222;
    font-style: normal;
  }

  .wpr-card-location {
    font-size: 11px;
    color: #888;
    font-style: normal;
  }

  .wpr-card-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
  }

  .wpr-card-stars {
    display: flex;
    gap: 1px;
  }

  .wpr-card-time {
    font-size: 10px;
    color: #999;
    display: flex;
    align-items: center;
    gap: 4px;
    font-style: normal;
  }

  /* ===== Screenshot Card ===== */
  .wpr-card--screenshot {
    padding: 0;
    overflow: hidden;
    flex: 0 0 280px;
  }

  .wpr-screenshot-img {
    width: 100%;
    overflow: hidden;
    border-radius: 16px 16px 0 0;
  }

  .wpr-screenshot-img img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .wpr-card--screenshot .wpr-card-footer {
    padding: 12px 16px 14px 16px;
    border-top: none;
    margin-top: 0;
  }

  /* ===== Mobile: hide for now (desktop only) ===== */
  @media screen and (max-width: 768px) {
    .wpr-section {
      display: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  /* Ensure marquee pauses on hover and resumes on mouse leave */
  document.addEventListener('DOMContentLoaded', function() {
    var marquees = document.querySelectorAll('.wpr-marquee');
    marquees.forEach(function(m) {
      m.addEventListener('mouseenter', function() {
        this.style.animationPlayState = 'paused';
      });
      m.addEventListener('mouseleave', function() {
        this.style.animationPlayState = 'running';
      });
    });
  });
{% endjavascript %}
