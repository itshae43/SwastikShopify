            </div>
            <p class="wpr-card-text">{{ block.settings.review_text }}</p>

            <div class="wpr-card-footer">
              <div class="wpr-card-author">
                <span class="wpr-card-name">{{ block.settings.customer_name }}</span>
                <span class="wpr-card-location">{{ block.settings.customer_location }}</span>
              </div>
              <div class="wpr-card-meta">
                <div class="wpr-card-stars">
                  {% for i in (1..5) %}
                    {% if i <= block.settings.rating %}
                      <svg viewBox="0 0 24 24" width="14" height="14" fill="#F5C518"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                    {% else %}
                      <svg viewBox="0 0 24 24" width="14" height="14" fill="#E0E0E0"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                    {% endif %}
                  {% endfor %}
                </div>
                <span class="wpr-card-time">{{ block.settings.time }}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#53bdeb" stroke-width="2.5"><path d="M18 6L7 17l-5-5"/><path d="M22 10l-11 11"/></svg>
                </span>
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <!-- Row 2: Marquee scrolling LEFT (mix of text + screenshot reviews) -->
  <div class="wpr-marquee-wrap">
    <div class="wpr-marquee wpr-marquee-row2" id="wpr-marquee-row2">
